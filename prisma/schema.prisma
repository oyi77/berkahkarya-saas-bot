// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER MODEL
// =============================================================================
model User {
  id                BigInt    @id @default(autoincrement())
  telegramId        BigInt    @unique @map("telegram_id")
  uuid              String    @unique @default(uuid()) @db.Uuid
  username          String?   @db.VarChar(32)
  firstName         String    @map("first_name") @db.VarChar(64)
  lastName          String?   @map("last_name") @db.VarChar(64)
  phoneNumber       String?   @map("phone_number") @db.VarChar(20)
  
  // Tier & Credits
  tier              String    @default("free") @db.VarChar(16)
  creditBalance     Decimal   @default(0) @map("credit_balance") @db.Decimal(10, 2)
  creditExpiresAt   DateTime? @map("credit_expires_at")
  
  // Referral
  referralCode      String?   @unique @map("referral_code") @db.VarChar(32)
  referredBy        String?   @map("referred_by") @db.Uuid
  referralTier      Int       @default(1) @map("referral_tier")
  
  // Settings
  language          String    @default("id") @db.VarChar(5)
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")
  autoRenewal       Boolean   @default(false) @map("auto_renewal")
  
  // Free Trial
  welcomeBonusUsed  Boolean   @default(false) @map("welcome_bonus_used")
  dailyFreeUsed     Boolean   @default(false) @map("daily_free_used")
  dailyFreeResetAt  DateTime? @map("daily_free_reset_at")
  selectedNiche     String?   @map("selected_niche") @db.VarChar(32)
  
  // Security
  isBanned          Boolean   @default(false) @map("is_banned")
  banReason         String?   @map("ban_reason")
  bannedAt          DateTime? @map("banned_at")
  fraudScore        Int       @default(0) @map("fraud_score")
  
  // Metadata
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastActivityAt    DateTime  @default(now()) @map("last_activity_at")
  
  // UTM & Attribution Tracking (Full Funnel)
  utmSource         String?   @map("utm_source") @db.VarChar(255)
  utmMedium         String?   @map("utm_medium") @db.VarChar(255)
  utmCampaign       String?   @map("utm_campaign") @db.VarChar(255)
  utmContent        String?   @map("utm_content") @db.VarChar(255)
  lpVariant         String?   @map("lp_variant") @db.VarChar(50)
  
  // Attribution IDs (for platform matching)
  fbc               String?   @map("fbc") @db.VarChar(500) // Facebook Click ID
  fbp               String?   @map("fbp") @db.VarChar(500) // Facebook Pixel ID
  ttclid            String?   @map("ttclid") @db.VarChar(500) // TikTok Click ID
  
  // LTV Metrics
  daysToFirstPurchase Int?    @map("days_to_first_purchase")
  signupToFirstVideoMin Int?  @map("signup_to_first_video_min")
  totalSpent        Decimal   @default(0) @map("total_spent") @db.Decimal(12, 2)
  
  // Relations
  transactions      Transaction[]
  videos            Video[]
  commissions       Commission[]
  subscriptions     Subscription[]
  socialAccounts    SocialAccount[]
  avatars           UserAvatar[]
  
  @@index([telegramId])
  @@index([referralCode])
  @@index([tier])
  @@index([lastActivityAt])
  @@map("users")
}

// =============================================================================
// TRANSACTION MODEL
// =============================================================================
model Transaction {
  id                    BigInt    @id @default(autoincrement())
  orderId               String    @unique @map("order_id") @db.VarChar(64)
  userId                BigInt    @map("user_id")
  
  // Transaction details
  type                  String    @db.VarChar(32)
  packageName           String?   @map("package_name") @db.VarChar(32)
  amountIdr             Decimal   @map("amount_idr") @db.Decimal(12, 2)
  creditsAmount         Decimal?  @map("credits_amount") @db.Decimal(10, 2)
  
  // Payment details
  gateway               String    @db.VarChar(16)
  gatewayTransactionId  String?   @map("gateway_transaction_id") @db.VarChar(128)
  paymentMethod         String?   @map("payment_method") @db.VarChar(32)
  paymentChannel        String?   @map("payment_channel") @db.VarChar(32)
  
  // Status tracking
  status                String    @default("pending") @db.VarChar(16)
  statusHistory         Json?     @map("status_history")
  
  // Timestamps
  createdAt             DateTime  @default(now()) @map("created_at")
  paidAt                DateTime? @map("paid_at")
  expiredAt             DateTime? @default(dbgenerated("NOW() + INTERVAL '30 minutes'")) @map("expired_at")
  
  // Metadata
  ipAddress             String?   @map("ip_address") @db.Inet
  userAgent             String?   @map("user_agent")
  metadata              Json?
  
  // UTM & Attribution (for LTV tracking)
  utmCampaign           String?   @map("utm_campaign") @db.VarChar(255)
  utmContent            String?   @map("utm_content") @db.VarChar(255)
  lpVariant             String?   @map("lp_variant") @db.VarChar(50)
  daysToConversion      Int?      @map("days_to_conversion")
  
  // Relations
  user                  User      @relation(fields: [userId], references: [telegramId])
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

// =============================================================================
// VIDEO MODEL
// =============================================================================
model Video {
  id              BigInt    @id @default(autoincrement())
  userId          BigInt    @map("user_id")
  jobId           String    @unique @map("job_id") @db.VarChar(64)
  
  // Video details
  title           String?   @db.VarChar(255)
  description     String?   @db.Text
  
  // Generation params
  niche           String    @db.VarChar(32)
  platform        String    @db.VarChar(32)
  duration        Int
  scenes          Int
  
  // Output
  thumbnailUrl    String?   @map("thumbnail_url")
  videoUrl        String?   @map("video_url")
  downloadUrl     String?   @map("download_url")
  
  // Status
  status          String    @default("processing") @db.VarChar(16)
  progress        Int       @default(0)
  errorMessage    String?   @map("error_message")
  favorited       Boolean   @default(false)

  // Credits
  creditsUsed     Decimal   @map("credits_used") @db.Decimal(10, 2)

  // Phase 1: Multi-provider & style fields
  styles             String[]
  storyboard         Json?
  providerChain      String[]  @map("provider_chain")
  optimizedPrompts   Json?     @map("optimized_prompts")
  productAnalysis    Json?     @map("product_analysis")
  generationMetadata Json?     @map("generation_metadata")
  finalProvider      String?   @map("final_provider")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  expiresAt       DateTime? @default(dbgenerated("NOW() + INTERVAL '30 days'")) @map("expires_at")

  // Relations
  user            User      @relation(fields: [userId], references: [telegramId])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([niche])
  @@map("videos")
}

// =============================================================================
// COMMISSION MODEL (Affiliate)
// =============================================================================
model Commission {
  id              BigInt    @id @default(autoincrement())
  referrerId      BigInt    @map("referrer_id")
  referredId      BigInt    @map("referred_id")
  
  // Commission details
  amount          Decimal   @db.Decimal(12, 2)
  tier            Int
  status          String    @default("pending") @db.VarChar(16)
  
  // Availability
  availableAt     DateTime  @map("available_at")
  withdrawnAt     DateTime? @map("withdrawn_at")
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  referrer        User      @relation(fields: [referrerId], references: [telegramId])
  
  @@index([referrerId])
  @@index([status])
  @@index([availableAt])
  @@map("commissions")
}

// =============================================================================
// SUBSCRIPTION MODEL
// =============================================================================
model Subscription {
  id                  BigInt    @id @default(autoincrement())
  userId              BigInt    @map("user_id")
  
  plan                String    @db.VarChar(16)
  billingCycle        String    @map("billing_cycle") @db.VarChar(16)
  
  status              String    @default("active") @db.VarChar(16)
  
  currentPeriodStart  DateTime  @map("current_period_start")
  currentPeriodEnd    DateTime  @map("current_period_end")
  
  cancelAtPeriodEnd   Boolean   @default(false) @map("cancel_at_period_end")
  cancelledAt         DateTime? @map("cancelled_at")
  
  paymentMethodId     String?   @map("payment_method_id") @db.VarChar(64)
  
  metadata            Json?
  
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user                User      @relation(fields: [userId], references: [telegramId])
  
  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// =============================================================================
// AUDIT LOG MODEL
// =============================================================================
model AuditLog {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt?   @map("user_id")
  action      String    @db.VarChar(64)
  entityType  String    @map("entity_type") @db.VarChar(32)
  entityId    String    @map("entity_id") @db.VarChar(64)
  oldValue    Json?     @map("old_value")
  newValue    Json?     @map("new_value")
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// SOCIAL ACCOUNT MODEL (PostBridge Integration)
// =============================================================================
model SocialAccount {
  id              Int      @id @default(autoincrement())
  userId          BigInt   @map("user_id")
  platform        String   @db.VarChar(32) // tiktok, facebook, instagram, etc
  pbAccountId     String   @unique @map("pb_account_id") @db.VarChar(64)
  accountName     String?  @map("account_name") @db.VarChar(128)
  avatarUrl       String?  @map("avatar_url")
  status          String   @default("active") @db.VarChar(16)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  user            User     @relation(fields: [userId], references: [telegramId])

  @@index([userId])
  @@map("social_accounts")
}

// =============================================================================
// PAYMENT SETTINGS MODEL
// =============================================================================
model PaymentSettings {
  id                    Int      @id @default(autoincrement())
  key                   String   @unique @db.VarChar(64)
  value                 String   @db.VarChar(256)
  description           String?  @db.VarChar(256)
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedBy             BigInt?  @map("updated_by")
  
  @@map("payment_settings")
}

// =============================================================================
// PROVIDER HEALTH MODEL (Phase 1)
// =============================================================================
model ProviderHealth {
  provider            String    @id
  status              String    @default("healthy")
  lastSuccess         DateTime? @map("last_success")
  lastFailure         DateTime? @map("last_failure")
  failureCount        Int       @default(0) @map("failure_count")
  avgResponseTime     Int?      @map("avg_response_time")
  circuitBreakerState String    @default("closed") @map("circuit_breaker_state")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  @@map("provider_health")
}

// =============================================================================
// PROMPT CACHE MODEL (Phase 1)
// =============================================================================
model PromptCache {
  id              Int      @id @default(autoincrement())
  promptHash      String   @unique @map("prompt_hash") @db.VarChar(32)
  rawPrompt       String   @map("raw_prompt") @db.Text
  provider        String   @db.VarChar(50)
  styleKey        String?  @map("style_key") @db.VarChar(100)
  optimizedPrompt String   @map("optimized_prompt") @db.Text
  tokenEstimate   Int?     @map("token_estimate")
  hitCount        Int      @default(0) @map("hit_count")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")
  @@index([promptHash])
  @@index([expiresAt])
  @@map("prompt_cache")
}

// =============================================================================
// USER AVATAR MODEL (Persistent character/identity for consistent generation)
// =============================================================================
model UserAvatar {
  id              Int       @id @default(autoincrement())
  userId          BigInt    @map("user_id")
  name            String    @db.VarChar(64)
  imageUrl        String    @map("image_url")
  localPath       String?   @map("local_path")
  description     String?   @db.Text
  features        Json?
  isDefault       Boolean   @default(false) @map("is_default")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [telegramId])

  @@index([userId])
  @@index([userId, isDefault])
  @@map("user_avatars")
}

// =============================================================================
// PRICING CONFIG MODEL (Dynamic pricing — packages, subscriptions, provider costs)
// =============================================================================
model PricingConfig {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(32)
  key         String   @db.VarChar(64)
  value       Json
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   BigInt?  @map("updated_by")

  @@unique([category, key])
  @@index([category])
  @@map("pricing_config")
}

// =============================================================================
// SAVED PROMPTS — User custom prompt library
// =============================================================================
model SavedPrompt {
  id          Int      @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  title       String   @db.VarChar(100)
  prompt      String   @db.Text
  niche       String   @db.VarChar(32)        // fnb, fashion, tech, etc
  source      String   @default("custom") @db.VarChar(16) // custom | library | daily
  sourceId    String?  @map("source_id") @db.VarChar(32)  // original prompt id if from library
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, niche])
  @@map("saved_prompts")
}

// =============================================================================
// GENERATION ANALYTICS MODEL (Phase 1)
// =============================================================================
model GenerationAnalytics {
  id               Int      @id @default(autoincrement())
  userId           BigInt   @map("user_id")
  jobId            String?  @map("job_id") @db.VarChar(255)
  niche            String?  @db.VarChar(50)
  styles           String[]
  providerUsed     String?  @map("provider_used") @db.VarChar(50)
  fallbackCount    Int      @default(0) @map("fallback_count")
  optimizationUsed Boolean  @default(false) @map("optimization_used")
  generationTimeMs Int?     @map("generation_time_ms")
  sceneCount       Int?     @map("scene_count")
  duration         Int?
  creditsUsed      Decimal? @map("credits_used") @db.Decimal(3, 1)
  createdAt        DateTime @default(now()) @map("created_at")
  @@index([userId])
  @@index([niche])
  @@index([createdAt])
  @@map("generation_analytics")
}

// Token Usage Tracking
model TokenUsage {
  id               Int      @id @default(autoincrement())
  userId           BigInt?  @map("user_id")
  provider         String   @db.VarChar(50)
  model            String   @db.VarChar(100)
  service          String   @db.VarChar(50)
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  costUsd          Float    @default(0) @map("cost_usd")
  costIdr          Float    @default(0) @map("cost_idr")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
  @@map("token_usage")
}

// =============================================================================
// GAMIFICATION MODELS (v3.0)
// =============================================================================

model UserStreak {
  id              BigInt    @id @default(autoincrement())
  userId          BigInt    @unique @map("user_id")
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastGenerateDate DateTime? @map("last_generate_date") @db.Date
  streakStartDate DateTime? @map("streak_start_date") @db.Date
  totalGenerates  Int       @default(0) @map("total_generates")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_streaks")
}

model UserBadge {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  badgeId     String    @map("badge_id") @db.VarChar(50)
  awardedAt   DateTime  @default(now()) @map("awarded_at")
  notified    Boolean   @default(false)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model RetentionLog {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  triggerType String    @map("trigger_type") @db.VarChar(50)
  sentAt      DateTime  @default(now()) @map("sent_at")
  responded   Boolean   @default(false)

  @@index([userId])
  @@index([triggerType])
  @@index([sentAt])
  @@map("retention_logs")
}
