# ==========================================
# BERKAHKARYA AI VIDEO STUDIO - PRODUCTION CONFIG
# ==========================================

# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username
WEBHOOK_URL=https://api-saas.aitradepulse.com/webhook/telegram
WEB_APP_URL=https://your-domain.com
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/berkahkarya
REDIS_URL=redis://localhost:6379

# ==========================================
# VIDEO GENERATION PROVIDERS (9-Tier Fallback)
# ==========================================

# Tier 1: Primary - BytePlus Seedance
BYTEPLUS_API_KEY=bp_live_xxxxxxxxxxxxxxxx
BYTEPLUS_API_SECRET=bp_secret_xxxxxxxxxxxxxxxx
BYTEPLUS_REGION=ap-southeast-1
BYTEPLUS_TIMEOUT=30000

# Tier 2: Fallback 1 - XAI Grok Aurora
XAI_API_KEY=xai_live_xxxxxxxxxxxxxxxx
XAI_TIMEOUT=25000

# Tier 3: Fallback 2 - LaoZhang
LAOZHANG_API_KEY=lz_xxxxxxxxxxxxxxxx
LAOZHANG_ENDPOINT=https://api.laozhang.ai/v1
LAOZHANG_TIMEOUT=35000

# Tier 4: Fallback 3 - EvoLink
EVOLINK_API_KEY=evo_xxxxxxxxxxxxxxxx
EVOLINK_WEBHOOK_SECRET=evo_wh_xxxxxxxxxxxxxxxx
EVOLINK_TIMEOUT=40000

# Tier 5: Fallback 4 - Hypereal
HYPEREAL_API_KEY=hyp_xxxxxxxxxxxxxxxx
HYPEREAL_TIMEOUT=35000

# Tier 6: Fallback 5 - SiliconFlow
SILICONFLOW_API_KEY=sf_xxxxxxxxxxxxxxxx
SILICONFLOW_TIMEOUT=30000

# Tier 7: Fallback 6 - Fal.ai Video
FALAI_VIDEO_KEY=fal_live_xxxxxxxxxxxxxxxx
FALAI_VIDEO_TIMEOUT=45000

# Tier 8: Fallback 7 - Kie.ai
KIE_API_KEY=kie_xxxxxxxxxxxxxxxx
KIE_TIMEOUT=50000

# Together.ai (Image - FLUX Schnell, cheapest text2img)
TOGETHER_API_KEY=key_xxxxxxxxxxxxxxxx

# PiAPI (Image + Video - Flux Dev, Kling, Midjourney)
PIAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# D-ID (Talking Photo / Lip Sync)
D_ID_API_KEY=your_d_id_api_key_here

# Tier 9: Last Resort - Local Remotion
REMOTION_ENABLED=true
FFMPEG_PATH=/usr/bin/ffmpeg
REMOTION_RENDER_TIMEOUT=120000

# ==========================================
# IMAGE GENERATION PROVIDERS (5-Tier untuk /skip)
# ==========================================

# Tier 1: Primary - GeminiGen
GEMINIGEN_API_KEY=gem_xxxxxxxxxxxxxxxx
GEMINIGEN_TIMEOUT=20000

# Tier 2: Fallback 1 - NVIDIA Flux
NVIDIA_API_KEY=nvda_xxxxxxxxxxxxxxxx
NVIDIA_TIMEOUT=15000

# Tier 3: Fallback 2 - Replicate
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxx
REPLICATE_TIMEOUT=30000

# Tier 4: Fallback 3 - Fal.ai Image
FALAI_IMAGE_KEY=fal_img_xxxxxxxxxxxxxxxx
FALAI_IMAGE_TIMEOUT=25000

# Tier 5: Fallback 4 - HuggingFace
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxx
HUGGINGFACE_TIMEOUT=35000

# ==========================================
# AI PROMPT OPTIMIZATION
# ==========================================

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
GEMINI_API_KEY=gemini-xxxxxxxxxxxxxxxx

AI_OPTIMIZATION_ENABLED=true
AI_OPTIMIZATION_BUDGET_USD=500
AI_OPTIMIZATION_TIMEOUT_MS=5000
PROMPT_CACHE_TTL=86400

# ==========================================
# CIRCUIT BREAKER & FALLBACK
# ==========================================

CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_MS=60000
MAX_PROVIDER_RETRY=2
FALLBACK_CHAIN_MAX=8

# Provider-specific thresholds
BYTEPLUS_CB_THRESHOLD=3
BYTEPLUS_CB_TIMEOUT=60000
XAI_CB_THRESHOLD=3
XAI_CB_TIMEOUT=45000
LAOZHANG_CB_THRESHOLD=5
LAOZHANG_CB_TIMEOUT=90000
EVOLINK_CB_THRESHOLD=5
EVOLINK_CB_TIMEOUT=120000
HYPEREAL_CB_THRESHOLD=4
HYPEREAL_CB_TIMEOUT=90000
SILICONFLOW_CB_THRESHOLD=5
SILICONFLOW_CB_TIMEOUT=60000
FALAI_CB_THRESHOLD=4
FALAI_CB_TIMEOUT=120000
KIE_CB_THRESHOLD=5
KIE_CB_TIMEOUT=180000

# ==========================================
# QUEUE CONFIGURATION
# ==========================================

BULLMQ_CONCURRENCY=5
VIDEO_QUEUE_NAME=video-generation
IMAGE_QUEUE_NAME=image-generation

# ==========================================
# PAYMENT GATEWAYS
# ==========================================

MIDTRANS_ENVIRONMENT=production
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx

TRIPAY_API_KEY=xxxxxxxxxxxxxxxx
TRIPAY_PRIVATE_KEY=xxxxxxxxxxxxxxxx
TRIPAY_MERCHANT_CODE=Txxxxxxxx

DUITKU_MERCHANT_CODE=Dxxxxxxxx
DUITKU_API_KEY=xxxxxxxxxxxxxxxx

# NOWPayments Crypto
NOWPAYMENTS_API_KEY=your_nowpayments_api_key

# Telegram Stars (no token needed, Stars uses empty provider_token)
# Stars are enabled automatically when provider_token is empty string

# ==========================================
# POST-BRIDGE SOCIAL INTEGRATION
# ==========================================

POSTBRIDGE_ENABLED=true
POSTBRIDGE_API_KEY=pb_xxxxxxxxxxxxxxxx
POSTBRIDGE_WEBHOOK_SECRET=pb_wh_xxxxxxxxxxxxxxxx
POSTBRIDGE_BASE_URL=https://api.post-bridge.com/v1
POSTBRIDGE_PLATFORMS=instagram,tiktok,youtube,facebook,twitter,linkedin

# ==========================================
# FEATURE FLAGS
# ==========================================

ENABLE_NICHE_SELECTION=true
ENABLE_STYLE_SELECTION=true
ENABLE_AI_OPTIMIZATION=true
ENABLE_MULTI_STYLE=true
ENABLE_STORYBOARD_PREVIEW=true
ENABLE_PROVIDER_FALLBACK=true
ENABLE_POSTBRIDGE=true
DEMO_MODE=false

# ==========================================
# ANALYTICS & TRACKING PIXELS
# ==========================================

FACEBOOK_PIXEL_ID=your_fb_pixel_id
GA4_TRACKING_ID=G-XXXXXXXXXX
TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# ==========================================
# LOGGING
# ==========================================

LOG_LEVEL=info
LOG_FILE=/var/log/berkahkarya/app.log
