    "hashtag_generator_rules": {
      "mix_strategy": "3_large_3_medium_3_small",
      "tone_bias": [
        "niche_specific",
        "benefit_oriented",
        "platform_relevant"
      ]
    },
    "engagement_hooks": {
      "pattern_interrupt": [
        "sudden_zoom_in",
        "hard_pause_then_resume",
