<!-- Mobile Bottom Nav -->
<div class="mobile-nav">
  <div class="mobile-nav-item active" onclick="nav('dashboard')" id="mnav-dashboard"><span class="mni">🏠</span>Home</div>
  <div class="mobile-nav-item" onclick="nav('create')" id="mnav-create"><span class="mni">🎬</span>Buat</div>
  <div class="mobile-nav-item" onclick="nav('videos')" id="mnav-videos"><span class="mni">📁</span>Video</div>
  <div class="mobile-nav-item" onclick="nav('billing')" id="mnav-billing"><span class="mni">💳</span>Billing</div>
</div>

<script>
const API = '';
let token = localStorage.getItem('token');
let currentUser = null;
let createState = { step: 1, niche: '', style: '', duration: 30, customPrompt: '', storyboard: null };
let pollInterval = null;

// ── UTILS ─────────────────────────────────────────────────
function esc(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── AUTH ──────────────────────────────────────────────────
async function apiFetch(path, opts = {}) {
  const controller = new AbortController();
  const tid = setTimeout(() => controller.abort(), 15000);
  try {
    const res = await fetch(API + path, {
      ...opts,
      signal: controller.signal,
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token, ...(opts.headers || {}) },
    });
    clearTimeout(tid);
    if (res.status === 401) { logout(); return null; }
    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: res.statusText }));
      throw new Error(err.error || `Request failed (${res.status})`);
    }
    return await res.json();
  } catch(e) {
    clearTimeout(tid);
    if (e.name === 'AbortError') throw new Error('Request timed out. Check your connection.');
    throw e;
  }
}

function logout() {
  localStorage.removeItem('token');
  window.location.href = '/';
}

function toast(msg, type = 'info') {
  const c = document.getElementById('toast');
  const d = document.createElement('div');
  d.className = 'toast-msg toast-' + type;
  d.textContent = msg;
  c.appendChild(d);
  requestAnimationFrame(() => { requestAnimationFrame(() => d.classList.add('show')); });
  setTimeout(() => { d.classList.remove('show'); setTimeout(() => d.remove(), 400); }, 3500);
}

// ── INIT ──────────────────────────────────────────────────
async function tryTwaLogin() {
  const tg = window.Telegram?.WebApp;
  if (!tg || !tg.initDataUnsafe?.user) return;
  const u = tg.initDataUnsafe.user;
  try {
    const r = await fetch('/auth/telegram', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ initData: tg.initData })
    });
    const d = await r.json();
    if (d.token) { token = d.token; localStorage.setItem('token', token); }
  } catch(_) {}
}

async function init() {
  // Safety timeout — kalau init > 8s, redirect ke landing
  const safetyTimer = setTimeout(() => {
    if (!token) window.location.href = '/';
  }, 8000);

  // Try Telegram WebApp login first (wait a tick for SDK to load)
  if (!token) {
    await new Promise(r => setTimeout(r, 300));
    await tryTwaLogin();
  }

  if (!token) { 
    clearTimeout(safetyTimer); 
    showLoginScreen(); 
    return; 
  }

  clearTimeout(safetyTimer);

  const loadingText = document.getElementById('loading-text');
  if (loadingText) loadingText.textContent = 'Menyiapkan dashboard...';

  const user = await apiFetch('/api/user');
  if (!user) { window.location.href = '/'; return; }
  currentUser = user;

  document.getElementById('user-greeting').textContent = 'Halo, ' + (user.firstName || user.username || 'User') + '!';
  updateCreditsDisplay(user.credits);
  document.getElementById('stat-tier').textContent = user.tier?.toUpperCase() || 'FREE';
  document.getElementById('stat-ref').textContent = user.referralCode || '—';
  document.getElementById('stat-ref-copy').onclick = () => { navigator.clipboard?.writeText(user.referralCode || ''); toast('Referral code disalin!', 'ok'); };
  document.getElementById('billing-credits').textContent = Math.floor(Number(user.credits));

  document.getElementById('loading-overlay').style.display = 'none';
  document.getElementById('app').style.display = 'flex';

  loadDashboard();
}

function updateCreditsDisplay(credits) {
  const c = Math.floor(Number(credits));
  document.getElementById('stat-credits').textContent = c;
  document.getElementById('header-credits').textContent = '✨ ' + c + ' cr';
  document.getElementById('sidebar-credits').textContent = '✨ ' + c + ' Credits';
  document.getElementById('billing-credits').textContent = c;
}

// ── NAVIGATION ────────────────────────────────────────────
function nav(page) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item, .mobile-nav-item').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + page).classList.add('active');
  const navEl = document.getElementById('nav-' + page);
  const mnavEl = document.getElementById('mnav-' + page);
  if (navEl) navEl.classList.add('active');
  if (mnavEl) mnavEl.classList.add('active');
  const titles = { dashboard: 'Dashboard', create: 'Buat Video', videos: 'Video Saya', billing: 'Billing & Top Up', subscription: 'Langganan', referral: 'Referral', profile: 'Profil', settings: 'Pengaturan', image: 'Buat Gambar' };
  document.getElementById('page-title').textContent = titles[page] || page;

  if (page === 'videos') loadVideos();
  if (page === 'billing') loadBilling();
  if (page === 'create') initCreate();
  if (page === 'subscription') loadSubscription();
  if (page === 'referral') loadReferral();
  if (page === 'profile') loadProfile();
}

// ── DASHBOARD ─────────────────────────────────────────────
async function loadDashboard() {
  const { videos } = await apiFetch('/api/user/videos?limit=4');
  if (!videos) return;
  document.getElementById('stat-videos').textContent = videos.length;
  const recent = videos.slice(0, 4);
  const container = document.getElementById('recent-videos');
  if (recent.length === 0) {
    container.innerHTML = '<div class="empty"><div class="icon">🎬</div><h3>Belum ada video</h3><p>Buat video pertamamu sekarang!</p><button class="btn btn-primary" onclick="nav(\'create\')" style="margin-top:16px">Buat Video</button></div>';
  } else {
    container.innerHTML = recent.map(v => videoCard(v)).join('');
  }
}

function videoCard(v) {
  const statusMap = { processing: 'processing', completed: 'completed', failed: 'failed', pending: 'pending' };
  const statusLabel = { processing: '⏳ Processing', completed: '✅ Selesai', failed: '❌ Gagal', pending: '🕐 Pending' };
  const s = v.status || 'pending';
  const safeStatus = statusMap[s] || 'pending';
  const dl = v.downloadUrl || v.videoUrl;
  const videoSrc = v.videoUrl ? esc(v.videoUrl) : (v.downloadUrl ? esc(v.downloadUrl) : '');
  const posterSrc = v.thumbnailUrl ? ` poster="${esc(v.thumbnailUrl)}"` : '';
  
  let thumbHtml = '<span>🎬</span>';
  if (s === 'processing' || s === 'pending') {
    thumbHtml = '<div class="spinner" style="border-width:2px;width:24px;height:24px;"></div>';
  } else if (s === 'failed') {
    thumbHtml = '<span style="color:var(--danger)">❌ Failed</span>';
  } else if (videoSrc) {
    thumbHtml = `<video src="${videoSrc}" controls autoplay muted loop preload="auto"${posterSrc} playsinline style="width:100%; height:100%; object-fit:cover; border-radius:12px;"></video>`;
  } else if (dl && !videoSrc) {
    thumbHtml = v.thumbnailUrl ? `<img src="${esc(v.thumbnailUrl)}" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">` : '<span>🔗</span>';
  }

  return `<div class="video-card">
    <div class="video-thumb">${thumbHtml}</div>
    <div class="video-info">
      <div class="video-title">${esc(v.niche?.toUpperCase()) || 'VIDEO'} · ${esc(String(v.duration || ''))}s</div>
      <div class="video-meta">${esc(new Date(v.createdAt).toLocaleDateString('id-ID'))}</div>
      <span class="status-badge status-${safeStatus}">${statusLabel[s] || esc(s)}</span>
      <div style="margin-top:8px; display:flex; gap:8px; flex-wrap:wrap;">
        ${dl && s === 'completed' ? `<a href="${esc(dl)}" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">⬇ Download</a>` : ''}
        <button class="btn btn-danger btn-sm" onclick="deleteVideo('${esc(v.jobId || v.id)}')">🗑️ Hapus</button>
      </div>
    </div>
  </div>`;
}

// ── CREATE VIDEO ──────────────────────────────────────────
const NICHES_DATA = [
  {id:'fnb',emoji:'🍔',name:'F&B'},
  {id:'product',emoji:'🛍️',name:'Produk'},
  {id:'fashion',emoji:'👗',name:'Fashion'},
  {id:'tech',emoji:'💻',name:'Tech'},
  {id:'health',emoji:'💪',name:'Health'},
  {id:'beauty',emoji:'💄',name:'Beauty'},
  {id:'travel',emoji:'✈️',name:'Travel'},
  {id:'education',emoji:'📚',name:'Edukasi'},
];
const STYLES = ['Viral Hook','Testimonial','Tutorial','Showcase'];
const DURATIONS = [5, 15, 30, 60];

function initCreate() {
  createState = { step: 1, niche: '', style: 'Viral Hook', duration: 30, customPrompt: '', storyboard: null };
  renderCreateStep();
}

function renderCreateStep() {
  const dots = 6;
  const dotEl = document.getElementById('step-dots');
  dotEl.innerHTML = Array.from({length: dots}, (_, i) =>
    '<div class="step-dot' + (i < createState.step ? ' done' : '') + '"></div>'
  ).join('');

  const c = document.getElementById('create-step-container');
  if (createState.step === 1) {
    c.innerHTML = `
      <div class="step-header">Pilih Niche Bisnis</div>
      <div class="step-sub">Kategori konten akan menentukan gaya video</div>
      <div class="niche-grid">
        ${NICHES_DATA.map(n => '<div class="niche-btn' + (createState.niche === n.id ? ' selected' : '') + '" onclick="selectNiche(\'' + n.id + '\')"><span class="ni">' + n.emoji + '</span>' + n.name + '</div>').join('')}
      </div>
      <div style="margin-top:24px"><button class="btn btn-primary" onclick="nextStep()" ${!createState.niche ? 'disabled' : ''}>Lanjut →</button></div>
    `;
  } else if (createState.step === 2) {
    c.innerHTML = `
      <div class="step-header">Pilih Style Video</div>
      <div class="step-sub">Gaya penyampaian konten</div>
      <div class="chip-group">
        ${STYLES.map(s => '<div class="chip' + (createState.style === s ? ' selected' : '') + '" onclick="selectStyle(\'' + s + '\')">'+s+'</div>').join('')}
      </div>
      <div style="margin-top:24px;display:flex;gap:12px">
        <button class="btn btn-outline" onclick="prevStep()">← Kembali</button>
        <button class="btn btn-primary" onclick="nextStep()">Lanjut →</button>
      </div>
    `;
  } else if (createState.step === 3) {
    c.innerHTML = `
      <div class="step-header">Pilih Durasi</div>
      <div class="step-sub">Durasi video output</div>
      <div class="dur-group">
        ${DURATIONS.map(d => '<div class="dur-btn' + (createState.duration === d ? ' selected' : '') + '" onclick="selectDur(' + d + ')">' + d + 's</div>').join('')}
      </div>
      <div style="margin-top:24px;display:flex;gap:12px">
        <button class="btn btn-outline" onclick="prevStep()">← Kembali</button>
        <button class="btn btn-primary" onclick="nextStep()">Lanjut →</button>
      </div>
    `;
  } else if (createState.step === 4) {
    c.innerHTML = `
      <div class="step-header">Advanced Setup (Opsional)</div>
      <div class="step-sub">Deskripsikan produkmu dan atur parameter video</div>
      <div class="form-group">
        <label class="form-label">Custom Prompt / Promo</label>
        <textarea id="custom-prompt" placeholder="Contoh: Kopi arabika single origin dari Aceh..." rows="3">${createState.customPrompt}</textarea>
      </div>
      <div class="form-group" style="background:var(--card); padding:16px; border-radius:12px; border:1px solid var(--border);">
        <label class="form-label" style="margin-bottom:12px; font-weight:700;">Pengaturan Video (AI Bot Parity)</label>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
            <input type="checkbox" id="adv-no-watermark" style="width:auto;" ${createState.noWatermark ? 'checked' : ''}> Hapus Watermark 
            <span style="font-size:11px;color:var(--warn);background:rgba(255,165,2,0.15);padding:2px 6px;border-radius:4px;">-10 Credits</span>
          </label>
          <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
            <input type="checkbox" id="adv-subtitles" style="width:auto;" ${createState.subtitles !== false ? 'checked' : ''}> Auto Subtitle
          </label>
          <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
            <input type="checkbox" id="adv-voiceover" style="width:auto;" ${createState.voiceover !== false ? 'checked' : ''}> Voice Over AI
          </label>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:24px;">
        <button class="btn btn-outline" onclick="prevStep()">← Kembali</button>
        <button class="btn btn-primary" style="flex:1" onclick="saveAdvAndNext()">Preview Storyboard →</button>
      </div>
    `;
  } else if (createState.step === 5) {
    c.innerHTML = `
      <div class="step-header">Preview Storyboard</div>
      <div class="step-sub">AI sedang generate storyboard...</div>
      <div style="display:flex;align-items:center;gap:12px;padding:20px 0"><div class="spinner"></div><span style="color:var(--dim);font-size:14px">Generating storyboard...</span></div>
    `;
    generateStoryboardPreview();
  } else if (createState.step === 6) {
    const scenes = createState.storyboard?.scenes || [];
    const creditCost = createState.duration <= 5 ? unitPricing.IMAGE_UNIT : createState.duration <= 15 ? unitPricing.VIDEO_15S : createState.duration <= 30 ? unitPricing.VIDEO_30S : createState.duration <= 60 ? unitPricing.VIDEO_60S : unitPricing.VIDEO_120S;
    const canAfford = Number(currentUser?.credits || 0) >= creditCost;
    c.innerHTML = `
      <div class="step-header">Konfirmasi & Generate</div>
      <div class="step-sub">${scenes.length} scene · ${createState.duration}s · ${createState.niche} · ${createState.style}</div>
      <div style="margin-bottom:20px">
        ${scenes.map(s => '<div class="scene-card"><div class="scene-num">Scene '+esc(String(s.scene))+' · '+esc(String(s.duration))+'s</div><p>'+esc(s.description)+'</p></div>').join('')}
      </div>
      ${createState.storyboard?.caption ? '<div class="card" style="margin-bottom:20px"><div style="font-size:12px;color:var(--dim);margin-bottom:6px">📝 Caption</div><p style="font-size:14px;line-height:1.6">'+esc(createState.storyboard.caption)+'</p></div>' : ''}
      <div class="card" style="margin-bottom:20px">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span style="font-size:14px">Biaya</span>
          <span style="font-size:18px;font-weight:700;color:var(--accent)">${creditCost} Credits</span>
        </div>
        ${!canAfford ? '<div style="margin-top:12px;color:var(--danger);font-size:13px">⚠️ Credits tidak cukup. <a href="#" onclick="nav(\'billing\')" style="color:var(--accent)">Top Up sekarang</a></div>' : ''}
      </div>
      <div style="display:flex;gap:12px">
        <button class="btn btn-outline" onclick="createState.step=4;renderCreateStep()">← Kembali</button>
        <button class="btn btn-primary" onclick="startGeneration()" ${!canAfford ? 'disabled' : ''} id="gen-btn">🎬 Generate Video</button>
      </div>
    `;
  }
}

function selectNiche(id) { createState.niche = id; renderCreateStep(); }
function selectStyle(s) { createState.style = s; renderCreateStep(); }
function selectDur(d) { createState.duration = d; renderCreateStep(); }
function nextStep() { createState.step++; renderCreateStep(); }
function prevStep() { createState.step--; renderCreateStep(); }
function saveAdvAndNext() {
  createState.customPrompt = document.getElementById('custom-prompt').value;
  createState.noWatermark = document.getElementById('adv-no-watermark').checked;
  createState.subtitles = document.getElementById('adv-subtitles').checked;
  createState.voiceover = document.getElementById('adv-voiceover').checked;
  nextStep();
}

async function generateStoryboardPreview() {
  try {
    const data = await apiFetch('/api/storyboard', {
      method: 'POST',
      body: JSON.stringify({ niche: createState.niche, duration: createState.duration, customPrompt: createState.customPrompt || undefined })
    });
    if (!data || data.error) { toast('Gagal generate storyboard: ' + (data?.error || 'Unknown'), 'err'); createState.step = 4; renderCreateStep(); return; }
    createState.storyboard = data;
    createState.step = 6;
    renderCreateStep();
  } catch(e) { toast('Error: ' + e.message, 'err'); createState.step = 4; renderCreateStep(); }
}

async function startGeneration() {
  const btn = document.getElementById('gen-btn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<div class="spinner"></div> Memulai...'; }
  try {
    const data = await apiFetch('/api/video/create', {
      method: 'POST',
      body: JSON.stringify({
        niche: createState.niche,
        style: createState.style,
        duration: createState.duration,
        platform: 'tiktok',
        customPrompt: createState.customPrompt || undefined,
        customScenes: createState.storyboard?.scenes || undefined,
        noWatermark: createState.noWatermark,
        subtitles: createState.subtitles,
        voiceover: createState.voiceover
      })
    });
    if (!data || data.error) { toast('Gagal: ' + (data?.error || 'Server error'), 'err'); if (btn) { btn.disabled = false; btn.innerHTML = '🎬 Generate Video'; } return; }
    toast('✅ Video mulai diproses! Cek di "Video Saya"', 'ok');
    const user = await apiFetch('/api/user');
    if (user) { currentUser = user; updateCreditsDisplay(user.credits); }
    nav('videos');
    startPolling();
  } catch(e) { toast('Error: ' + e.message, 'err'); if (btn) { btn.disabled = false; btn.innerHTML = '🎬 Generate Video'; } }
}

function startPolling() {
  if (pollInterval) clearInterval(pollInterval);
  let attempts = 0;
  const MAX_ATTEMPTS = 75; // 5 minutes at 4s intervals
  pollInterval = setInterval(async () => {
    attempts++;
    try {
      const { videos } = await apiFetch('/api/user/videos');
      if (!videos) { clearInterval(pollInterval); pollInterval = null; return; }
      loadVideosList(videos);
      const processing = videos.filter(v => v.status === 'processing' || v.status === 'pending');
      if (processing.length === 0) {
        clearInterval(pollInterval); pollInterval = null;
        toast('🎉 Video selesai diproses!', 'ok');
        const user = await apiFetch('/api/user');
        if (user) { currentUser = user; updateCreditsDisplay(user.credits); }
      } else if (attempts >= MAX_ATTEMPTS) {
        clearInterval(pollInterval); pollInterval = null;
        toast('⏱️ Video masih diproses. Refresh halaman untuk update terbaru.', 'warn');
      }
    } catch(e) {
      // Network error during polling — don't stop, just wait for next tick
      if (attempts >= MAX_ATTEMPTS) { clearInterval(pollInterval); pollInterval = null; }
    }
  }, 4000);
}
// Cleanup polling when page unloads
window.addEventListener('beforeunload', () => { if (pollInterval) clearInterval(pollInterval); });

let videosCursor = null;

async function loadVideos(cursor) {
  const container = document.getElementById('videos-container');
  if (!cursor) {
    videosCursor = null;
    container.innerHTML = '<div style="padding:20px;color:var(--dim);font-size:14px"><div class="spinner" style="display:inline-block"></div> Memuat video...</div>';
  }
  const url = '/api/user/videos?limit=20' + (cursor ? '&cursor=' + encodeURIComponent(cursor) : '');
  const res = await apiFetch(url);
  if (!res) return;
  const { videos, nextCursor } = res;
  if (!cursor) {
    loadVideosList(videos);
  } else {
    container.insertAdjacentHTML('beforeend', videos.map(v => videoCard(v)).join(''));
  }
  videosCursor = nextCursor;
  const loadMoreBtn = document.getElementById('load-more-videos-btn');
  if (loadMoreBtn) loadMoreBtn.style.display = nextCursor ? '' : 'none';
  if (videos.some(v => v.status === 'processing' || v.status === 'pending')) startPolling();
}

function loadVideosList(videos) {
  const container = document.getElementById('videos-container');
  if (!videos || videos.length === 0) {
    container.innerHTML = '<div class="empty"><div class="icon">📁</div><h3>Belum ada video</h3><p>Buat video pertamamu!</p><button class="btn btn-primary" onclick="nav(\'create\')" style="margin-top:16px">Buat Video</button></div>';
    return;
  }
  container.innerHTML = videos.map(v => videoCard(v)).join('');
}

let unitPricing = { VIDEO_15S: 0.8, VIDEO_30S: 1.5, VIDEO_60S: 3.0, VIDEO_120S: 6.5, IMAGE_UNIT: 0.2 };
let enabledGateways = [];

async function loadBilling() {
  const res = await apiFetch('/api/packages');
  if (res && res.unitCosts) unitPricing = { ...unitPricing, ...res.unitCosts };
  if (res && res.enabledGateways) enabledGateways = res.enabledGateways;
  const pkgs = res && res.packages ? res.packages : (Array.isArray(res) ? res : []);
  const pc = document.getElementById('packages-container');
  if (pkgs && pkgs.length > 0) {
    pc.innerHTML = pkgs.map((p) => `
      <div class="price-card ${p.isPopular ? 'popular' : ''}">
        ${p.isPopular ? '<div class="popular-tag">⭐ POPULER</div>' : ''}
        <h3>${esc(p.name)}</h3>
        <div class="price">IDR ${Number(p.priceIdr || p.price).toLocaleString('id-ID')}</div>
        <div class="cred">${esc(String(p.totalCredits || p.credits))} Credits</div>
        <button class="btn btn-${p.isPopular ? 'primary' : 'outline'} btn-full" data-pkg-id="${esc(p.id)}">Beli Paket</button>
      </div>
    `).join('');
    pc.querySelectorAll('button[data-pkg-id]').forEach(btn => {
      btn.addEventListener('click', () => buyPackage(btn.dataset.pkgId));
    });
  }
  const txns = await apiFetch('/api/my/transactions');
  const tbody = document.getElementById('txn-body');
  if (txns && txns.length > 0) {
    const safeStatuses = new Set(['processing','completed','failed','pending','paid','expired','cancelled']);
    tbody.innerHTML = txns.map(t => {
      const safeStatus = safeStatuses.has(t.status) ? t.status : 'pending';
      return `
      <tr>
        <td style="font-family:monospace;font-size:11px">${esc((t.orderId||'').slice(0,18))}...</td>
        <td>${esc(t.packageName || '—')}</td>
        <td>IDR ${Number(t.amountIdr||0).toLocaleString('id-ID')}</td>
        <td>${Number(t.creditsAmount||0).toFixed(1)}</td>
        <td><span class="status-badge status-${safeStatus}">${esc(t.status)}</span></td>
        <td>
          <a href="/api/my/transactions/${t.id}/receipt" target="_blank" style="color:var(--accent);text-decoration:none;">
            ${esc(new Date(t.createdAt).toLocaleDateString('id-ID'))}
          </a>
        </td>
        <td>
          <button onclick="window.open('/api/my/transactions/${t.id}/receipt', '_blank')" style="background:none;border:none;color:var(--accent);cursor:pointer;font-size:11px;">
            📄 Receipt
          </button>
        </td>
      </tr>
    `}).join('');
  } else {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--dim);padding:24px">Belum ada transaksi</td></tr>';
  }
}

async function buyPackage(pkgId) {
  const gateway = enabledGateways.length > 0 ? enabledGateways[0].id : 'duitku';
  toast('⏳ Membuat transaksi...', 'info');
  const data = await apiFetch('/api/payment/create', {
    method: 'POST',
    body: JSON.stringify({ packageId: pkgId, gateway })
  });
  if (!data || data.error) { toast('Gagal: ' + (data?.error || 'Server error'), 'err'); return; }
  const url = data.paymentUrl || data.payment_url || data.invoiceUrl;
  if (url) { window.open(url, '_blank'); toast('✅ Halaman pembayaran dibuka', 'ok'); }
  else toast('❌ Payment URL tidak ditemukan', 'err');
}

function payStars() { window.open('https://t.me/<%= botUsername %>?start=topup_stars', '_blank'); }
function payCrypto() { window.open('https://t.me/<%= botUsername %>?start=topup_crypto', '_blank'); }

function shareRef() {
  const code = currentUser?.referralCode;
  if (!code) { toast('Referral code tidak ditemukan', 'err'); return; }
  const msg = encodeURIComponent('🎬 Buat video viral dengan AI di BerkahKarya! Pakai kode referral saya: ' + code + '\nhttps://t.me/<%= botUsername %>?start=ref_' + code);
  window.open('https://t.me/share/url?url=https://t.me/<%= botUsername %>&text=' + msg, '_blank');
}

function showLoginScreen() {
  document.getElementById('loading-overlay').style.display = 'none';
  document.getElementById('app').style.display = 'none';
  const loginHtml = `
    <div style="min-height:100vh;background:#0a0a1a;display:flex;align-items:center;justify-content:center;font-family:Inter,sans-serif;padding:20px">
      <div style="text-align:center;max-width:380px;width:100%">
        <div style="font-size:48px;margin-bottom:16px">🎬</div>
        <div style="font-size:26px;font-weight:800;background:linear-gradient(135deg,#00d9ff,#00ff88);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:8px">BerkahKarya</div>
        <div style="color:rgba(255,255,255,0.55);font-size:14px;margin-bottom:32px">AI Video Studio — Login untuk melanjutkan</div>
        <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:32px">
          <p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:24px">Login dengan akun Telegram kamu</p>
          <div id="tg-login-btn"></div>
          <div style="margin-top:20px;color:rgba(255,255,255,0.35);font-size:12px">atau</div>
          <a href="https://t.me/<%= botUsername %>" style="display:inline-block;margin-top:16px;padding:12px 24px;background:linear-gradient(135deg,#00d9ff,#00ff88);color:#0a0a1a;border-radius:12px;font-weight:700;text-decoration:none;font-size:14px">🚀 Buka di Telegram</a>
        </div>
      </div>
    </div>`;
  document.body.innerHTML = loginHtml;
  const script = document.createElement('script');
  script.async = true;
  script.src = 'https://telegram.org/js/telegram-widget.js?22';
  script.setAttribute('data-telegram-login', '<%= botUsername %>');
  script.setAttribute('data-size', 'large');
  script.setAttribute('data-radius', '12');
  script.setAttribute('data-request-access', 'write');
  script.setAttribute('data-onauth', 'onTgAuth(user)');
  document.getElementById('tg-login-btn').appendChild(script);
}

window.onTgAuth = function(user) {
  fetch('/auth/telegram', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify(user)
  }).then(r=>r.json()).then(d=>{
    if(d.token){ localStorage.setItem('token',d.token); window.location.reload(); }
    else alert('Login gagal, coba lagi.');
  }).catch(()=>alert('Login gagal, coba lagi.'));
}

// ── SUBSCRIPTION ─────────────────────────────────────────
async function loadSubscription() {
  const plans = await apiFetch('/api/subscriptions');
  const container = document.getElementById('subscription-plans');
  if (!plans || !container) return;
  container.innerHTML = Object.entries(plans).map(([key, p]) => `
    <div class="card" style="text-align:center">
      <h3>${p.name}</h3>
      <div style="font-size:24px;font-weight:800;margin:12px 0">IDR ${Number(p.monthlyPriceIdr || 0).toLocaleString('id-ID')}</div>
      <div style="font-size:12px;color:var(--dim);margin-bottom:16px">${p.credits || 0} credits/bulan</div>
      <button class="btn btn-primary btn-full" onclick="buySubscription('${key}')">Pilih</button>
    </div>
  `).join('');
}

async function buySubscription(plan) {
  const result = await apiFetch('/api/subscription/buy', { method: 'POST', body: JSON.stringify({ plan, cycle: 'monthly' }) });
  if (result?.paymentUrl) window.open(result.paymentUrl, '_blank');
}

// ── REFERRAL ─────────────────────────────────────────────
async function loadReferral() {
  const data = await apiFetch('/api/referral');
  if (!data) return;
  document.getElementById('ref-tier1').textContent = data.tier1Count || 0;
  document.getElementById('ref-tier2').textContent = data.tier2Count || 0;
  document.getElementById('ref-tier3').textContent = data.tier3Count || 0;
  document.getElementById('ref-balance').textContent = 'IDR ' + Number(data.availableCommission || 0).toLocaleString('id-ID');
  document.getElementById('ref-link').value = data.referralLink || '';
}

function copyRefLink() {
  const input = document.getElementById('ref-link');
  input.select();
  document.execCommand('copy');
  toast('✅ Link referral disalin!', 'ok');
}

async function withdrawReferral() {
  if (!confirm('Tarik komisi Anda sekarang?\n\nAnda akan mendapatkan 50% dari total komisi tersedia dalam bentuk saldo IDR (Admin Transfer).\n\nLanjutkan?')) return;
  
  toast('⏳ Memproses penarikan...', 'info');
  try {
    const res = await apiFetch('/api/referral/withdraw', {
      method: 'POST',
      body: JSON.stringify({ action: 'sell_admin' })
    });
    
    if (res && res.ok) {
      toast('✅ Penarikan diajukan! Tunggu konfirmasi admin.', 'ok');
      loadReferral();
    } else {
      toast(res?.error || 'Gagal menarik komisi', 'err');
    }
  } catch (e) {
    toast(e.message, 'err');
  }
}

// ── PROFILE ──────────────────────────────────────────────
async function loadProfile() {
  const user = await apiFetch('/api/user');
  if (!user) return;
  document.getElementById('profile-info').innerHTML = `
    <div class="stat-card" style="margin-bottom:12px"><div class="label">Nama</div><div class="value" style="font-size:18px">${esc(user.firstName || '-')}</div></div>
    <div class="stat-card" style="margin-bottom:12px"><div class="label">Username</div><div class="value" style="font-size:18px">@${esc(user.username || '-')}</div></div>
    <div class="stat-card" style="margin-bottom:12px"><div class="label">Credits</div><div class="value" style="font-size:18px">${user.credits || 0}</div></div>
    <div class="stat-card" style="margin-bottom:12px"><div class="label">Tier</div><div class="value" style="font-size:18px">${esc(user.tier || 'free')}</div></div>
    <div class="stat-card"><div class="label">Bergabung</div><div class="value" style="font-size:18px">${new Date(user.createdAt).toLocaleDateString('id-ID')}</div></div>
  `;
}

// ── IMAGE GENERATION ─────────────────────────────────────
async function generateImage() {
  const prompt = document.getElementById('image-prompt').value;
  if (!prompt) { toast('Masukkan prompt!', 'warn'); return; }
  const btn = document.getElementById('gen-image-btn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Generating...';
  document.getElementById('image-result').innerHTML = '';
  try {
    const result = await apiFetch('/api/image/generate', { method: 'POST', body: JSON.stringify({ prompt }) });
    if (result?.imageUrl) {
      document.getElementById('image-result').innerHTML = `<img src="${esc(result.imageUrl)}" style="max-width:100%;border-radius:12px;margin-top:16px;box-shadow: 0 10px 30px rgba(0,217,255,0.2);">`;
      toast('Gambar berhasil dibuat!', 'ok');
    } else {
      toast('Gagal memproses gambar.', 'err');
    }
  } catch (e) {
    toast('Error: ' + e.message, 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = 'Generate Gambar';
  }
}

// ── SETTINGS ─────────────────────────────────────────────
async function saveSettings() {
  const lang = document.getElementById('settings-lang').value;
  const notif = document.getElementById('settings-notif').value === '1';
  try {
    const res = await apiFetch('/api/user/settings', {
      method: 'PATCH',
      body: JSON.stringify({ language: lang, notificationsEnabled: notif })
    });
    if (res?.ok) {
      toast('Pengaturan berhasil disimpan!', 'ok');
      localStorage.setItem('lang', lang);
    } else {
      toast(res?.error || 'Gagal menyimpan pengaturan', 'err');
    }
  } catch(e) {
    toast('Error: ' + e.message, 'err');
  }
}

async function changeLang(lang) {
  localStorage.setItem('lang', lang);
  try {
    await apiFetch('/api/user/settings', {
      method: 'PATCH',
      body: JSON.stringify({ language: lang })
    });
  } catch (e) {
    console.error('Failed to save language to server:', e);
  }
}

async function deleteAccount() {
  if (!confirm('Yakin ingin menghapus akun? Tindakan ini tidak dapat dibatalkan.')) return;
  const result = await apiFetch('/api/user', { method: 'DELETE' });
  if (result?.message) {
    alert(result.message);
    localStorage.removeItem('token');
    location.reload();
  }
}

async function deleteVideo(id) {
  if (!confirm('Yakin ingin menghapus video ini?')) return;
  const result = await apiFetch('/api/video/' + id, {method: 'DELETE'});
  if (result?.ok) {
    loadVideos();
  }
}

// ── P2P TRANSFER ─────────────────────────────────────────
async function sendCredits() {
  const username = document.getElementById('send-username').value.replace('@','').trim();
  const amount = parseInt(document.getElementById('send-amount').value);
  
  if (!username) { toast('Username penerima wajib diisi', 'warn'); return; }
  if (!amount || amount < 50) { toast('Minimal pengiriman 50 credits', 'warn'); return; }
  if (!confirm(`Kirim ${amount} credits ke @${username}?\n\n(Akan dikenakan biaya admin 0.5%)`)) return;

  const btn = event.target;
  const oldText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Diproses...';

  try {
    const res = await apiFetch('/api/user/p2p-transfer', {
      method: 'POST',
      body: JSON.stringify({ recipientUsername: username, amount })
    });
    if (res && res.success) {
      toast(`✅ Berhasil mengirim ${res.amountSent} credits ke @${res.recipient}`, 'ok');
      document.getElementById('send-username').value = '';
      document.getElementById('send-amount').value = '';
      loadDashboard();
    } else {
      toast(res?.error || 'Transfer gagal', 'err');
    }
  } catch (e) {
    toast(e.message, 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = oldText;
  }
}

function toggleEditProfile() {
  const form = document.getElementById('edit-profile-form');
  const btn = document.getElementById('edit-profile-btn');
  const visible = form.style.display !== 'none';
  form.style.display = visible ? 'none' : 'block';
  btn.textContent = visible ? '✏️ Edit Profil' : '✖ Tutup';
  if (!visible && currentUser) {
    document.getElementById('edit-firstName').value = currentUser.firstName || '';
    document.getElementById('edit-lang').value = currentUser.language || 'id';
  }
}

async function saveProfile() {
  const firstName = document.getElementById('edit-firstName').value.trim();
  const lang = document.getElementById('edit-lang').value;
  if (!firstName) { toast('Nama tidak boleh kosong', 'warn'); return; }
  try {
    const res = await apiFetch('/api/user/settings', {
      method: 'PATCH',
      body: JSON.stringify({ firstName, language: lang })
    });
    if (res?.ok) {
      toast('Profil berhasil disimpan!', 'ok');
      currentUser = { ...currentUser, firstName, language: lang };
      localStorage.setItem('lang', lang);
      toggleEditProfile();
      loadProfile();
    } else {
      toast(res?.error || 'Gagal menyimpan profil', 'err');
    }
  } catch (e) {
    toast('Error: ' + e.message, 'err');
  }
}

init();

// Initialize Telegram WebApp natively
if (window.Telegram && window.Telegram.WebApp) {
  const twa = window.Telegram.WebApp;
  twa.ready();
  twa.expand();
  // Attempt to match Telegram theme colors dynamically if supported
  if (twa.themeParams && twa.themeParams.bg_color) {
    document.documentElement.style.setProperty('--bg', twa.themeParams.bg_color);
  }
}
</script>
</body>
</html>