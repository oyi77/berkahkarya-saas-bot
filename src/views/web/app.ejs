          <select id="settings-lang" onchange="changeLang(this.value)">
            <option value="id">🇮🇩 Indonesia</option>
            <option value="en">🇺🇸 English</option>
            <option value="ru">🇷🇺 Русский</option>
            <option value="zh">🇨🇳 中文</option>
