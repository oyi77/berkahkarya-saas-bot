    function switchLang(lang) {
      if (!LANDING_I18N[lang]) lang = 'id';
      var dict = LANDING_I18N[lang];
      var els = document.querySelectorAll('[data-i18n]');
      for (var i = 0; i < els.length; i++) {
        var el = els[i];
        var key = el.getAttribute('data-i18n');
        if (!dict[key]) continue;
        var text = dict[key];
        // Handle parameterized text like "~{n} video 30 detik"
        var param = el.getAttribute('data-i18n-param');
        if (param) {
          text = text.replace('{n}', param);
        }
        // Use innerHTML for elements that contain HTML markup
        if (el.getAttribute('data-i18n-html') === 'true' || key === 'hero_title' || key === 'hero_trust' || key === 'pricing_bonus') {
          el.innerHTML = text;
        } else {
          el.textContent = text;
        }
      }

      // Translate dynamic content (headline/subheadline from DB) using cached translations
      var dynamicEls = document.querySelectorAll('[data-i18n-dynamic]');
      for (var d = 0; d < dynamicEls.length; d++) {
        (function(dynEl) {
          var dynKey = dynEl.getAttribute('data-i18n-dynamic');
          if (!dynEl._originalText) dynEl._originalText = dynEl.textContent || dynEl.innerHTML;
          
          if (lang === 'id') {
            dynEl.innerHTML = dynEl._originalText;
            return;
          }
          
          var cacheKey = 'landing_trans_' + dynKey + '_' + lang;
          var cached = null;
          try { cached = localStorage.getItem(cacheKey); } catch(e) {}
          
          if (cached) {
            dynEl.innerHTML = cached;
          } else {
            translateText(dynEl._originalText, lang).then(function(translated) {
              if (translated) {
                dynEl.innerHTML = translated;
                try { localStorage.setItem(cacheKey, translated); } catch(e) {}
              }
            });
          }
        })(dynamicEls[d]);
      }

      // Update html lang attribute
      document.documentElement.lang = lang;
      // Update flag switcher
      var flagMap = { id: 'id', en: 'us', ru: 'ru', zh: 'cn' };
      var labelMap = { id: 'ID', en: 'EN', ru: 'RU', zh: 'ZH' };
      var flagEl = document.getElementById('langFlag');
      var labelEl = document.getElementById('langLabel');
      if (flagEl) flagEl.src = 'https://flagcdn.com/w20/' + (flagMap[lang] || 'id') + '.png';
      if (labelEl) labelEl.textContent = labelMap[lang] || 'ID';
      // Convert prices based on language
      var USD_RATE = 16000;
      var priceEls = document.querySelectorAll('[data-price-idr]');
      for (var p = 0; p < priceEls.length; p++) {
        var idr = parseInt(priceEls[p].getAttribute('data-price-idr'));
        if (lang === 'id') {
          priceEls[p].textContent = 'IDR ' + (idr / 1000).toFixed(0) + 'K';
        } else {
          var usd = (idr / USD_RATE).toFixed(2);
          priceEls[p].textContent = '$' + usd + ' USD';
        }
      }
      // Persist choice
      try { localStorage.setItem('oc_lang', lang); } catch(e) {}
      
      // Update FOMO widget time label if visible
      var timeLabels = { id: 'Baru saja', en: 'Just now', ru: 'Только что', zh: '刚刚' };
      var timeEl = document.getElementById('fomoTime');
      if (timeEl) timeEl.textContent = timeLabels[lang] || 'Baru saja';
    }

    // Free translation via MyMemory API (5000 words/day, no API key)
    var translateQueue = [];
    var translateRunning = false;
    function translateText(text, targetLang) {
      return new Promise(function(resolve) {
        if (!text || targetLang === 'id') { resolve(text); return; }
        var cacheKey = 'landing_trans_' + text.substring(0, 30) + '_' + targetLang;
        var cached = null;
        try { cached = localStorage.getItem(cacheKey); } catch(e) {}
        if (cached) { resolve(cached); return; }
        
        var langMap = { en: 'en', ru: 'ru', zh: 'zh-CN' };
        var target = langMap[targetLang] || targetLang;
        var url = 'https://api.mymemory.translated.net/get?q=' + 
          encodeURIComponent(text.substring(0, 450)) + 
          '&langpair=id|' + target;
        
        translateQueue.push({ url: url, resolve: resolve, cacheKey: cacheKey });
        if (!translateRunning) processTranslateQueue();
      });
    }
    
    function processTranslateQueue() {
      if (translateQueue.length === 0) { translateRunning = false; return; }
      translateRunning = true;
      var item = translateQueue.shift();
      
      // Rate limit: 1 request per 300ms to avoid being blocked
      setTimeout(function() {
        fetch(item.url)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var translated = data && data.responseData ? data.responseData.translatedText : null;
            if (translated && translated !== item.url.split('q=')[1]) {
              try { localStorage.setItem(item.cacheKey, translated); } catch(e) {}
              item.resolve(translated);
            } else {
              item.resolve(null);
            }
          })
          .catch(function() { item.resolve(null); })
          .then(function() { processTranslateQueue(); });
      }, 300);
    }

    function toggleLangDropdown() {
      var dd = document.getElementById('langDropdown');
      var sw = document.getElementById('lang-switcher');
      if (dd.style.display === 'none' || !dd.style.display) {
        dd.style.display = 'block';
        sw.classList.add('open');
      } else {
        dd.style.display = 'none';
        sw.classList.remove('open');
      }
    }

    // Close dropdown on outside click
    document.addEventListener('click', function(e) {
      var sw = document.getElementById('lang-switcher');
      var dd = document.getElementById('langDropdown');
      if (sw && dd && !sw.contains(e.target)) {
        dd.style.display = 'none';
        sw.classList.remove('open');
      }
    });

    // Auto-detect language on load
    (function() {
      var stored = null;
      try { stored = localStorage.getItem('oc_lang'); } catch(e) {}
      if (stored && LANDING_I18N[stored]) {
        switchLang(stored);
        return;
      }
      // Detect from browser
      var navLang = (navigator.language || navigator.userLanguage || 'id').toLowerCase();
      var detected = 'id';
      if (navLang.startsWith('en')) detected = 'en';
      else if (navLang.startsWith('ru')) detected = 'ru';
      else if (navLang.startsWith('zh')) detected = 'zh';
      switchLang(detected);
    })();
  </script>

  <script>
    // Track scroll depth for LTV analysis
    let maxScroll = 0;
    let scrollThrottle = null;
    window.addEventListener('scroll', function() {
      if (scrollThrottle) return;
      scrollThrottle = requestAnimationFrame(function() {
        scrollThrottle = null;
        const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        if (scrollPercent > maxScroll) {
          maxScroll = Math.floor(scrollPercent / 25) * 25;
          if (maxScroll > 0 && typeof gtag !== 'undefined') {
            gtag('event', 'scroll_depth', { event_category: 'engagement', event_label: maxScroll + '%', value: maxScroll });
          }
        }
      });
    });

    // Track time on page for LTV analysis
    let timeOnPage = 0;
    setInterval(function() {
      timeOnPage += 10;
      if (timeOnPage % 30 === 0 && typeof gtag !== 'undefined') {
        gtag('event', 'time_on_page', {
          event_category: 'engagement',
          event_label: timeOnPage + 's',
          value: timeOnPage
        });
      }
    }, 10000);
  </script>

