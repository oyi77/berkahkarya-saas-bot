        var videoId = thumb.dataset.videoId;
        fetch("https://www.tiktok.com/oembed?url=https://www.tiktok.com/@x/video/" + videoId)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.thumbnail_url) {
              thumb.src = data.thumbnail_url;
            }
          })
          .catch(function(e) {
            thumb.style.background = "linear-gradient(135deg, rgba(0,217,255,0.2), rgba(0,255,136,0.2))";
