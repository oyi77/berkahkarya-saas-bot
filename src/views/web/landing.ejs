    .modal-body {
      position: relative;
      width: 90%;
      max-width: 500px;
      aspect-ratio: 9/16;
    }
    
    .modal-close {
      position: absolute;
      top: -50px;
      right: 0;
      background: none;
      border: none;
      color: #fff;
      font-size: 40px;
      cursor: pointer;
      padding: 0;
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.2s;
