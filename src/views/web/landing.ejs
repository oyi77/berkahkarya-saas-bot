      background: linear-gradient(135deg, rgba(0,217,255,0.05) 0%, rgba(0,255,136,0.05) 100%);
      z-index: -1;
    }
    
    /* Hero Banner */
    .showcase-hero-banner {
      text-align: center;
      margin-bottom: 100px;
      animation: fadeInDown 0.8s ease-out;
    }
    
    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .hero-title {
      font-size: 48px;
      font-weight: 900;
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--accent), #00ff88, var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.2;
    }
    
    .hero-subtitle {
      font-size: 20px;
      color: var(--dim);
      max-width: 800px;
      margin: 0 auto 50px;
      line-height: 1.6;
    }
    
    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
    }
    
    .stat-card {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--card);
      border: 1px solid var(--border);
      padding: 16px 24px;
      border-radius: 12px;
      backdrop-filter: blur(10px);
    }
    
    .stat-icon {
      font-size: 32px;
    }
    
    .stat-value {
      font-size: 24px;
      font-weight: 800;
      color: var(--accent);
    }
    
    .stat-label {
      font-size: 12px;
      color: var(--dim);
      margin-top: 4px;
    }
    
    /* Featured Video */
    .featured-showcase {
      position: relative;
      margin-bottom: 100px;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,217,255,0.2);
      animation: slideUp 0.8s ease-out 0.1s backwards;
    }
    
    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .featured-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      background: linear-gradient(135deg, var(--accent), #00ff88);
      color: #0a0a1a;
      padding: 8px 16px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 13px;
      z-index: 10;
      box-shadow: 0 4px 15px rgba(0,217,255,0.5);
    }
    
    .tiktok-embed-wrapper {
      width: 100%;
      max-width: 500px;
      margin: 0 auto;
    }
    
    .tiktok-embed {
      max-width: 100% !important;
    }
    
    .featured-stats-bar {
      display: flex;
      justify-content: space-around;
      align-items: center;
      padding: 20px;
      background: linear-gradient(90deg, var(--bg2), var(--bg));
      border-top: 1px solid var(--border);
    }
    
    .stat-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--accent);
    }
    
    .stat-icon {
      font-size: 18px;
    }
    
    /* Carousel Section */
    .showcase-carousel {
      margin-bottom: 80px;
    }
    
    .carousel-title {
      font-size: 32px;
      font-weight: 800;
      text-align: center;
      margin-bottom: 8px;
    }
    
    .carousel-subtitle {
      font-size: 16px;
      color: var(--dim);
      text-align: center;
      margin-bottom: 50px;
    }
    
    .carousel-container {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      max-width: 1400px;
      margin: 0 auto;
    }
    
    .carousel-video {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      background: var(--card);
      border: 1px solid var(--border);
      transition: all 0.3s ease;
    }
    
    .carousel-video:hover {
      border-color: var(--accent);
      transform: translateY(-8px);
      box-shadow: 0 12px 30px rgba(0,217,255,0.2);
    }
    
    .carousel-video .tiktok-embed {
      max-width: 100% !important;
    }
    
    .video-badge-small {
      position: absolute;
      bottom: 10px;
      right: 10px;
      background: rgba(0,217,255,0.9);
      color: #0a0a1a;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      backdrop-filter: blur(10px);
    }
    
    /* Final CTA */
    .showcase-final-cta {
      text-align: center;
      margin-top: 60px;
    }
    
    .btn-showcase {
      font-size: 18px !important;
      padding: 16px 48px !important;
      min-width: 320px;
      animation: pulse-glow 2s infinite;
    }
    
    @keyframes pulse-glow {
      0%, 100% {
        box-shadow: 0 0 20px rgba(0,217,255,0.5), inset 0 0 20px rgba(0,255,136,0.1);
      }
      50% {
        box-shadow: 0 0 40px rgba(0,217,255,0.8), inset 0 0 20px rgba(0,255,136,0.2);
      }
    }
    
    #cta-subtext {
      margin-top: 16px;
      font-size: 14px;
      color: var(--dim);
    }
    
    /* Responsive */
    @media(max-width: 1200px) {
      .carousel-container {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media(max-width: 768px) {
      .video-showcase-premium {
        padding: 80px 16px;
      }
      
      .hero-title {
        font-size: 28px;
      }
      
      .hero-subtitle {
        font-size: 16px;
      }
      
      .hero-stats {
        gap: 12px;
      }
      
      .stat-card {
        padding: 12px 16px;
        font-size: 13px;
      }
      
      .carousel-container {
        grid-template-columns: 1fr;
      }
      
      .btn-showcase {
        min-width: auto;
        width: 100%;
        max-width: 280px;
      }
    }
</style>

