      fabEl.classList.toggle('open', chatOpened);
      if (chatOpened && messagesEl.children.length === 0) {
        addMessage(CHAT_GREETINGS[detectLang()] || CHAT_GREETINGS.id, 'bot');
      }
      if (chatOpened) inputEl.focus();
    };

    window.sendChatMessage = async function() {
      var msg = inputEl.value.trim();
      if (!msg || chatBusy) return;

      addMessage(msg, 'user');
      inputEl.value = '';
      inputEl.style.height = 'auto';
      chatBusy = true;
      sendBtn.disabled = true;

      var typing = addMessage('Typing...', 'bot typing');

      try {
        var res = await fetch('/api/chat/landing', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg, sessionId: chatSessionId }),
        });
        var data = await res.json();
        typing.remove();

        if (res.ok && data.reply) {
          chatSessionId = data.sessionId;
          addMessage(data.reply, 'bot');
        } else {
          addMessage(data.error || 'Sorry, something went wrong. Please try again.', 'bot');
        }
      } catch(e) {
        typing.remove();
        addMessage('Connection error. Please try again.', 'bot');
      }

      chatBusy = false;
      sendBtn.disabled = false;
      inputEl.focus();
    };

    // Send on Enter (Shift+Enter for newline)
    inputEl.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        window.sendChatMessage();
      }
    });

    // Auto-resize textarea
    inputEl.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 80) + 'px';
    });
  })();
  </script>
