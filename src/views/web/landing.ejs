  <script>
    // Track scroll depth for LTV analysis
    let maxScroll = 0;
    let scrollThrottle = null;
    window.addEventListener('scroll', function() {
      if (scrollThrottle) return;
      scrollThrottle = requestAnimationFrame(function() {
        scrollThrottle = null;
        const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        if (scrollPercent > maxScroll) {
          maxScroll = Math.floor(scrollPercent / 25) * 25;
          if (maxScroll > 0 && typeof gtag !== 'undefined') {
            gtag('event', 'scroll_depth', { event_category: 'engagement', event_label: maxScroll + '%', value: maxScroll });
          }
        }
      });
    });

    // Track time on page for LTV analysis
    let timeOnPage = 0;
    setInterval(function() {
      timeOnPage += 10;
      if (timeOnPage % 30 === 0 && typeof gtag !== 'undefined') {
        gtag('event', 'time_on_page', {
          event_category: 'engagement',
          event_label: timeOnPage + 's',
          value: timeOnPage
        });
      }
    }, 10000);
  </script>
