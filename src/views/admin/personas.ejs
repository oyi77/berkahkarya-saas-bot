<style>
  .persona-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .persona-table th { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
  .persona-table td { padding: 10px 12px; border-bottom: 1px solid rgba(42,42,58,0.5); vertical-align: middle; }
  .persona-table tr:last-child td { border-bottom: none; }
  .persona-table tr:hover td { background: rgba(196,163,90,0.03); }
  .niche-tag { display: inline-block; padding: 2px 7px; border-radius: 9999px; font-size: 11px; background: #1a2a4a; color: #60a5fa; margin: 1px 2px; }
  .preset-tag { display: inline-block; padding: 2px 7px; border-radius: 9999px; font-size: 11px; background: #2a1a4a; color: #a78bfa; margin: 1px 2px; }
  .inline-edit { display: none; background: rgba(13,13,20,0.7); border-top: 1px solid var(--border); }
  .inline-edit.open { display: table-row; }
  .inline-edit td { padding: 16px 12px; }
  .niche-checkbox-grid { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
  .niche-cb-label { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border-radius: 9999px; font-size: 12px; background: #1a1a2e; border: 1px solid var(--border); cursor: pointer; }
  .niche-cb-label:hover { border-color: var(--gold-dim); }
  .niche-cb-label input { accent-color: var(--gold); }
</style>

<div class="section-title">🎭 Persona Management</div>
<div class="section-sub">Override persona settings — allowed niches, presets, and price multipliers. Changes are persisted to DB and cached for 5 minutes.</div>

<div class="card" style="overflow-x: auto;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
    <span style="font-size: 13px; color: var(--muted);"><%= personas.length %> personas loaded</span>
    <button class="btn btn-ghost btn-sm" onclick="loadPersonas()">🔃 Reload</button>
  </div>

  <table class="persona-table" id="persona-table">
    <thead>
      <tr>
        <th>Persona</th>
        <th>Allowed Niches</th>
        <th>Allowed Presets</th>
        <th>Price Multiplier</th>
        <th style="width: 80px;"></th>
      </tr>
    </thead>
    <tbody id="persona-tbody">
      <% personas.forEach(function(p) { %>
      <tr id="row-<%= p.id %>">
        <td>
          <span style="font-size: 18px;"><%= p.emoji %></span>
          <span style="margin-left: 8px; font-weight: 600;"><%= p.name %></span>
          <div style="font-size: 11px; color: var(--muted); margin-top: 2px;"><code style="background: #111; padding: 1px 5px; border-radius: 3px;"><%= p.id %></code></div>
        </td>
        <td id="niches-display-<%= p.id %>">
          <% if (p.allowedNiches === 'ALL') { %>
            <span class="niche-tag" style="background: #0f3020; color: #4ade80;">ALL</span>
          <% } else { %>
            <% (p.allowedNiches || []).forEach(function(n) { %><span class="niche-tag"><%= n %></span><% }); %>
          <% } %>
        </td>
        <td id="presets-display-<%= p.id %>">
          <% (p.allowedPresets || []).forEach(function(pr) { %><span class="preset-tag"><%= pr %></span><% }); %>
        </td>
        <td id="multiplier-display-<%= p.id %>">
          <span style="font-weight: 600; color: var(--gold);"><%= (p.priceMultiplier || 1.0).toFixed(2) %>x</span>
        </td>
        <td>
          <button class="btn btn-ghost btn-xs" onclick="toggleEdit('<%= p.id %>')">✏️ Edit</button>
        </td>
      </tr>
      <tr class="inline-edit" id="edit-<%= p.id %>">
        <td colspan="5">
          <div style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 16px; align-items: start;">
            <!-- Allowed Niches -->
            <div>
              <div class="form-group">
                <label>Allowed Niches</label>
                <div style="margin-bottom: 6px;">
                  <label style="font-size: 12px; cursor: pointer;">
                    <input type="checkbox" id="all-niches-<%= p.id %>" onchange="toggleAllNiches('<%= p.id %>', this.checked)"
                      <%= p.allowedNiches === 'ALL' ? 'checked' : '' %>>
                    Allow ALL niches
                  </label>
                </div>
                <div class="niche-checkbox-grid" id="niche-grid-<%= p.id %>">
                  <% nicheIds.forEach(function(nid) {
                       var checked = p.allowedNiches === 'ALL' || (Array.isArray(p.allowedNiches) && p.allowedNiches.includes(nid));
                  %>
                  <label class="niche-cb-label">
                    <input type="checkbox" name="niche-<%= p.id %>" value="<%= nid %>" <%= checked ? 'checked' : '' %>>
                    <%= nid %>
                  </label>
                  <% }); %>
                </div>
              </div>
            </div>
            <!-- Allowed Presets -->
            <div>
              <div class="form-group">
                <label>Allowed Presets</label>
                <div class="niche-checkbox-grid">
                  <% ['quick', 'standard', 'extended', 'custom'].forEach(function(pr) {
                       var checked = Array.isArray(p.allowedPresets) && p.allowedPresets.includes(pr);
                  %>
                  <label class="niche-cb-label">
                    <input type="checkbox" name="preset-<%= p.id %>" value="<%= pr %>" <%= checked ? 'checked' : '' %>>
                    <%= pr %>
                  </label>
                  <% }); %>
                </div>
              </div>
              <div class="form-group" style="margin-top: 12px;">
                <label>Price Multiplier</label>
                <input type="number" class="input input-sm" id="multiplier-<%= p.id %>"
                  value="<%= (p.priceMultiplier || 1.0).toFixed(2) %>"
                  min="0.1" max="10" step="0.05" style="width: 80px;">
                <span style="font-size: 12px; color: var(--muted); margin-left: 4px;">x (1.0 = no change)</span>
              </div>
            </div>
            <!-- Actions -->
            <div style="display: flex; flex-direction: column; gap: 8px; padding-top: 20px;">
              <button class="btn btn-gold btn-sm" onclick="savePersona('<%= p.id %>')">💾 Save</button>
              <button class="btn btn-ghost btn-sm" onclick="toggleEdit('<%= p.id %>')">Cancel</button>
            </div>
          </div>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<!-- Toast container (shared via layout if not already present) -->
<div id="toast-container" style="position:fixed;bottom:24px;right:24px;z-index:200;display:flex;flex-direction:column;gap:8px;"></div>

<script>
function toggleEdit(id) {
  const row = document.getElementById('edit-' + id);
  row.classList.toggle('open');
}

function toggleAllNiches(id, checked) {
  const grid = document.getElementById('niche-grid-' + id);
  grid.querySelectorAll('input[type=checkbox]').forEach(cb => { cb.disabled = checked; });
}

// Init disabled state
document.querySelectorAll('[id^="all-niches-"]').forEach(function(cb) {
  const id = cb.id.replace('all-niches-', '');
  if (cb.checked) {
    const grid = document.getElementById('niche-grid-' + id);
    if (grid) grid.querySelectorAll('input[type=checkbox]').forEach(c => { c.disabled = true; });
  }
});

async function savePersona(id) {
  const allNiches = document.getElementById('all-niches-' + id).checked;
  const nicheInputs = document.querySelectorAll('input[name="niche-' + id + '"]:checked');
  const presetInputs = document.querySelectorAll('input[name="preset-' + id + '"]:checked');
  const multiplier = parseFloat(document.getElementById('multiplier-' + id).value) || 1.0;

  const allowedNiches = allNiches ? 'ALL' : Array.from(nicheInputs).map(i => i.value);
  const allowedPresets = Array.from(presetInputs).map(i => i.value);

  const payload = { id, allowedNiches, allowedPresets, priceMultiplier: multiplier };

  try {
    const res = await fetch('/api/personas', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Save failed');
    showToast('Persona ' + id + ' saved', 'success');
    toggleEdit(id);
    // Refresh display
    updateDisplayRow(id, allowedNiches, allowedPresets, multiplier);
  } catch (e) {
    showToast(e.message, 'error');
  }
}

function updateDisplayRow(id, niches, presets, multiplier) {
  const nd = document.getElementById('niches-display-' + id);
  if (nd) {
    if (niches === 'ALL') {
      nd.innerHTML = '<span class="niche-tag" style="background:#0f3020;color:#4ade80;">ALL</span>';
    } else {
      nd.innerHTML = niches.map(n => '<span class="niche-tag">' + n + '</span>').join('');
    }
  }
  const pd = document.getElementById('presets-display-' + id);
  if (pd) pd.innerHTML = presets.map(p => '<span class="preset-tag">' + p + '</span>').join('');
  const md = document.getElementById('multiplier-display-' + id);
  if (md) md.innerHTML = '<span style="font-weight:600;color:var(--gold);">' + multiplier.toFixed(2) + 'x</span>';
}

async function loadPersonas() {
  try {
    const res = await fetch('/api/personas');
    if (!res.ok) throw new Error('Failed to load');
    showToast('Personas reloaded — refresh page to see latest', 'info');
  } catch (e) {
    showToast(e.message, 'error');
  }
}

function showToast(msg, type) {
  const tc = document.getElementById('toast-container');
  if (!tc) return;
  const t = document.createElement('div');
  t.className = 'toast toast-' + (type || 'info');
  t.textContent = msg;
  tc.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
</script>
