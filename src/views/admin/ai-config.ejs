<script>
// ===================== AUTH =====================
const getToken = () => localStorage.getItem('admin_password') || new URLSearchParams(location.search).get('token') || '';

function logout() {
  localStorage.removeItem('admin_password');
  document.cookie = 'admin_token=; Max-Age=0; Path=/;';
  location.href = '/admin/login';
}

// ===================== API =====================
async function api(path, opts = {}) {
  const token = getToken();
  const headers = {
    'Authorization': 'Basic ' + btoa(':' + token),
    ...(opts.headers || {}),
  };
  if (opts.body && typeof opts.body !== 'string' && !(opts.body instanceof FormData)) {
    headers['Content-Type'] = 'application/json';
    opts.body = JSON.stringify(opts.body);
  }
  try {
    const res = await fetch(path, { ...opts, headers, credentials: 'include' });
    if (res.status === 401) { location.href = '/admin/login'; return null; }
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = text; }
    if (!res.ok) throw new Error(typeof data === 'string' ? data : (data?.error || 'Request failed'));
    return data;
  } catch (e) {
    throw e;
  }
}

// ===================== TOAST =====================
function toast(msg, type = 'info') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}

// ===================== HELPERS =====================
function esc(s) {
  if (s == null) return '';
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

function setPreset(fieldId, value) {
  const el = document.getElementById(fieldId);
  if (el) el.value = value;
}

// ===================== TAB SWITCHING =====================
function switchAiTab(tab) {
  document.querySelectorAll('.ai-tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.ai-tab[data-tab="${tab}"]`).classList.add('active');
  document.querySelectorAll('.ai-panel').forEach(p => p.classList.remove('active'));
  document.getElementById(`ai-panel-${tab}`).classList.add('active');
}

// ===================== PROVIDER / MODEL LOGIC =====================
const AI_TASK_MODELS = {
  groq: ['llama-3.3-70b-versatile', 'llama-3.1-70b-versatile', 'llama-3.1-8b-instant', 'mixtral-8x7b-32768'],
  gemini: ['gemini-2.5-flash', 'gemini-2.0-flash', 'gemini-1.5-flash', 'gemini-1.5-pro'],
  omniroute: ['antigravity/gemini-2.5-flash', 'gpt-4o', 'gpt-4o-mini'],
  builtin: [],
};

const ALL_TASKS = ['storyboard', 'transcript', 'promptEnhancement', 'promptGeneration', 'caption', 'voNarration', 'qualityCheck', 'watermarkDetect'];

function onProviderChange(task) {
  const provider = document.getElementById(`task-${task}-provider`).value;
  const modelSelect = document.getElementById(`task-${task}-model-select`);
  const modelInput = document.getElementById(`task-${task}-model`);
  const models = AI_TASK_MODELS[provider] || [];

  if (provider === 'builtin') {
    modelSelect.style.display = 'none';
    modelInput.style.display = 'none';
    return;
  }

  modelInput.style.display = '';
  if (models.length) {
    modelSelect.innerHTML = models.map(m => `<option value="${esc(m)}">${esc(m)}</option>`).join('');
    if (!modelInput.value || !models.includes(modelInput.value)) {
      modelInput.value = models[0];
    }
    modelSelect.value = models.includes(modelInput.value) ? modelInput.value : models[0];
    modelSelect.style.display = '';
  } else {
    modelSelect.style.display = 'none';
  }
}

function syncModelInput(task) {
  const modelSelect = document.getElementById(`task-${task}-model-select`);
  const modelInput = document.getElementById(`task-${task}-model`);
  modelInput.value = modelSelect.value;
}

// ===================== LOAD CONFIG =====================
async function loadConfig() {
  try {
    const data = await api('/api/admin/ai-config');
    if (!data) return;

    // Populate tasks
    if (data.tasks) {
      ALL_TASKS.forEach(task => {
        const cfg = data.tasks[task] || {};
        const providerEl = document.getElementById(`task-${task}-provider`);
        const modelEl = document.getElementById(`task-${task}-model`);
        if (providerEl && cfg.provider) providerEl.value = cfg.provider;
        onProviderChange(task);
        if (modelEl && cfg.model) {
          modelEl.value = cfg.model;
          const modelSelect = document.getElementById(`task-${task}-model-select`);
          if (modelSelect) modelSelect.value = cfg.model;
        }
      });
    }

    // Populate prompts
    if (data.prompts) {
      const promptFields = ['botPersona', 'promptOptimizer', 'voNarration', 'qualityCheck', 'watermarkDetect', 'captionGeneration', 'storyboardGeneration'];
      promptFields.forEach(key => {
        const el = document.getElementById(`prompt-${key}`);
        if (el && data.prompts[key] != null) el.value = data.prompts[key];
      });
    }

    // Populate chat
    if (data.chat) {
      const chatEl = document.getElementById('chat-default-model');
      if (chatEl && data.chat.defaultModel) chatEl.value = data.chat.defaultModel;
    }
  } catch (e) {
    toast('Failed to load AI config: ' + e.message, 'error');
  }
}

// ===================== SAVE TASKS =====================
async function saveTasks() {
  const tasks = {};
  ALL_TASKS.forEach(task => {
    const provider = document.getElementById(`task-${task}-provider`)?.value || 'builtin';
    const model = document.getElementById(`task-${task}-model`)?.value || '';
    tasks[task] = { provider, model };
  });

  try {
    await api('/api/admin/ai-config/tasks', { method: 'POST', body: tasks });
    toast('Tasks config saved', 'success');
  } catch (e) {
    toast('Failed to save tasks: ' + e.message, 'error');
  }
}

// ===================== SAVE PROMPTS =====================
async function savePrompts() {
  const prompts = {};
  const promptFields = ['botPersona', 'promptOptimizer', 'voNarration', 'qualityCheck', 'watermarkDetect', 'captionGeneration', 'storyboardGeneration'];
  promptFields.forEach(key => {
    const el = document.getElementById(`prompt-${key}`);
    if (el) prompts[key] = el.value;
  });

  try {
    await api('/api/admin/ai-config/prompts', { method: 'POST', body: prompts });
    toast('Prompts saved', 'success');
  } catch (e) {
    toast('Failed to save prompts: ' + e.message, 'error');
  }
}

// ===================== SAVE CHAT =====================
async function saveChat() {
  const chat = { defaultModel: document.getElementById('chat-default-model').value };

  try {
    await api('/api/admin/ai-config/chat', { method: 'POST', body: chat });
    toast('Chat config saved', 'success');
  } catch (e) {
    toast('Failed to save chat config: ' + e.message, 'error');
  }
}

// ===================== RESET ALL =====================
async function resetAll(scope) {
  const label = scope === 'tasks' ? 'AI task configuration' : scope === 'prompts' ? 'all system prompts' : 'chat model config';
  if (!confirm(`Reset ${label} to built-in defaults?`)) return;

  try {
    await api('/api/admin/ai-config/reset', { method: 'POST', body: { scope } });
    await loadConfig();
    toast('Reset to defaults', 'success');
  } catch (e) {
    toast('Failed to reset: ' + e.message, 'error');
  }
}

// ===================== INIT =====================
const urlToken = new URLSearchParams(location.search).get('token');
if (urlToken) {
  localStorage.setItem('admin_password', urlToken);
}

loadConfig();

// ── MODEL BROWSER ──────────────────────────────────────────
let allModels = [];
let activeChips = new Set();
let currentPage = 1;
const PAGE_SIZE = 50;

async function loadModelCatalog(forceRefresh = false) {
  const tbody = document.getElementById('model-tbody');
  const stats = document.getElementById('model-stats');
  tbody.innerHTML = '<tr><td colspan="5" style="padding:40px;text-align:center;color:var(--muted);">Loading 4,000+ models from models.dev…</td></tr>';
  stats.textContent = 'Loading…';

  try {
    const url = forceRefresh ? '/api/admin/models-catalog?refresh=1' : '/api/admin/models-catalog';
    const data = await api(url);
    if (!data) return;
    allModels = data.models || [];
    stats.innerHTML = `<strong style="color:var(--fg)">${data.total.toLocaleString()}</strong> models across all providers — <span style="color:#63b3ed"><strong>${data.visionCount.toLocaleString()}</strong> vision-capable 👁</span>`;
    currentPage = 1;
    filterModels();
  } catch (e) {
    tbody.innerHTML = `<tr><td colspan="5" style="padding:40px;text-align:center;color:var(--red);">Failed to load: ${esc(e.message)}</td></tr>`;
    stats.textContent = 'Error loading catalog';
  }
}

function toggleChip(chip) {
  const el = document.getElementById('chip-' + chip);
  if (activeChips.has(chip)) { activeChips.delete(chip); el.classList.remove('active'); }
  else { activeChips.add(chip); el.classList.add('active'); }
  currentPage = 1;
  filterModels();
}

function filterModels() {
  const q = (document.getElementById('model-search').value || '').toLowerCase();
  let filtered = allModels;

  if (q) filtered = filtered.filter(m =>
    m.id.toLowerCase().includes(q) ||
    m.name.toLowerCase().includes(q) ||
    m.provider.toLowerCase().includes(q) ||
    m.providerName.toLowerCase().includes(q) ||
    (m.family || '').toLowerCase().includes(q)
  );
  if (activeChips.has('vision'))    filtered = filtered.filter(m => m.vision);
  if (activeChips.has('reasoning')) filtered = filtered.filter(m => m.reasoning);
  if (activeChips.has('tools'))     filtered = filtered.filter(m => m.toolCall);

  renderModels(filtered);
}

function renderModels(models) {
  const tbody = document.getElementById('model-tbody');
  const total = models.length;
  const start = (currentPage - 1) * PAGE_SIZE;
  const page = models.slice(start, start + PAGE_SIZE);

  if (!page.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="padding:40px;text-align:center;color:var(--muted);">No models match filters</td></tr>';
    document.getElementById('model-pagination').innerHTML = '';
    return;
  }

  tbody.innerHTML = page.map(m => {
    const caps = [
      m.vision    ? '<span class="cap-badge cap-vision">👁 Vision</span>' : '',
      m.reasoning ? '<span class="cap-badge cap-reasoning">🧠 Reasoning</span>' : '',
      m.toolCall  ? '<span class="cap-badge cap-tools">🔧 Tools</span>' : '',
      m.openWeights ? '<span class="cap-badge cap-open">⚡ Open</span>' : '',
    ].filter(Boolean).join('');

    const ctx = m.contextWindow ? (m.contextWindow >= 1000000 ? (m.contextWindow/1000000).toFixed(1)+'M' : m.contextWindow >= 1000 ? Math.round(m.contextWindow/1000)+'K' : m.contextWindow) : '—';

    return `<tr class="model-row" style="border-bottom:1px solid rgba(255,255,255,0.04);">
      <td style="padding:8px 10px;">
        <div class="model-id">${esc(m.id)}</div>
        ${m.family ? `<div style="font-size:10px;color:var(--muted);margin-top:2px;">${esc(m.family)}</div>` : ''}
      </td>
      <td style="padding:8px 10px;" class="provider-name">${esc(m.providerName)}</td>
      <td style="padding:8px 10px;">${caps || '<span style="color:var(--muted);font-size:11px;">text only</span>'}</td>
      <td style="padding:8px 10px;color:var(--muted);white-space:nowrap;">${ctx}</td>
      <td style="padding:8px 10px;">
        <select class="input" style="font-size:11px;padding:3px 6px;height:auto;" onchange="useModelForTask('${esc(m.id)}', this.value); this.value=''">
          <option value="">Use for…</option>
          <option value="promptEnhancement">Prompt Enhancement</option>
          <option value="promptGeneration">Prompt Generation</option>
          <option value="storyboard">Storyboard</option>
          <option value="caption">Caption</option>
          <option value="voNarration">VO Narration</option>
          <option value="transcript">Transcript</option>
          <option value="qualityCheck">Quality Check</option>
          <option value="watermarkDetect">Watermark</option>
          <option value="chat">Chat Model</option>
        </select>
      </td>
    </tr>`;
  }).join('');

  // Pagination
  const totalPages = Math.ceil(total / PAGE_SIZE);
  const pag = document.getElementById('model-pagination');
  if (totalPages <= 1) { pag.innerHTML = `<span style="font-size:12px;color:var(--muted);">Showing ${total} models</span>`; return; }

  let pagHtml = `<span style="font-size:12px;color:var(--muted);margin-right:8px;">${total.toLocaleString()} results</span>`;
  if (currentPage > 1) pagHtml += `<button class="btn btn-ghost btn-sm" onclick="gotoPage(${currentPage-1})">← Prev</button>`;
  pagHtml += `<span style="font-size:12px;color:var(--muted);padding:0 8px;">Page ${currentPage} / ${totalPages}</span>`;
  if (currentPage < totalPages) pagHtml += `<button class="btn btn-ghost btn-sm" onclick="gotoPage(${currentPage+1})">Next →</button>`;
  pag.innerHTML = pagHtml;
}

function gotoPage(n) { currentPage = n; filterModels(); document.getElementById('model-table').scrollIntoView({behavior:'smooth'}); }

function useModelForTask(modelId, task) {
  if (!task) return;
  if (task === 'chat') {
    const el = document.getElementById('chat-default-model');
    if (el) { el.value = modelId; toast(`Chat model set to ${modelId}`, 'success'); }
  } else {
    switchAiTab('tasks');
    const modelInput = document.getElementById(`task-${task}-model`);
    const providerSel = document.getElementById(`task-${task}-provider`);
    if (modelInput) {
      modelInput.value = modelId;
      if (providerSel) { providerSel.value = 'omniroute'; onProviderChange(task); }
      modelInput.value = modelId; // re-set after onProviderChange resets it
      modelInput.style.borderColor = 'var(--gold)';
      setTimeout(() => { if (modelInput) modelInput.style.borderColor = ''; }, 2000);
      toast(`"${modelId}" set for ${task} — remember to Save`, 'success');
    }
  }
}

// Lazy-load when tab is opened
const _origSwitchAiTab = switchAiTab;
switchAiTab = function(tab) {
  _origSwitchAiTab(tab);
  if (tab === 'models' && allModels.length === 0) loadModelCatalog();
};
</script>
