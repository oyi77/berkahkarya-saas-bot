<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Model Playground — BerkahKarya Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --bg: #0d0d14;
      --sidebar: #111118;
      --card: #1a1a24;
      --border: #2a2a3a;
      --gold: #c4a35a;
      --gold-dim: #8a6f3a;
      --text: #e0e0f0;
      --muted: #888899;
      --green: #4ade80;
      --red: #f87171;
    }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; margin: 0; min-height: 100vh; }
    .sidebar { background: var(--sidebar); border-right: 1px solid var(--border); width: 240px; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 50; display: flex; flex-direction: column; }
    .main { margin-left: 240px; padding: 24px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; cursor: pointer; border-left: 3px solid transparent; transition: all 0.15s; color: var(--muted); font-size: 14px; }
    .nav-item:hover { background: rgba(196,163,90,0.08); color: var(--text); }
    .nav-item.active { border-left-color: var(--gold); color: var(--gold); background: rgba(196,163,90,0.1); }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; }
    .btn-gold { background: var(--gold); color: #0d0d14; }
    .btn-gold:disabled { opacity: 0.5; cursor: not-allowed; }
    .input { background: #0d0d14; border: 1px solid var(--border); color: var(--text); padding: 8px 12px; border-radius: 8px; font-size: 13px; outline: none; width: 100%; }
    .input:focus { border-color: var(--gold); }
    .tab-bar { display: flex; gap: 4px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 1px; }
    .tab { padding: 10px 20px; cursor: pointer; color: var(--muted); font-size: 14px; border-bottom: 2px solid transparent; transition: all 0.2s; }
    .tab.active { color: var(--gold); border-bottom-color: var(--gold); }
    .tab:hover:not(.active) { color: var(--text); }
    .playground-section { display: none; }
    .playground-section.active { display: block; }
    pre { background: #000; padding: 12px; border-radius: 8px; overflow-x: auto; font-size: 12px; border: 1px solid var(--border); }
    .preview-container { min-height: 200px; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.3); border-radius: 12px; border: 1px dashed var(--border); }
    .spinner { width: 24px; height: 24px; border: 3px solid rgba(196,163,90,0.2); border-top-color: var(--gold); border-radius: 50%; animation: spin 1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

<div class="sidebar">
  <div style="padding: 20px; border-bottom: 1px solid var(--border);">
    <div style="font-size: 16px; font-weight: 700; color: var(--gold);">⚡ BerkahKarya</div>
    <div style="font-size: 11px; color: var(--muted); margin-top: 2px;">Admin Dashboard v3</div>
  </div>
  <nav style="flex: 1; padding: 12px 0;">
    <div class="nav-item" onclick="window.location='/admin/dashboard'">📊 Dashboard</div>
    <div class="nav-item active">🧪 Playground</div>
    <div class="nav-item" onclick="window.location='/admin/providers'">🔌 Providers</div>
  </nav>
  <div style="padding: 16px 20px; border-top: 1px solid var(--border);">
    <button class="btn btn-gold" style="width: 100%; justify-content: center;" onclick="window.location='/admin/dashboard'">Back to Main</button>
  </div>
</div>

<div class="main">
  <div style="margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 700;">🧪 Model Playground</h1>
    <p style="color: var(--muted); font-size: 14px;">Test AI models and providers directly from the admin panel.</p>
  </div>

  <div class="tab-bar">
    <div class="tab active" data-tab="text" onclick="switchTab('text')">💬 Text/Chat</div>
    <div class="tab" data-tab="image" onclick="switchTab('image')">🖼️ Image Gen</div>
    <div class="tab" data-tab="video" onclick="switchTab('video')">🎬 Video Gen</div>
  </div>

  <!-- Text Playground -->
  <div id="section-text" class="playground-section active">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      <div class="card">
        <h3 style="margin-bottom: 16px; font-weight: 600;">Input</h3>
        <div style="margin-bottom: 16px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Select Model</label>
          <select id="text-model" class="input">
            <% omniModels.forEach(model => { %>
              <option value="<%= model %>"><%= model %></option>
            <% }) %>
          </select>
        </div>
        <div style="margin-bottom: 16px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Prompt</label>
          <textarea id="text-prompt" class="input" style="height: 200px;" placeholder="Tanyakan sesuatu..."></textarea>
        </div>
        <button id="btn-text" class="btn btn-gold" style="width: 100%; justify-content: center;" onclick="runText()">Send Message</button>
      </div>
      <div class="card">
        <h3 style="margin-bottom: 16px; font-weight: 600;">Output</h3>
        <div id="text-output" style="white-space: pre-wrap; font-size: 14px; line-height: 1.6; color: #ccc;">
          Result will appear here...
        </div>
      </div>
    </div>
  </div>

  <!-- Image Playground -->
  <div id="section-image" class="playground-section">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      <div class="card">
        <h3 style="margin-bottom: 16px; font-weight: 600;">Input</h3>
        <div style="margin-bottom: 16px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Provider</label>
          <select id="image-provider" class="input">
            <option value="">Auto (Routing)</option>
            <% imageProviders.forEach(p => { %>
              <option value="<%= p %>"><%= p %></option>
            <% }) %>
          </select>
        </div>
        <div style="margin-bottom: 16px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Aspect Ratio</label>
          <select id="image-ratio" class="input">
            <option value="1:1">Square (1:1)</option>
            <option value="16:9">Landscape (16:9)</option>
            <option value="9:16">Portrait (9:16)</option>
            <option value="4:5">Instagram (4:5)</option>
          </select>
        </div>
        <div style="margin-bottom: 16px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Prompt</label>
          <textarea id="image-prompt" class="input" style="height: 120px;" placeholder="Describe the image..."></textarea>
        </div>
        <button id="btn-image" class="btn btn-gold" style="width: 100%; justify-content: center;" onclick="runImage()">Generate Image</button>
      </div>
      <div class="card">
        <h3 style="margin-bottom: 16px; font-weight: 600;">Output</h3>
        <div id="image-preview" class="preview-container">
          <span style="color: var(--muted);">Image will appear here...</span>
        </div>
        <div id="image-meta" style="margin-top: 16px;"></div>
      </div>
    </div>
  </div>

  <!-- Video Playground -->
  <div id="section-video" class="playground-section">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      <div class="card">
        <h3 style="margin-bottom: 16px; font-weight: 600;">Input</h3>
        <div style="margin-bottom: 12px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Provider</label>
          <select id="video-provider" class="input">
            <option value="">Auto (Routing)</option>
            <% videoProviders.forEach(p => { %>
              <option value="<%= p %>"><%= p %></option>
            <% }) %>
          </select>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
          <div>
            <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Niche</label>
            <select id="video-niche" class="input">
              <option value="fnb">Food & Beverage</option>
              <option value="fashion">Fashion</option>
              <option value="tech">Tech</option>
              <option value="travel">Travel</option>
            </select>
          </div>
          <div>
            <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Duration</label>
            <select id="video-duration" class="input">
              <option value="5">5 seconds</option>
              <option value="10">10 seconds</option>
              <option value="15">15 seconds</option>
            </select>
          </div>
        </div>
        <div style="margin-bottom: 16px;">
          <label style="display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px;">Prompt</label>
          <textarea id="video-prompt" class="input" style="height: 100px;" placeholder="Describe the video..."></textarea>
        </div>
        <button id="btn-video" class="btn btn-gold" style="width: 100%; justify-content: center;" onclick="runVideo()">Generate Video</button>
      </div>
      <div class="card">
        <h3 style="margin-bottom: 16px; font-weight: 600;">Output</h3>
        <div id="video-preview" class="preview-container">
          <span style="color: var(--muted);">Video will appear here...</span>
        </div>
        <div id="video-meta" style="margin-top: 16px;"></div>
      </div>
    </div>
  </div>
</div>

<script>
  function switchTab(tabId) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.playground-section').forEach(s => s.classList.remove('active'));
    
    document.querySelector(`.tab[data-tab="${tabId}"]`).classList.add('active');
    document.getElementById(`section-${tabId}`).classList.add('active');
  }

  async function runText() {
    const btn = document.getElementById('btn-text');
    const output = document.getElementById('text-output');
    const prompt = document.getElementById('text-prompt').value;
    const model = document.getElementById('text-model').value;

    if (!prompt) return alert('Prompt required');

    btn.disabled = true;
    output.innerHTML = '<div class="spinner"></div> Processing...';

    try {
      const res = await fetch('/api/admin/playground/text', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt, model })
      });
      const data = await res.json();
      if (data.success) {
        output.textContent = data.content;
      } else {
        output.innerHTML = `<span style="color:var(--red);">Error: ${data.error || 'Failed to generate'}</span>`;
      }
    } catch (err) {
      output.innerHTML = `<span style="color:var(--red);">Error: ${err.message}</span>`;
    } finally {
      btn.disabled = false;
    }
  }

  async function runImage() {
    const btn = document.getElementById('btn-image');
    const preview = document.getElementById('image-preview');
    const meta = document.getElementById('image-meta');
    const prompt = document.getElementById('image-prompt').value;
    const provider = document.getElementById('image-provider').value;
    const aspectRatio = document.getElementById('image-ratio').value;

    if (!prompt) return alert('Prompt required');

    btn.disabled = true;
    preview.innerHTML = '<div class="spinner"></div> Generating...';
    meta.innerHTML = '';

    try {
      const res = await fetch('/api/admin/playground/image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt, provider, aspectRatio })
      });
      const data = await res.json();
      if (data.success) {
        preview.innerHTML = `<img src="${data.imageUrl}" class="max-w-full max-h-96 rounded-lg shadow-lg">`;
        meta.innerHTML = `<div style="font-size:12px; color:var(--muted);">Provider: <span style="color:var(--gold);">${data.provider}</span></div>`;
      } else {
        preview.innerHTML = `<span style="color:var(--red);">Error: ${data.error || 'Failed to generate'}</span>`;
      }
    } catch (err) {
      preview.innerHTML = `<span style="color:var(--red);">Error: ${err.message}</span>`;
    } finally {
      btn.disabled = false;
    }
  }

  async function runVideo() {
    const btn = document.getElementById('btn-video');
    const preview = document.getElementById('video-preview');
    const meta = document.getElementById('video-meta');
    const prompt = document.getElementById('video-prompt').value;
    const provider = document.getElementById('video-provider').value;
    const niche = document.getElementById('video-niche').value;
    const duration = document.getElementById('video-duration').value;

    if (!prompt) return alert('Prompt required');

    btn.disabled = true;
    preview.innerHTML = '<div class="spinner"></div> Generating... (This may take a while)';
    meta.innerHTML = '';

    try {
      const res = await fetch('/api/admin/playground/video', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt, provider, niche, duration })
      });
      const data = await res.json();
      if (data.success) {
        preview.innerHTML = `<video src="${data.videoUrl}" controls class="max-w-full max-h-96 rounded-lg shadow-lg"></video>`;
        meta.innerHTML = `<div style="font-size:12px; color:var(--muted);">Provider: <span style="color:var(--gold);">${data.provider}</span></div>`;
      } else {
        preview.innerHTML = `<span style="color:var(--red);">Error: ${data.error || 'Failed to generate'}</span>`;
      }
    } catch (err) {
      preview.innerHTML = `<span style="color:var(--red);">Error: ${err.message}</span>`;
    } finally {
      btn.disabled = false;
    }
  }
</script>

</body>
</html>
