<%
  // activePage: 'dashboard' | 'playground' | 'providers' | 'settings' | 'medias' | 'prompts' | 'dynamic-pricing'
  const _ap = typeof activePage !== 'undefined' ? activePage : 'dashboard';
  function _nav(page) { return _ap === page ? 'nav-item active' : 'nav-item'; }
%>
<button class="hamburger" onclick="document.getElementById('sidebar').classList.toggle('open')">&#9776;</button>
<div class="sidebar" id="sidebar">
  <div style="padding: 20px; border-bottom: 1px solid var(--border);">
    <div style="font-size: 16px; font-weight: 700; color: var(--gold);">⚡ BerkahKarya</div>
    <div style="font-size: 11px; color: var(--muted); margin-top: 2px;">Admin Dashboard v3</div>
  </div>
  <nav style="flex: 1; padding: 12px 0; overflow-y: auto;">
    <div class="nav-item <%= _ap === 'dashboard' && !window.location.hash ? 'active' : '' %>" id="nav-dashboard" onclick="window.location='/admin/dashboard'">📊 Overview</div>
    <div class="nav-item" id="nav-users" onclick="window.location='/admin/dashboard#users'">👥 Users</div>
    <div class="nav-item" id="nav-transactions" onclick="window.location='/admin/dashboard#transactions'">💳 Transactions</div>
    <div class="nav-item" id="nav-analytics" onclick="window.location='/admin/dashboard#analytics'">📈 Analytics</div>
    <div class="nav-item" id="nav-pricing" onclick="window.location='/admin/dashboard#pricing'">💰 Pricing</div>
    <div class="nav-item" id="nav-tokens" onclick="window.location='/admin/dashboard#tokens'">🪙 Token Usage</div>
    <div class="nav-item" id="nav-profit" onclick="window.location='/admin/dashboard#profit'">💹 Revenue</div>
    <div class="nav-item" id="nav-niches" onclick="window.location='/admin/dashboard#niches'">🏷️ Niches</div>
    <div class="nav-item" id="nav-landing-page" onclick="window.location='/admin/dashboard#landing-page'">🌐 Landing Page</div>
    <div style="margin: 8px 0; border-top: 1px solid var(--border);"></div>
    <div class="<%= _nav('medias') %>" onclick="window.location='/admin/medias'">🎬 Media Gallery</div>
    <div class="<%= _nav('prompts') %>" onclick="window.location='/admin/prompts'">✍️ Prompts</div>
    <div class="<%= _nav('providers') %>" onclick="window.location='/admin/providers'">🔌 Providers</div>
    <div class="<%= _nav('ai-config') %>" onclick="window.location='/admin/ai-config'">🤖 AI Config</div>
    <div class="<%= _nav('dynamic-pricing') %>" onclick="window.location='/admin/dynamic-pricing'">💵 Dynamic Pricing</div>
    <div class="<%= _nav('playground') %>" onclick="window.location='/admin/playground'">🧪 Playground</div>
    <div class="<%= _nav('personas') %>" onclick="window.location='/admin/personas'">🎭 Personas</div>
    <div class="<%= _nav('settings') %>" onclick="window.location='/admin/settings'">⚙️ Settings</div>
    <div style="margin: 8px 0; border-top: 1px solid var(--border);"></div>
    <div class="nav-item" onclick="window.location='/admin/dashboard#ai-assistant'">🤖 AI Assistant</div>
  </nav>
  <div style="padding: 16px 20px; border-top: 1px solid var(--border);">
    <div id="live-clock" style="font-size: 12px; color: var(--muted); font-family: monospace;"></div>
    <button class="btn btn-ghost btn-sm" style="margin-top: 8px; width: 100%; justify-content: center;" onclick="logout ? logout() : (localStorage.removeItem('admin_password'), document.cookie='admin_token=; Max-Age=0; Path=/;', location.href='/admin/login')">🚪 Logout</button>
  </div>
</div>

<script>
// Handle hash-based active states for dashboard subsections
function updateDashboardNav() {
  const hash = window.location.hash.replace('#', '');
  const isDashboard = window.location.pathname === '/admin/dashboard';

  // Handle Overview active state (only active when NO hash)
  const overviewEl = document.getElementById('nav-dashboard');
  if (overviewEl) {
    if (isDashboard && !hash) {
      overviewEl.classList.add('active');
    } else {
      overviewEl.classList.remove('active');
    }
  }

  // Remove active class from all dashboard subsections
  const subsections = ['users', 'transactions', 'analytics', 'pricing', 'tokens', 'profit', 'niches', 'landing-page'];
  subsections.forEach(section => {
    const el = document.getElementById(`nav-${section}`);
    if (el) el.classList.remove('active');
  });

  // Add active class to current subsection
  if (hash && subsections.includes(hash)) {
    const activeEl = document.getElementById(`nav-${hash}`);
    if (activeEl) activeEl.classList.add('active');
  }
}

// Update on page load and hash change
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', updateDashboardNav);
} else {
  updateDashboardNav();
}
window.addEventListener('hashchange', updateDashboardNav);
</script>
