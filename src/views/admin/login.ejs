<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - BerkahKarya Bot</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-gray-900 to-gray-800 text-white min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="bg-gray-800 rounded-lg shadow-2xl p-8">
      <h1 class="text-3xl font-bold mb-2 text-center">BerkahKarya Bot</h1>
      <p class="text-gray-400 text-center mb-8">Admin Dashboard</p>
      
      <form id="loginForm" onsubmit="handleLogin(event)">
        <div class="mb-6">
          <label for="password" class="block text-sm font-medium mb-2">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-lg focus:outline-none focus:border-blue-500 text-white"
            placeholder="Enter admin password"
            required
            autofocus
          >
        </div>
        
        <button 
          type="submit" 
          class="w-full bg-blue-600 hover:bg-blue-700 font-medium py-2 px-4 rounded-lg transition duration-200"
        >
          Login
        </button>
      </form>
      
      <div id="error" class="mt-4 p-3 bg-red-900 border border-red-700 rounded-lg hidden text-sm">
        <span id="errorText"></span>
      </div>
      
      <div id="success" class="mt-4 p-3 bg-green-900 border border-green-700 rounded-lg hidden text-sm">
        ✅ Login successful! Redirecting...
      </div>
    </div>
    
    <p class="text-center text-gray-400 mt-8 text-sm">
      Default password: <code class="bg-gray-800 px-2 py-1 rounded">admin</code>
    </p>
  </div>

  <script>
    async function handleLogin(e) {
      e.preventDefault();
      const password = document.getElementById('password').value;
      const errorDiv = document.getElementById('error');
      const successDiv = document.getElementById('success');
      
      try {
        // Verify password is correct
        const response = await fetch('/admin/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ password }),
          credentials: 'include',
        });

        if (response.ok) {
          successDiv.classList.remove('hidden');
          // Store password in localStorage for API calls
          localStorage.setItem('admin_password', password);
          setTimeout(() => {
            // Redirect to dashboard with token in query
            window.location.href = '/admin/dashboard?token=' + encodeURIComponent(password);
          }, 1000);
        } else {
          const data = await response.json();
          errorDiv.classList.remove('hidden');
          document.getElementById('errorText').textContent = data.error || 'Login failed';
        }
      } catch (error) {
        errorDiv.classList.remove('hidden');
        document.getElementById('errorText').textContent = 'Network error: ' + error.message;
      }
    }

    // Auto-fill from URL token if provided
    const params = new URLSearchParams(window.location.search);
    if (params.get('token')) {
      document.getElementById('password').value = decodeURIComponent(params.get('token'));
      document.getElementById('loginForm').dispatchEvent(new Event('submit'));
    }
  </script>
</body>
</html>
