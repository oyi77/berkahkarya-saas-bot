<!-- Toast Container -->
<div id="toast-container"></div>

<script>
// ===================== AUTH =====================
const getToken = () => localStorage.getItem('admin_password') || new URLSearchParams(location.search).get('token') || '';

function logout() {
  localStorage.removeItem('admin_password');
  document.cookie = 'admin_token=; Max-Age=0; Path=/;';
  location.href = '/admin/login';
}

// ===================== API =====================
async function api(path, opts = {}) {
  const token = getToken();
  const headers = {
    'Authorization': 'Basic ' + btoa(':' + token),
    ...(opts.headers || {}),
  };
  if (opts.body && typeof opts.body !== 'string' && !(opts.body instanceof FormData)) {
    headers['Content-Type'] = 'application/json';
    opts.body = JSON.stringify(opts.body);
  }
  try {
    const res = await fetch(path, { ...opts, headers, credentials: 'include' });
    if (res.status === 401) { location.href = '/admin/login'; return null; }
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = text; }
    if (!res.ok) throw new Error(typeof data === 'string' ? data : (data?.error || 'Request failed'));
    return data;
  } catch (e) {
    throw e;
  }
}

// ===================== TOAST =====================
function toast(msg, type = 'info') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}

// ===================== HELPERS =====================
function formatBalance(b) {
  if (!b) return `<span class="spinner"></span>`;
  if (b.status === 'not_configured') return `<span style="color:var(--muted);">—</span>`;
  if (b.status === 'not_supported') return `<span style="color:var(--muted);">N/A</span>`;
  if (b.status === 'error') return `<span style="color:var(--red);" title="${esc(b.error||'')}">Error</span>`;
  if (b.currency === 'key_valid') return `<span style="color:var(--green);">✓ Valid</span>`;
  if (b.balance !== null && b.balance !== undefined) return `<span style="color:var(--green);">${esc(String(b.balance))} ${esc(b.currency)}</span>`;
  return `<span style="color:var(--muted);">N/A</span>`;
}

function esc(s) {
  if (s == null) return '';
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

function reltime(s) {
  if (!s) return '—';
  const diff = Date.now() - new Date(s).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return m + 'm ago';
  const h = Math.floor(m / 60);
  if (h < 24) return h + 'h ago';
  return Math.floor(h / 24) + 'd ago';
}

function dt(s) {
  if (!s) return '—';
  return new Date(s).toLocaleString('id-ID', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
}

// ===================== STATE =====================
let currentTab = 'video';
let providersData = { video: [], image: [] };
let balancesData = {};
let expandedCards = new Set();

// ===================== TAB SWITCHING =====================
function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[data-tab="${tab}"]`).classList.add('active');

  const isAITasks = tab === 'ai-tasks';
  const isCustom = tab === 'custom';
  const isBuiltin = !isAITasks && !isCustom;

  document.getElementById('ai-tasks-panel').style.display = isAITasks ? 'block' : 'none';
  document.getElementById('custom-providers-panel').style.display = isCustom ? 'block' : 'none';
  document.getElementById('provider-grid').style.display = isBuiltin ? '' : 'none';
  document.querySelector('.kpi-grid').style.display = isBuiltin ? '' : 'none';
  document.querySelector('.card').style.display = isBuiltin ? '' : 'none';

  if (isAITasks) {
    loadAITaskSettings();
  } else if (isCustom) {
    loadCustomProviders();
  } else {
    renderCards();
    updateSummary();
  }
}

// ===================== LOAD PROVIDERS =====================
async function loadProviders() {
  const grid = document.getElementById('provider-grid');
  grid.innerHTML = '<div class="loading">Loading providers...</div>';

  try {
    const data = await api('/api/admin/providers/all');
    if (!data) return;

    providersData = data;
    renderCards();
    updateSummary();

    // Load balances after providers
    loadBalances();
  } catch (e) {
    grid.innerHTML = `<div class="empty-state">Failed to load providers: ${esc(e.message)}</div>`;
    toast('Failed to load providers: ' + e.message, 'error');
  }
}

// ===================== LOAD BALANCES =====================
async function loadBalances() {
  try {
    const data = await api('/api/admin/providers/balances');
    if (!data || !data.balances) return;

    balancesData = {};
    data.balances.forEach(b => {
      balancesData[b.provider] = b;
    });

    // Update balance displays for cards already rendered with spinner placeholders
    Object.entries(balancesData).forEach(([key, b]) => {
      const el = document.getElementById(`balance-${key}`);
      if (el) el.innerHTML = formatBalance(b);
    });
  } catch (e) {
    console.error('Failed to load balances:', e);
  }
}

// ===================== UPDATE SUMMARY =====================
function updateSummary() {
  const providers = providersData[currentTab] || [];
  const total = providers.length;
  const active = providers.filter(p => p.enabled !== false).length;
  const configured = providers.filter(p => p.hasApiKey).length;
  const erroring = providers.filter(p => p.circuitBreaker?.state === 'open').length;

  document.getElementById('summary-total').textContent = total;
  document.getElementById('summary-active').textContent = active;
  document.getElementById('summary-configured').textContent = configured;
  document.getElementById('summary-erroring').textContent = erroring;
}

// ===================== RENDER CARDS =====================
function renderCards() {
  const grid = document.getElementById('provider-grid');
  const providers = providersData[currentTab] || [];

  if (!providers.length) {
    grid.innerHTML = `<div class="empty-state">No ${currentTab} providers configured</div>`;
    return;
  }

  grid.innerHTML = providers.map(p => renderProviderCard(p)).join('');
}

function renderProviderCard(p) {
  const key = p.key || p.name;
  const type = currentTab;
  const isExpanded = expandedCards.has(key);
  const hasError = p.circuitBreaker?.state === 'open';

  // API Key status
  const apiKeyStatus = p.hasApiKey
    ? '<span class="status-dot green" title="API key configured"></span>'
    : '<span class="status-dot red" title="API key missing"></span>';

  // Circuit breaker status
  let cbBadge = 'badge-closed';
  let cbDot = 'green';
  let cbLabel = 'Closed';
  if (p.circuitBreaker?.state === 'open') {
    cbBadge = 'badge-open';
    cbDot = 'red';
    cbLabel = 'Open';
  } else if (p.circuitBreaker?.state === 'half_open') {
    cbBadge = 'badge-half';
    cbDot = 'yellow';
    cbLabel = 'Half-Open';
  }

  const balanceDisplay = balancesData[key] !== undefined
    ? formatBalance(balancesData[key])
    : `<span id="balance-${key}"><span class="spinner"></span></span>`;

  return `
    <div class="provider-card ${hasError ? 'erroring' : ''}" data-key="${esc(key)}">
      <div class="provider-header" onclick="toggleCard('${esc(key)}')">
        <div class="provider-row">
          <div style="flex: 1;">
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
              <span style="font-size: 15px; font-weight: 600;">${esc(p.name || key)}</span>
              <span class="badge badge-${type}">${type}</span>
              ${hasError ? '<span class="badge badge-open">⚠️ Erroring</span>' : ''}
            </div>
            <div style="display: flex; align-items: center; gap: 16px; font-size: 12px; color: var(--muted);">
              <span style="display: flex; align-items: center; gap: 4px;" title="API Key Status">
                ${apiKeyStatus} Key
              </span>
              <span style="display: flex; align-items: center; gap: 4px;" title="Circuit Breaker">
                <span class="status-dot ${cbDot}"></span>
                <span class="badge ${cbBadge}">${cbLabel}</span>
              </span>
              <span title="Balance">💰 ${balanceDisplay}</span>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 8px;">
            <div style="display: flex; align-items: center; gap: 4px;">
              <input type="number" class="input input-sm" id="prio-${esc(key)}" value="${p.priority ?? 99}" min="1" max="999" onclick="event.stopPropagation()" onchange="markChanged('${esc(key)}')">
            </div>
            <div class="toggle ${p.enabled !== false ? 'on' : ''}" id="toggle-${esc(key)}" onclick="event.stopPropagation(); toggleProvider('${esc(key)}')" title="Enable/Disable"></div>
          </div>
        </div>
      </div>

      <div class="provider-details ${isExpanded ? 'open' : ''}" id="details-${esc(key)}">
        <div style="padding-top: 16px;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Timeout</div>
              <div style="font-size: 13px;">${p.timeout ? p.timeout + 'ms' : '—'}</div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Failures</div>
              <div style="font-size: 13px;">${p.circuitBreaker?.failureCount ?? 0}</div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Last Success</div>
              <div style="font-size: 12px;">${reltime(p.circuitBreaker?.lastSuccess)}</div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Last Failure</div>
              <div style="font-size: 12px;">${reltime(p.circuitBreaker?.lastFailure)}</div>
            </div>
          </div>

          ${p.strengths?.length ? `
            <div style="margin-bottom: 12px;">
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 6px;">Strengths</div>
              <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                ${(Array.isArray(p.strengths) ? p.strengths : [p.strengths]).filter(Boolean).map(s => `<span style="background: rgba(74,222,128,0.1); color: var(--green); padding: 2px 8px; border-radius: 4px; font-size: 11px;">${esc(s)}</span>`).join('')}
              </div>
            </div>
          ` : ''}

          ${p.quirks?.length ? `
            <div style="margin-bottom: 16px;">
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 6px;">Quirks / Notes</div>
              <div style="font-size: 12px; color: var(--yellow); line-height: 1.5;">
                ${Array.isArray(p.quirks) ? p.quirks.map(q => `• ${esc(q)}`).join('<br>') : `• ${esc(p.quirks)}`}
              </div>
            </div>
          ` : ''}

          <div style="display: flex; gap: 8px; flex-wrap: wrap; border-top: 1px solid var(--border); padding-top: 16px;">
            <button class="btn btn-ghost btn-xs" onclick="testProvider('${esc(key)}')">🧪 Test</button>
            <button class="btn btn-ghost btn-xs" onclick="resetCB('${esc(key)}')">🔄 Reset CB</button>
            <button class="btn btn-ghost btn-xs" onclick="showModels('${esc(key)}')">📋 Models</button>
          </div>
        </div>
      </div>
    </div>
  `;
}

// ===================== CARD INTERACTIONS =====================
function toggleCard(key) {
  if (expandedCards.has(key)) {
    expandedCards.delete(key);
  } else {
    expandedCards.add(key);
  }
  const details = document.getElementById(`details-${key}`);
  if (details) {
    details.classList.toggle('open', expandedCards.has(key));
  }
}

function toggleProvider(key) {
  const toggle = document.getElementById(`toggle-${key}`);
  const isOn = toggle.classList.toggle('on');
  markChanged(key);
}

function markChanged(key) {
  // Visual indicator for unsaved changes
  const card = document.querySelector(`.provider-card[data-key="${key}"]`);
  if (card) {
    card.style.borderColor = 'var(--gold-dim)';
  }
}

// ===================== BULK ACTIONS =====================
async function refreshAllBalances() {
  toast('Refreshing all balances...', 'info');
  await loadBalances();
  toast('Balances refreshed', 'success');
}

async function resetAllCB() {
  if (!confirm('Reset all circuit breakers? This will allow requests to all providers again.')) return;

  try {
    await api('/api/admin/providers/reset-all-cb', { method: 'POST' });
    toast('All circuit breakers reset', 'success');
    loadProviders();
  } catch (e) {
    toast('Failed: ' + e.message, 'error');
  }
}

// ===================== PROVIDER ACTIONS =====================
async function saveProviders() {
  const providers = providersData[currentTab] || [];
  const settings = {};

  providers.forEach(p => {
    const key = p.key || p.name;
    const prioEl = document.getElementById(`prio-${key}`);
    const toggleEl = document.getElementById(`toggle-${key}`);

    if (prioEl && toggleEl) {
      settings[key] = {
        priority: parseInt(prioEl.value) || 99,
        enabled: toggleEl.classList.contains('on')
      };
    }
  });

  try {
    await api('/api/admin/providers/settings', {
      method: 'POST',
      body: { type: currentTab, settings }
    });
    toast('Provider settings saved', 'success');

    // Clear visual indicators
    document.querySelectorAll('.provider-card').forEach(card => {
      card.style.borderColor = '';
    });

    loadProviders();
  } catch (e) {
    toast('Failed to save: ' + e.message, 'error');
  }
}

async function resetCB(key) {
  try {
    await api(`/api/admin/providers/${encodeURIComponent(key)}/reset-cb`, { method: 'POST' });
    toast(`Circuit breaker reset for ${key}`, 'success');
    loadProviders();
  } catch (e) {
    toast('Failed: ' + e.message, 'error');
  }
}

async function testProvider(key) {
  toast(`Testing ${key}...`, 'info');

  try {
    const result = await api(`/api/admin/providers/${encodeURIComponent(key)}/test`, { method: 'POST' });

    if (result?.success) {
      toast(`✅ ${key} test passed`, 'success');
    } else {
      toast(`❌ ${key} test failed: ${result?.error || 'Unknown error'}`, 'error');
    }
  } catch (e) {
    toast(`❌ Test failed: ${e.message}`, 'error');
  }
}

async function showModels(key) {
  const modal = document.getElementById('modal-models');
  const content = document.getElementById('modal-models-content');
  const title = document.getElementById('modal-models-title');

  title.textContent = `Models — ${key}`;
  content.innerHTML = '<div class="loading">Loading...</div>';
  modal.classList.add('open');

  try {
    const provider = [...providersData.video, ...providersData.image].find(p => (p.key || p.name) === key);
    const models = provider?.models || [];

    if (!models.length) {
      content.innerHTML = '<div class="empty-state">No models configured for this provider</div>';
      return;
    }

    content.innerHTML = `
      <table style="width: 100%; font-size: 13px;">
        <thead>
          <tr>
            <th style="text-align: left; padding: 8px; color: var(--muted); border-bottom: 1px solid var(--border);">Model ID</th>
            <th style="text-align: left; padding: 8px; color: var(--muted); border-bottom: 1px solid var(--border);">Type</th>
          </tr>
        </thead>
        <tbody>
          ${models.map(m => `
            <tr>
              <td style="padding: 8px; font-family: monospace; font-size: 12px;">${esc(typeof m === 'string' ? m : m.id || m.name)}</td>
              <td style="padding: 8px;"><span class="badge badge-${currentTab}">${currentTab}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  } catch (e) {
    content.innerHTML = `<div class="empty-state">Failed to load models: ${esc(e.message)}</div>`;
  }
}

// ===================== MODAL HELPERS =====================
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-overlay.open').forEach(m => m.classList.remove('open'));
  }
});

// ===================== AI TASK SETTINGS =====================
const AI_TASK_MODELS = {
  groq: ['llama-3.3-70b-versatile', 'llama-3.1-70b-versatile', 'llama-3.1-8b-instant', 'mixtral-8x7b-32768'],
  gemini: ['gemini-2.5-flash', 'gemini-2.0-flash', 'gemini-1.5-flash', 'gemini-1.5-pro'],
  omniroute: ['antigravity/gemini-2.5-flash', 'gpt-4o', 'gpt-4o-mini'],
  builtin: [],
};

const AI_TASKS = ['storyboard', 'transcript', 'promptEnhancement', 'promptGeneration'];

function onProviderChange(task) {
  const provider = document.getElementById(`task-${task}-provider`).value;
  const modelSelect = document.getElementById(`task-${task}-model-select`);
  const modelInput = document.getElementById(`task-${task}-model`);
  const models = AI_TASK_MODELS[provider] || [];

  if (provider === 'builtin') {
    modelSelect.style.display = 'none';
    modelInput.style.display = 'none';
    return;
  }

  modelInput.style.display = '';
  if (models.length) {
    modelSelect.innerHTML = models.map(m => `<option value="${esc(m)}">${esc(m)}</option>`).join('');
    // Set the text input to the first option by default if empty
    if (!modelInput.value || !models.includes(modelInput.value)) {
      modelInput.value = models[0];
    }
    modelSelect.value = models.includes(modelInput.value) ? modelInput.value : models[0];
    modelSelect.style.display = '';
  } else {
    modelSelect.style.display = 'none';
  }
}

function syncModelInput(task) {
  const modelSelect = document.getElementById(`task-${task}-model-select`);
  const modelInput = document.getElementById(`task-${task}-model`);
  modelInput.value = modelSelect.value;
}

async function loadAITaskSettings() {
  try {
    const settings = await api('/api/admin/ai-tasks/settings');
    if (!settings) return;

    AI_TASKS.forEach(task => {
      const cfg = settings[task] || {};
      const providerEl = document.getElementById(`task-${task}-provider`);
      const modelEl = document.getElementById(`task-${task}-model`);
      if (providerEl && cfg.provider) providerEl.value = cfg.provider;
      if (modelEl && cfg.model) modelEl.value = cfg.model;
      onProviderChange(task);
      // Re-set model after onProviderChange (which may have overwritten it)
      if (modelEl && cfg.model) {
        modelEl.value = cfg.model;
        const modelSelect = document.getElementById(`task-${task}-model-select`);
        if (modelSelect) modelSelect.value = cfg.model;
      }
    });
  } catch (e) {
    toast('Failed to load AI task settings: ' + e.message, 'error');
  }
}

async function saveAITaskSettings() {
  const settings = {};
  AI_TASKS.forEach(task => {
    const provider = document.getElementById(`task-${task}-provider`)?.value || 'builtin';
    const model = document.getElementById(`task-${task}-model`)?.value || '';
    settings[task] = { provider, model };
  });

  try {
    await api('/api/admin/ai-tasks/settings', { method: 'POST', body: settings });
    toast('AI task settings saved', 'success');
  } catch (e) {
    toast('Failed to save: ' + e.message, 'error');
  }
}

// ===================== SAVE BUTTON =====================
document.addEventListener('DOMContentLoaded', () => {
  // Add floating save button
  const saveBtn = document.createElement('button');
  saveBtn.className = 'btn btn-gold';
  saveBtn.style.cssText = 'position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 50; box-shadow: 0 4px 20px rgba(196,163,90,0.3);';
  saveBtn.innerHTML = '💾 Save Changes';
  saveBtn.onclick = () => currentTab === 'ai-tasks' ? saveAITaskSettings() : saveProviders();
  document.body.appendChild(saveBtn);
});

