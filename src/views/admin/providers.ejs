const urlToken = new URLSearchParams(location.search).get('token');
if (urlToken) {
  localStorage.setItem('admin_password', urlToken);
}

loadProviders();

// Auto-refresh every 60s
setInterval(() => {
  loadBalances();
  updateSummary();
