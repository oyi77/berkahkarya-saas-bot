<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Provider Management — BerkahKarya Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --bg: #0d0d14;
      --sidebar: #111118;
      --card: #1a1a24;
      --border: #2a2a3a;
      --gold: #c4a35a;
      --gold-dim: #8a6f3a;
      --text: #e0e0f0;
      --muted: #888899;
      --green: #4ade80;
      --red: #f87171;
      --blue: #3b82f6;
      --yellow: #fbbf24;
    }
    * { box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; }
    .sidebar { background: var(--sidebar); border-right: 1px solid var(--border); width: 240px; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 50; display: flex; flex-direction: column; }
    .main { margin-left: 240px; padding: 24px; min-height: 100vh; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; cursor: pointer; border-left: 3px solid transparent; transition: all 0.15s; color: var(--muted); font-size: 14px; }
    .nav-item:hover { background: rgba(196,163,90,0.08); color: var(--text); }
    .nav-item.active { border-left-color: var(--gold); color: var(--gold); background: rgba(196,163,90,0.1); }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
    .kpi-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 16px 20px; }
    .kpi-card .label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
    .kpi-card .value { font-size: 28px; font-weight: 700; margin-top: 4px; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: 11px; font-weight: 600; }
    .badge-video { background: #1a2a4a; color: #60a5fa; }
    .badge-image { background: #2a1a4a; color: #a78bfa; }
    .badge-active { background: #0f3020; color: #4ade80; }
    .badge-inactive { background: #3a0f0f; color: #f87171; }
    .badge-closed { background: #0f3020; color: #4ade80; }
    .badge-open { background: #3a0f0f; color: #f87171; }
    .badge-half { background: #3a2a0a; color: #fbbf24; }
    .badge-configured { background: #0f3020; color: #4ade80; }
    .badge-missing { background: #3a0f0f; color: #f87171; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; }
    .btn-gold { background: var(--gold); color: #0d0d14; }
    .btn-gold:hover { background: #d4b36a; }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.05); color: var(--text); }
    .btn-danger { background: #3a0f0f; color: #f87171; border: 1px solid #5a1f1f; }
    .btn-danger:hover { background: #5a1f1f; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .btn-xs { padding: 3px 8px; font-size: 11px; }
    .input { background: #0d0d14; border: 1px solid var(--border); color: var(--text); padding: 6px 10px; border-radius: 6px; font-size: 13px; outline: none; }
    .input:focus { border-color: var(--gold); }
    .input-sm { width: 60px; text-align: center; padding: 4px 6px; }
    .toggle { position: relative; width: 40px; height: 22px; background: var(--border); border-radius: 11px; cursor: pointer; transition: background 0.2s; }
    .toggle.on { background: var(--green); }
    .toggle::after { content: ''; position: absolute; width: 18px; height: 18px; background: #fff; border-radius: 50%; top: 2px; left: 2px; transition: transform 0.2s; }
    .toggle.on::after { transform: translateX(18px); }
    .tab-bar { display: flex; gap: 4px; margin-bottom: 16px; }
    .tab { padding: 8px 20px; border-radius: 8px; font-size: 14px; cursor: pointer; color: var(--muted); background: transparent; border: 1px solid transparent; transition: all 0.15s; }
    .tab.active { background: rgba(196,163,90,0.15); color: var(--gold); border-color: var(--gold-dim); }
    .tab:hover:not(.active) { background: rgba(255,255,255,0.05); color: var(--text); }
    .provider-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 16px; }
    .provider-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: border-color 0.15s; }
    .provider-card:hover { border-color: var(--gold-dim); }
    .provider-card.erroring { border-color: #5a1f1f; }
    .provider-header { padding: 16px; cursor: pointer; }
    .provider-header:hover { background: rgba(255,255,255,0.02); }
    .provider-row { display: flex; align-items: center; gap: 12px; }
    .provider-details { display: none; padding: 0 16px 16px; border-top: 1px solid var(--border); }
    .provider-details.open { display: block; }
    .status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
    .status-dot.green { background: var(--green); box-shadow: 0 0 8px rgba(74,222,128,0.4); }
    .status-dot.yellow { background: var(--yellow); box-shadow: 0 0 8px rgba(251,191,36,0.4); }
    .status-dot.red { background: var(--red); box-shadow: 0 0 8px rgba(248,113,113,0.4); }
    .status-dot.gray { background: var(--muted); }
    .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .section-title { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
    .section-sub { color: var(--muted); font-size: 13px; margin-bottom: 20px; }
    .loading { text-align: center; padding: 40px; color: var(--muted); }
    .empty-state { text-align: center; padding: 40px; color: var(--muted); font-size: 14px; }
    .divider { border: none; border-top: 1px solid var(--border); margin: 16px 0; }
    /* Toast */
    #toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 200; display: flex; flex-direction: column; gap: 8px; }
    .toast { padding: 12px 18px; border-radius: 10px; font-size: 13px; font-weight: 500; max-width: 320px; animation: slideIn 0.2s ease; border: 1px solid; }
    .toast-success { background: #0f3020; border-color: #1a5030; color: #4ade80; }
    .toast-error { background: #3a0f0f; border-color: #5a1f1f; color: #f87171; }
    .toast-info { background: #0f2040; border-color: #1a3060; color: #60a5fa; }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 24px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
    .modal h3 { font-size: 18px; font-weight: 700; margin: 0 0 20px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    /* Mobile */
    .hamburger { display: none; position: fixed; top: 12px; left: 12px; z-index: 200; background: var(--gold); border: none; border-radius: 8px; padding: 8px 10px; cursor: pointer; font-size: 18px; color: #000; }
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); transition: transform 0.25s ease; z-index: 150; }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0 !important; padding: 12px !important; }
      .hamburger { display: block; }
      .provider-grid { grid-template-columns: 1fr; }
      .kpi-grid { grid-template-columns: repeat(2, 1fr) !important; }
    }
  </style>
</head>
<body>

<%- include('./partials/sidebar', { activePage: 'providers' }) %>

<!-- Main Content -->
<div class="main">
  <div class="section-title">🔌 Provider Management</div>
  <div class="section-sub">Configure AI providers, monitor circuit breakers, and manage API balances</div>

  <!-- Tab Bar -->
  <div class="tab-bar">
    <div class="tab active" data-tab="video" onclick="switchTab('video')">🎬 Video Providers</div>
    <div class="tab" data-tab="image" onclick="switchTab('image')">🖼️ Image Providers</div>
  </div>

  <!-- Summary Cards -->
  <div class="kpi-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
    <div class="kpi-card">
      <div class="label">Total Providers</div>
      <div class="value" id="summary-total">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Active</div>
      <div class="value" style="color: var(--green);" id="summary-active">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Configured</div>
      <div class="value" style="color: var(--blue);" id="summary-configured">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Erroring</div>
      <div class="value" style="color: var(--red);" id="summary-erroring">—</div>
    </div>
  </div>

  <!-- Bulk Actions -->
  <div class="card" style="margin-bottom: 24px;">
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <span style="font-size: 13px; color: var(--muted); margin-right: 8px;">Bulk Actions:</span>
      <button class="btn btn-ghost btn-sm" onclick="refreshAllBalances()">🔄 Refresh Balances</button>
      <button class="btn btn-danger btn-sm" onclick="resetAllCB()">⚠️ Reset All Circuit Breakers</button>
      <button class="btn btn-gold btn-sm" style="margin-left: auto;" onclick="loadProviders()">🔃 Reload</button>
    </div>
  </div>

  <!-- Provider Grid -->
  <div id="provider-grid" class="provider-grid">
    <div class="loading">Loading providers...</div>
  </div>
</div>

<!-- Models Modal -->
<div class="modal-overlay" id="modal-models">
  <div class="modal" style="max-width: 700px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h3 style="margin:0;" id="modal-models-title">Available Models</h3>
      <button class="btn btn-ghost btn-sm" onclick="closeModal('modal-models')">✕</button>
    </div>
    <div id="modal-models-content"><div class="loading">Loading...</div></div>
  </div>
</div>

<!-- Toast Container -->
<div id="toast-container"></div>

<script>
// ===================== AUTH =====================
const getToken = () => localStorage.getItem('admin_password') || new URLSearchParams(location.search).get('token') || '';

function logout() {
  localStorage.removeItem('admin_password');
  document.cookie = 'admin_token=; Max-Age=0; Path=/;';
  location.href = '/admin/login';
}

// ===================== API =====================
async function api(path, opts = {}) {
  const token = getToken();
  const headers = {
    'Authorization': 'Basic ' + btoa(':' + token),
    ...(opts.headers || {}),
  };
  if (opts.body && typeof opts.body !== 'string' && !(opts.body instanceof FormData)) {
    headers['Content-Type'] = 'application/json';
    opts.body = JSON.stringify(opts.body);
  }
  try {
    const res = await fetch(path, { ...opts, headers, credentials: 'include' });
    if (res.status === 401) { location.href = '/admin/login'; return null; }
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = text; }
    if (!res.ok) throw new Error(typeof data === 'string' ? data : (data?.error || 'Request failed'));
    return data;
  } catch (e) {
    throw e;
  }
}

// ===================== TOAST =====================
function toast(msg, type = 'info') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}

// ===================== HELPERS =====================
function esc(s) {
  if (s == null) return '';
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

function reltime(s) {
  if (!s) return '—';
  const diff = Date.now() - new Date(s).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return m + 'm ago';
  const h = Math.floor(m / 60);
  if (h < 24) return h + 'h ago';
  return Math.floor(h / 24) + 'd ago';
}

function dt(s) {
  if (!s) return '—';
  return new Date(s).toLocaleString('id-ID', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
}

// ===================== CLOCK =====================
function updateClock() {
  document.getElementById('live-clock').textContent = new Date().toLocaleString('id-ID', { weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit' });
}
setInterval(updateClock, 1000);
updateClock();

// ===================== SIDEBAR =====================
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

// ===================== STATE =====================
let currentTab = 'video';
let providersData = { video: [], image: [] };
let balancesData = {};
let expandedCards = new Set();

// ===================== TAB SWITCHING =====================
function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[data-tab="${tab}"]`).classList.add('active');
  renderCards();
  updateSummary();
}

// ===================== LOAD PROVIDERS =====================
async function loadProviders() {
  const grid = document.getElementById('provider-grid');
  grid.innerHTML = '<div class="loading">Loading providers...</div>';
  
  try {
    const data = await api('/api/admin/providers/all');
    if (!data) return;
    
    providersData = data;
    renderCards();
    updateSummary();
    
    // Load balances after providers
    loadBalances();
  } catch (e) {
    grid.innerHTML = `<div class="empty-state">Failed to load providers: ${esc(e.message)}</div>`;
    toast('Failed to load providers: ' + e.message, 'error');
  }
}

// ===================== LOAD BALANCES =====================
async function loadBalances() {
  try {
    const data = await api('/api/admin/providers/balances');
    if (!data || !data.balances) return;
    
    balancesData = {};
    data.balances.forEach(b => {
      balancesData[b.key] = b.balance;
    });
    
    // Update balance displays
    Object.entries(balancesData).forEach(([key, balance]) => {
      const el = document.getElementById(`balance-${key}`);
      if (el) {
        el.innerHTML = balance !== null && balance !== undefined
          ? `<span style="color: var(--green);">${esc(String(balance))}</span>`
          : `<span style="color: var(--muted);">N/A</span>`;
      }
    });
  } catch (e) {
    console.error('Failed to load balances:', e);
  }
}

// ===================== UPDATE SUMMARY =====================
function updateSummary() {
  const providers = providersData[currentTab] || [];
  const total = providers.length;
  const active = providers.filter(p => p.enabled !== false).length;
  const configured = providers.filter(p => p.hasApiKey).length;
  const erroring = providers.filter(p => p.circuitBreaker?.state === 'open').length;
  
  document.getElementById('summary-total').textContent = total;
  document.getElementById('summary-active').textContent = active;
  document.getElementById('summary-configured').textContent = configured;
  document.getElementById('summary-erroring').textContent = erroring;
}

// ===================== RENDER CARDS =====================
function renderCards() {
  const grid = document.getElementById('provider-grid');
  const providers = providersData[currentTab] || [];
  
  if (!providers.length) {
    grid.innerHTML = `<div class="empty-state">No ${currentTab} providers configured</div>`;
    return;
  }
  
  grid.innerHTML = providers.map(p => renderProviderCard(p)).join('');
}

function renderProviderCard(p) {
  const key = p.key || p.name;
  const type = currentTab;
  const isExpanded = expandedCards.has(key);
  const hasError = p.circuitBreaker?.state === 'open';
  
  // API Key status
  const apiKeyStatus = p.hasApiKey
    ? '<span class="status-dot green" title="API key configured"></span>'
    : '<span class="status-dot red" title="API key missing"></span>';
  
  // Circuit breaker status
  let cbBadge = 'badge-closed';
  let cbDot = 'green';
  let cbLabel = 'Closed';
  if (p.circuitBreaker?.state === 'open') {
    cbBadge = 'badge-open';
    cbDot = 'red';
    cbLabel = 'Open';
  } else if (p.circuitBreaker?.state === 'half_open') {
    cbBadge = 'badge-half';
    cbDot = 'yellow';
    cbLabel = 'Half-Open';
  }
  
  const balanceDisplay = balancesData[key] !== undefined
    ? `<span style="color: var(--green);">${esc(String(balancesData[key]))}</span>`
    : `<span id="balance-${key}"><span class="spinner"></span></span>`;
  
  return `
    <div class="provider-card ${hasError ? 'erroring' : ''}" data-key="${esc(key)}">
      <div class="provider-header" onclick="toggleCard('${esc(key)}')">
        <div class="provider-row">
          <div style="flex: 1;">
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
              <span style="font-size: 15px; font-weight: 600;">${esc(p.name || key)}</span>
              <span class="badge badge-${type}">${type}</span>
              ${hasError ? '<span class="badge badge-open">⚠️ Erroring</span>' : ''}
            </div>
            <div style="display: flex; align-items: center; gap: 16px; font-size: 12px; color: var(--muted);">
              <span style="display: flex; align-items: center; gap: 4px;" title="API Key Status">
                ${apiKeyStatus} Key
              </span>
              <span style="display: flex; align-items: center; gap: 4px;" title="Circuit Breaker">
                <span class="status-dot ${cbDot}"></span>
                <span class="badge ${cbBadge}">${cbLabel}</span>
              </span>
              <span title="Balance">💰 ${balanceDisplay}</span>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 8px;">
            <div style="display: flex; align-items: center; gap: 4px;">
              <input type="number" class="input input-sm" id="prio-${esc(key)}" value="${p.priority ?? 99}" min="1" max="999" onclick="event.stopPropagation()" onchange="markChanged('${esc(key)}')">
            </div>
            <div class="toggle ${p.enabled !== false ? 'on' : ''}" id="toggle-${esc(key)}" onclick="event.stopPropagation(); toggleProvider('${esc(key)}')" title="Enable/Disable"></div>
          </div>
        </div>
      </div>
      
      <div class="provider-details ${isExpanded ? 'open' : ''}" id="details-${esc(key)}">
        <div style="padding-top: 16px;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Timeout</div>
              <div style="font-size: 13px;">${p.timeout ? p.timeout + 'ms' : '—'}</div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Failures</div>
              <div style="font-size: 13px;">${p.circuitBreaker?.failureCount ?? 0}</div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Last Success</div>
              <div style="font-size: 12px;">${reltime(p.circuitBreaker?.lastSuccess)}</div>
            </div>
            <div>
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px;">Last Failure</div>
              <div style="font-size: 12px;">${reltime(p.circuitBreaker?.lastFailure)}</div>
            </div>
          </div>
          
          ${p.strengths?.length ? `
            <div style="margin-bottom: 12px;">
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 6px;">Strengths</div>
              <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                ${(Array.isArray(p.strengths) ? p.strengths : [p.strengths]).filter(Boolean).map(s => `<span style="background: rgba(74,222,128,0.1); color: var(--green); padding: 2px 8px; border-radius: 4px; font-size: 11px;">${esc(s)}</span>`).join('')}
              </div>
            </div>
          ` : ''}
          
          ${p.quirks?.length ? `
            <div style="margin-bottom: 16px;">
              <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; margin-bottom: 6px;">Quirks / Notes</div>
              <div style="font-size: 12px; color: var(--yellow); line-height: 1.5;">
                ${Array.isArray(p.quirks) ? p.quirks.map(q => `• ${esc(q)}`).join('<br>') : `• ${esc(p.quirks)}`}
              </div>
            </div>
          ` : ''}
          
          <div style="display: flex; gap: 8px; flex-wrap: wrap; border-top: 1px solid var(--border); padding-top: 16px;">
            <button class="btn btn-ghost btn-xs" onclick="testProvider('${esc(key)}')">🧪 Test</button>
            <button class="btn btn-ghost btn-xs" onclick="resetCB('${esc(key)}')">🔄 Reset CB</button>
            <button class="btn btn-ghost btn-xs" onclick="showModels('${esc(key)}')">📋 Models</button>
          </div>
        </div>
      </div>
    </div>
  `;
}

// ===================== CARD INTERACTIONS =====================
function toggleCard(key) {
  if (expandedCards.has(key)) {
    expandedCards.delete(key);
  } else {
    expandedCards.add(key);
  }
  const details = document.getElementById(`details-${key}`);
  if (details) {
    details.classList.toggle('open', expandedCards.has(key));
  }
}

function toggleProvider(key) {
  const toggle = document.getElementById(`toggle-${key}`);
  const isOn = toggle.classList.toggle('on');
  markChanged(key);
}

function markChanged(key) {
  // Visual indicator for unsaved changes
  const card = document.querySelector(`.provider-card[data-key="${key}"]`);
  if (card) {
    card.style.borderColor = 'var(--gold-dim)';
  }
}

// ===================== BULK ACTIONS =====================
async function refreshAllBalances() {
  toast('Refreshing all balances...', 'info');
  await loadBalances();
  toast('Balances refreshed', 'success');
}

async function resetAllCB() {
  if (!confirm('Reset all circuit breakers? This will allow requests to all providers again.')) return;
  
  try {
    await api('/api/admin/providers/reset-all-cb', { method: 'POST' });
    toast('All circuit breakers reset', 'success');
    loadProviders();
  } catch (e) {
    toast('Failed: ' + e.message, 'error');
  }
}

// ===================== PROVIDER ACTIONS =====================
async function saveProviders() {
  const providers = providersData[currentTab] || [];
  const settings = {};
  
  providers.forEach(p => {
    const key = p.key || p.name;
    const prioEl = document.getElementById(`prio-${key}`);
    const toggleEl = document.getElementById(`toggle-${key}`);
    
    if (prioEl && toggleEl) {
      settings[key] = {
        priority: parseInt(prioEl.value) || 99,
        enabled: toggleEl.classList.contains('on')
      };
    }
  });
  
  try {
    await api('/api/admin/providers/settings', {
      method: 'POST',
      body: { type: currentTab, settings }
    });
    toast('Provider settings saved', 'success');
    
    // Clear visual indicators
    document.querySelectorAll('.provider-card').forEach(card => {
      card.style.borderColor = '';
    });
    
    loadProviders();
  } catch (e) {
    toast('Failed to save: ' + e.message, 'error');
  }
}

async function resetCB(key) {
  try {
    await api(`/api/admin/providers/${encodeURIComponent(key)}/reset-cb`, { method: 'POST' });
    toast(`Circuit breaker reset for ${key}`, 'success');
    loadProviders();
  } catch (e) {
    toast('Failed: ' + e.message, 'error');
  }
}

async function testProvider(key) {
  toast(`Testing ${key}...`, 'info');
  
  try {
    const result = await api(`/api/admin/providers/${encodeURIComponent(key)}/test`, { method: 'POST' });
    
    if (result?.success) {
      toast(`✅ ${key} test passed`, 'success');
    } else {
      toast(`❌ ${key} test failed: ${result?.error || 'Unknown error'}`, 'error');
    }
  } catch (e) {
    toast(`❌ Test failed: ${e.message}`, 'error');
  }
}

async function showModels(key) {
  const modal = document.getElementById('modal-models');
  const content = document.getElementById('modal-models-content');
  const title = document.getElementById('modal-models-title');
  
  title.textContent = `Models — ${key}`;
  content.innerHTML = '<div class="loading">Loading models...</div>';
  modal.classList.add('open');
  
  try {
    const provider = [...providersData.video, ...providersData.image].find(p => (p.key || p.name) === key);
    const models = provider?.models || [];
    
    if (!models.length) {
      content.innerHTML = '<div class="empty-state">No models configured for this provider</div>';
      return;
    }
    
    content.innerHTML = `
      <table style="width: 100%; font-size: 13px;">
        <thead>
          <tr>
            <th style="text-align: left; padding: 8px; color: var(--muted); border-bottom: 1px solid var(--border);">Model ID</th>
            <th style="text-align: left; padding: 8px; color: var(--muted); border-bottom: 1px solid var(--border);">Type</th>
          </tr>
        </thead>
        <tbody>
          ${models.map(m => `
            <tr>
              <td style="padding: 8px; font-family: monospace; font-size: 12px;">${esc(typeof m === 'string' ? m : m.id || m.name)}</td>
              <td style="padding: 8px;"><span class="badge badge-${currentTab}">${currentTab}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  } catch (e) {
    content.innerHTML = `<div class="empty-state">Failed to load models: ${esc(e.message)}</div>`;
  }
}

// ===================== MODAL HELPERS =====================
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-overlay.open').forEach(m => m.classList.remove('open'));
  }
});

// ===================== SAVE BUTTON (add to page) =====================
document.addEventListener('DOMContentLoaded', () => {
  // Add floating save button
  const saveBtn = document.createElement('button');
  saveBtn.className = 'btn btn-gold';
  saveBtn.style.cssText = 'position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 50; box-shadow: 0 4px 20px rgba(196,163,90,0.3);';
  saveBtn.innerHTML = '💾 Save Changes';
  saveBtn.onclick = saveProviders;
  document.body.appendChild(saveBtn);
});

// ===================== INIT =====================
const urlToken = new URLSearchParams(location.search).get('token');
if (urlToken) {
  localStorage.setItem('admin_password', urlToken);
}

loadProviders();

// Auto-refresh every 60s
setInterval(() => {
  loadBalances();
  updateSummary();
}, 60000);
</script>
</body>
</html>