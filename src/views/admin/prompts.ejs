<%
const niches = ['fnb','fashion','tech','health','travel','education','finance','entertainment'];
const nicheEmoji = { fnb:'🍔', fashion:'👗', tech:'📱', health:'💪', travel:'✈️', education:'📚', finance:'💰', entertainment:'🎭' };
%>
<style>
  .prompt-text { font-family: monospace; font-size: 12px; color: #a5b4fc; max-width: 400px; word-break: break-word; }
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; padding: 10px 12px; color: var(--muted); font-size: 12px; text-transform: uppercase; border-bottom: 1px solid var(--border); }
  td { padding: 10px 12px; border-bottom: 1px solid var(--border); font-size: 14px; vertical-align: top; }
  tr:hover td { background: rgba(255,255,255,0.02); }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .form-full { grid-column: 1 / -1; }
</style>

<div class="section-title">✍️ Prompt Management</div>
<div class="section-sub">Admin prompts are global and immediately available to all users in the bot and web app.</div>

<!-- Stats -->
<div class="stats-row">
  <div class="kpi-card"><div class="value" id="stat-total">—</div><div class="label">Total Prompts</div></div>
  <div class="kpi-card"><div class="value">8</div><div class="label">Niche Categories</div></div>
  <div class="kpi-card"><div class="value" id="stat-custom">—</div><div class="label">User Prompts</div></div>
  <div class="kpi-card"><div class="value" id="stat-admin">—</div><div class="label">Admin Prompts</div></div>
</div>

<!-- Niche Tabs + Add Button -->
<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
  <div class="tab-bar" style="margin-bottom: 0; flex-wrap: wrap; gap: 4px; border: none;">
    <div class="tab active" data-niche="all" onclick="filterNiche('all', this)">🌐 All</div>
    <% niches.forEach(function(n) { %>
      <div class="tab" data-niche="<%= n %>" onclick="filterNiche('<%= n %>', this)"><%= nicheEmoji[n] %> <%= n.charAt(0).toUpperCase() + n.slice(1) %></div>
    <% }); %>
  </div>
  <button class="btn btn-gold" onclick="showAddForm()">➕ Add Prompt</button>
</div>

<!-- Add Form -->
<div class="card" id="add-form" style="display: none; border-color: var(--gold-dim); margin-bottom: 20px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
    <span style="font-weight: 700;">➕ New Admin Prompt</span>
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('add-form').style.display='none'">✕</button>
  </div>
  <div class="form-grid">
    <div>
      <label style="font-size:12px; color:var(--muted); display:block; margin-bottom:4px;">Niche *</label>
      <select id="new-niche" class="input">
        <% niches.forEach(function(n) { %>
          <option value="<%= n %>"><%= nicheEmoji[n] %> <%= n.charAt(0).toUpperCase() + n.slice(1) %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label style="font-size:12px; color:var(--muted); display:block; margin-bottom:4px;">Title *</label>
      <input type="text" id="new-title" class="input" placeholder="e.g. Dramatic Food Close-up" style="width:100%;">
    </div>
    <div class="form-full">
      <label style="font-size:12px; color:var(--muted); display:block; margin-bottom:4px;">Prompt Text *</label>
      <textarea id="new-prompt" class="input" style="height:100px; width:100%; resize:vertical;" placeholder="Cinematic food shot with steam rising effect, slow zoom in..."></textarea>
    </div>
  </div>
  <button class="btn btn-gold" onclick="addPrompt()">💾 Save to Bot</button>
</div>

<!-- Prompts Table -->
<div class="card" style="padding: 0; overflow: hidden;">
  <div style="padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
    <span style="font-weight: 700;">Admin Prompts (active in bot & webapp)</span>
    <span id="prompt-count" style="font-size: 12px; color: var(--muted);"></span>
  </div>
  <table>
    <thead>
      <tr>
        <th>Niche</th>
        <th>Title</th>
        <th>Prompt</th>
        <th>Used</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="prompts-tbody">
      <tr><td colspan="5" style="text-align:center; padding:40px; color:var(--muted);">Loading...</td></tr>
    </tbody>
  </table>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <h3>✏️ Edit Prompt</h3>
    <input type="hidden" id="edit-id">
    <div class="form-group">
      <label>Niche</label>
      <select id="edit-niche" class="input" style="width:100%;">
        <% niches.forEach(function(n) { %>
          <option value="<%= n %>"><%= nicheEmoji[n] %> <%= n.charAt(0).toUpperCase() + n.slice(1) %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Title</label>
      <input type="text" id="edit-title" class="input" style="width:100%;">
    </div>
    <div class="form-group">
      <label>Prompt Text</label>
      <textarea id="edit-prompt" class="input" style="height:140px; width:100%; resize:vertical;"></textarea>
    </div>
    <div style="display:flex; gap:8px; margin-top:8px;">
      <button class="btn btn-gold" onclick="saveEdit()">💾 Save</button>
      <button class="btn btn-ghost" onclick="document.getElementById('edit-modal').classList.remove('open')">Cancel</button>
    </div>
  </div>
</div>

<!-- Toast Container -->
<div id="toast-container"></div>

<script>
let allPrompts = [];
let currentNiche = 'all';
const NICHE_EMOJI = <%- JSON.stringify(nicheEmoji) %>;

function toast(msg, type = 'success') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}

function esc(s) {
  const d = document.createElement('div');
  d.textContent = String(s == null ? '' : s);
  return d.innerHTML;
}

async function loadPrompts() {
  const url = currentNiche === 'all' ? '/api/admin-prompts' : '/api/admin-prompts?niche=' + currentNiche;
  try {
    const r = await fetch(url, { credentials: 'include' });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    allPrompts = await r.json();
    renderTable(allPrompts);
    document.getElementById('prompt-count').textContent = allPrompts.length + ' prompts';
    document.getElementById('stat-total').textContent = allPrompts.length;
    document.getElementById('stat-admin').textContent = allPrompts.length;
  } catch (e) {
    document.getElementById('prompts-tbody').innerHTML = `<tr><td colspan="5" style="text-align:center;padding:40px;color:var(--red);">Failed to load: ${esc(e.message)}</td></tr>`;
  }
}

function renderTable(prompts) {
  const tbody = document.getElementById('prompts-tbody');
  if (!prompts.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:40px;color:var(--muted);">No prompts for this niche. Click "+ Add Prompt" to create one.</td></tr>';
    return;
  }
  tbody.innerHTML = prompts.map(p => `
    <tr>
      <td><span class="badge badge-image">${esc(NICHE_EMOJI[p.niche] || '')} ${esc(p.niche)}</span></td>
      <td style="font-weight:600;">${esc(p.title)}</td>
      <td><div class="prompt-text">${esc(p.prompt.slice(0, 120))}${p.prompt.length > 120 ? '…' : ''}</div></td>
      <td style="color:var(--muted);">${p.successRate ?? 0}x</td>
      <td>
        <div style="display:flex;gap:6px;">
          <button class="btn btn-ghost btn-xs" onclick="openEdit(${p.id})">✏️ Edit</button>
          <button class="btn btn-danger btn-xs" onclick="deletePrompt(${p.id}, '${esc(p.title).replace(/'/g, "\\'")}')">🗑️</button>
        </div>
      </td>
    </tr>
  `).join('');
}

function filterNiche(niche, el) {
  currentNiche = niche;
  document.querySelectorAll('.tab[data-niche]').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  loadPrompts();
}

function showAddForm() {
  const f = document.getElementById('add-form');
  f.style.display = 'block';
  f.scrollIntoView({ behavior: 'smooth' });
}

async function addPrompt() {
  const niche = document.getElementById('new-niche').value;
  const title = document.getElementById('new-title').value.trim();
  const prompt = document.getElementById('new-prompt').value.trim();
  if (!title || !prompt) { toast('Title and prompt are required', 'error'); return; }
  try {
    const r = await fetch('/api/admin-prompts', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ niche, title, prompt }),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    toast('Prompt "' + title + '" saved to bot');
    document.getElementById('new-title').value = '';
    document.getElementById('new-prompt').value = '';
    document.getElementById('add-form').style.display = 'none';
    loadPrompts();
  } catch (e) {
    toast('Failed to save: ' + e.message, 'error');
  }
}

function openEdit(id) {
  const p = allPrompts.find(x => x.id === id);
  if (!p) return;
  document.getElementById('edit-id').value = id;
  document.getElementById('edit-niche').value = p.niche;
  document.getElementById('edit-title').value = p.title;
  document.getElementById('edit-prompt').value = p.prompt;
  document.getElementById('edit-modal').classList.add('open');
}

async function saveEdit() {
  const id = document.getElementById('edit-id').value;
  const niche = document.getElementById('edit-niche').value;
  const title = document.getElementById('edit-title').value.trim();
  const prompt = document.getElementById('edit-prompt').value.trim();
  if (!title || !prompt) { toast('Title and prompt are required', 'error'); return; }
  try {
    const r = await fetch('/api/admin-prompts/' + id, {
      method: 'PUT',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ niche, title, prompt }),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    toast('Prompt updated');
    document.getElementById('edit-modal').classList.remove('open');
    loadPrompts();
  } catch (e) {
    toast('Failed to update: ' + e.message, 'error');
  }
}

async function deletePrompt(id, title) {
  if (!confirm('Delete prompt "' + title + '"?')) return;
  try {
    const r = await fetch('/api/admin-prompts/' + id, {
      method: 'DELETE',
      credentials: 'include',
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    toast('Prompt deleted');
    loadPrompts();
  } catch (e) {
    toast('Failed to delete: ' + e.message, 'error');
  }
}

// Close modal on backdrop click
document.getElementById('edit-modal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

loadPrompts();
</script>
