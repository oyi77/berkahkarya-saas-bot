<!-- Toast Container -->
<div id="toast-container"></div>

<script>
// ===================== AUTH =====================
const getToken = () => localStorage.getItem('admin_password') || new URLSearchParams(location.search).get('token') || '';

function logout() {
  localStorage.removeItem('admin_password');
  document.cookie = 'admin_token=; Max-Age=0; Path=/;';
  location.href = '/admin/login';
}

// ===================== API =====================
async function api(path, opts = {}) {
  const token = getToken();
  const isFormData = opts.body instanceof FormData;
  const headers = {
    'Authorization': 'Basic ' + btoa(':' + token),
    ...(opts.headers || {}),
  };
  if (!isFormData && opts.body && typeof opts.body !== 'string') {
    headers['Content-Type'] = 'application/json';
    opts.body = JSON.stringify(opts.body);
  }
  try {
    const res = await fetch(path, { ...opts, headers, credentials: 'include' });
    if (res.status === 401) { location.href = '/admin/login'; return null; }
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch { data = text; }
    if (!res.ok) throw new Error(typeof data === 'string' ? data : (data?.error || 'Request failed'));
    return data;
  } catch (e) {
    throw e;
  }
}

// ===================== TOAST =====================
function toast(msg, type = 'info') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

// ===================== HELPERS =====================
const rp = n => 'Rp ' + Math.round(Number(n)).toLocaleString('id-ID');
const dt = s => s ? new Date(s).toLocaleString('id-ID', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
function reltime(s) {
  if (!s) return '—';
  const diff = Date.now() - new Date(s).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return m + 'm ago';
  const h = Math.floor(m / 60);
  if (h < 24) return h + 'h ago';
  return Math.floor(h / 24) + 'd ago';
}
function tierBadge(tier) {
  const map = { free: 'badge-free', basic: 'badge-starter', lite: 'badge-starter', pro: 'badge-pro', agency: 'badge-enterprise' };
  return `<span class="badge ${map[tier] || 'badge-free'}">${tier}</span>`;
}
function statusBadge(status) {
  const s = (status || '').toLowerCase();
  return `<span class="badge badge-${s}">${status}</span>`;
}
function userName(u) {
  if (!u) return '—';
  return u.firstName || u.username || u.telegramId?.toString() || '—';
}
function esc(s) {
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

// ===================== NAVIGATION =====================
let currentSection = 'overview';
document.querySelectorAll('.nav-item').forEach(el => {
  el.addEventListener('click', () => {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    const sec = el.dataset.section;
    document.getElementById('section-' + sec).classList.add('active');
    currentSection = sec;
    console.log('[nav] switching to section:', sec);
    try { loadSection(sec); } catch(e) { console.error('[nav] loadSection error:', e); }
  });
});

function loadSection(sec) {
  if (sec === 'overview') loadOverview();
  else if (sec === 'users') loadUsers(true);
  else if (sec === 'transactions') loadTransactions();
  else if (sec === 'videos') loadVideos();
  else if (sec === 'analytics') loadAnalytics();
  else if (sec === 'pricing') { loadGateways(); loadPricingTable('package'); }
  else if (sec === 'prompts') loadPrompts();
  else if (sec === 'system') loadSystem();
  else if (sec === 'tokens') loadTokenStats();
  else if (sec === 'profit') loadProfitReport();
  else if (sec === 'settings') loadSettings();
  else if (sec === 'niches') loadNiches();
  // ai-assistant section is static, no load needed
}

// ===================== CLOCK =====================
function updateClock() {
  document.getElementById('live-clock').textContent = new Date().toLocaleString('id-ID', { weekday:'short', day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit', second:'2-digit' });
}
setInterval(updateClock, 1000);
updateClock();

// ===================== OVERVIEW =====================
let chartRevenue, chartNewUsers, chartTiers, chartVStatus;

Chart.defaults.color = '#888899';
Chart.defaults.borderColor = '#22223a';

async function loadOverview() {
  try {
    const d = await api('/api/stats/overview');
    if (!d) return;

    document.getElementById('ov-users').textContent = d.users.total.toLocaleString();
    const tierList = Object.entries(d.users.byTier).map(([k,v]) => `${k}: ${v}`).join(', ');
    document.getElementById('ov-users-sub').textContent = tierList || 'no breakdown';

    document.getElementById('ov-revenue').textContent = rp(d.revenue.total);
    document.getElementById('ov-revenue-today').textContent = 'Today: ' + rp(d.revenue.today);

    document.getElementById('ov-videos').textContent = d.videos.total.toLocaleString();
    const statusList = Object.entries(d.videos.byStatus).map(([k,v]) => `${k}: ${v}`).join(', ');
    document.getElementById('ov-videos-sub').textContent = statusList || 'no breakdown';

    document.getElementById('ov-queue').textContent = d.queue?.video?.waiting ?? '—';
    document.getElementById('ov-queue-sub').textContent = `active: ${d.queue?.video?.active ?? 0}`;

    // Revenue chart
    const revLabels = d.charts.revenue.map(x => x.date);
    const revData = d.charts.revenue.map(x => x.revenue);
    if (chartRevenue) chartRevenue.destroy();
    chartRevenue = new Chart(document.getElementById('chart-revenue'), {
      type: 'line',
      data: { labels: revLabels, datasets: [{ label: 'Revenue', data: revData, borderColor: '#c4a35a', backgroundColor: 'rgba(196,163,90,0.08)', tension: 0.4, fill: true, pointRadius: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { ticks: { callback: v => 'Rp' + (v/1000).toFixed(0)+'K' } } } }
    });

    // New users chart
    const uLabels = d.charts.newUsers.map(x => x.date);
    const uData = d.charts.newUsers.map(x => x.count);
    if (chartNewUsers) chartNewUsers.destroy();
    chartNewUsers = new Chart(document.getElementById('chart-newusers'), {
      type: 'line',
      data: { labels: uLabels, datasets: [{ label: 'New Users', data: uData, borderColor: '#60a5fa', backgroundColor: 'rgba(96,165,250,0.08)', tension: 0.4, fill: true, pointRadius: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { ticks: { stepSize: 1 } } } }
    });

    // Tiers donut
    const tierColors = { free: '#555568', basic: '#1a4a8a', lite: '#2a5a9a', pro: '#4a1a8a', agency: '#8a6030' };
    const tierLabels = Object.keys(d.users.byTier);
    const tierData = Object.values(d.users.byTier);
    if (chartTiers) chartTiers.destroy();
    chartTiers = new Chart(document.getElementById('chart-tiers'), {
      type: 'doughnut',
      data: { labels: tierLabels, datasets: [{ data: tierData, backgroundColor: tierLabels.map(l => tierColors[l] || '#444'), borderWidth: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 8 } } } }
    });

    // Video status donut
    const vsColors = { completed: '#0f5030', pending: '#5a3a08', processing: '#0f3050', failed: '#5a1010' };
    const vsLabels = Object.keys(d.videos.byStatus);
    const vsData = Object.values(d.videos.byStatus);
    if (chartVStatus) chartVStatus.destroy();
    chartVStatus = new Chart(document.getElementById('chart-vstatus'), {
      type: 'doughnut',
      data: { labels: vsLabels, datasets: [{ data: vsData, backgroundColor: vsLabels.map(l => vsColors[l] || '#444'), borderWidth: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 8 } } } }
    });
  } catch(e) { toast('Failed to load overview: ' + e.message, 'error'); }
}

// ===================== USERS =====================
let userOffset = 0;
let currentUsers = [];
let userSearchTimer;
let currentBanUserId, currentBanIsBanned, currentCreditsUserId, currentTierUserId;

function debounceUserSearch() {
  clearTimeout(userSearchTimer);
  userSearchTimer = setTimeout(() => loadUsers(true), 400);
}

async function loadUsers(reset = false) {
  if (reset) { userOffset = 0; currentUsers = []; }
  const search = document.getElementById('user-search').value.trim();
  const filter = document.getElementById('user-filter').value;
  const wrap = document.getElementById('users-table-wrap');
  if (reset) wrap.innerHTML = '<div class="loading">Loading...</div>';

  try {
    let users;
    if (search) {
      users = await api('/api/users/search?q=' + encodeURIComponent(search) + '&limit=50');
    } else {
      const params = new URLSearchParams({ limit: '30', offset: String(userOffset) });
      if (filter === 'active') params.set('isBanned', 'false');
      else if (filter === 'banned') params.set('isBanned', 'true');
      else if (['free','basic','lite','pro','agency'].includes(filter)) params.set('tier', filter);
      users = await api('/api/users?' + params);
    }
    if (!users) return;

    if (reset) currentUsers = users;
    else currentUsers = [...currentUsers, ...users];

    renderUsersTable(currentUsers);
    document.getElementById('users-load-more').style.display = (users.length === 30 && !search) ? 'inline-flex' : 'none';
    userOffset += users.length;
  } catch(e) { toast('Failed to load users: ' + e.message, 'error'); }
}

// ===================== REAL-TIME SSE ENGINE =====================
const sse = new EventSource('/api/admin/sse');
sse.onmessage = (event) => {
  try {
    const data = JSON.parse(event.data);
    if (data.type === 'NEW_USER') {
      const uCount = document.getElementById('ov-users');
      if(uCount && uCount.textContent !== '—') uCount.textContent = (parseInt(uCount.textContent.replace(/,/g, '')) + 1).toLocaleString();
      toast('👤 New User Registered: @' + data.username, 'info');
    }
    if (data.type === 'VIDEO_SUCCESS') {
      const vCount = document.getElementById('ov-videos');
      if(vCount && vCount.textContent !== '—') vCount.textContent = (parseInt(vCount.textContent.replace(/,/g, '')) + 1).toLocaleString();
      toast('🎬 Video Generation Completed', 'success');
    }
  } catch(e) {}
};


function renderUsersTable(users) {
  const wrap = document.getElementById('users-table-wrap');
  if (!users.length) { wrap.innerHTML = '<div class="empty-state">No users found</div>'; return; }
  wrap.innerHTML = `<table>
    <thead><tr>
      <th>Telegram ID</th><th>Name</th><th>Username</th><th>Tier</th>
      <th>Credits</th><th>Status</th><th>Last Active</th><th>Actions</th>
    </tr></thead>
    <tbody>${users.map(u => `<tr>
      <td style="font-family:monospace;font-size:12px;">${u.telegramId}</td>
      <td>${esc(u.firstName || '—')}</td>
      <td style="color:var(--muted);">@${esc(u.username || '—')}</td>
      <td>${tierBadge(u.tier)}</td>
      <td>${Number(u.creditBalance).toFixed(1)}</td>
      <td>${u.isBanned ? '<span class="badge badge-banned">Banned</span>' : '<span class="badge badge-active">Active</span>'}</td>
      <td style="font-size:12px;color:var(--muted);">${reltime(u.lastActivityAt)}</td>
      <td>
        <div style="display:flex;gap:4px;">
          <button class="btn btn-ghost btn-sm" onclick="viewUser('${u.telegramId}')" title="View">👁</button>
          <button class="btn btn-ghost btn-sm" onclick="openCreditsModal('${u.telegramId}','${esc(u.firstName||u.username||'User')}')" title="Credits">💰</button>
          <button class="btn btn-ghost btn-sm" onclick="openTierModal('${u.telegramId}','${esc(u.firstName||u.username||'User')}','${u.tier}')" title="Tier">🏷</button>
          <button class="btn btn-ghost btn-sm" onclick="openBanModal('${u.telegramId}','${esc(u.firstName||u.username||'User')}',${u.isBanned})" title="${u.isBanned?'Unban':'Ban'}">🚫</button>
        </div>
      </td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function loadMoreUsers() { loadUsers(false); }

async function viewUser(id) {
  openModal('modal-user');
  document.getElementById('modal-user-content').innerHTML = '<div class="loading">Loading user detail...</div>';
  try {
    const u = await api('/api/users/' + id);
    if (!u) return;
    document.getElementById('modal-user-content').innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;">
        <div class="kpi-card" style="padding:12px;"><div class="label">Name</div><div style="font-weight:600;margin-top:4px;">${esc(u.firstName||'—')}</div></div>
        <div class="kpi-card" style="padding:12px;"><div class="label">Username</div><div style="font-weight:600;margin-top:4px;">@${esc(u.username||'—')}</div></div>
        <div class="kpi-card" style="padding:12px;"><div class="label">Tier</div><div style="margin-top:4px;">${tierBadge(u.tier)}</div></div>
        <div class="kpi-card" style="padding:12px;"><div class="label">Credits</div><div style="font-weight:600;margin-top:4px;">${Number(u.creditBalance).toFixed(2)}</div></div>
        <div class="kpi-card" style="padding:12px;"><div class="label">Status</div><div style="margin-top:4px;">${u.isBanned ? '<span class="badge badge-banned">Banned</span>' : '<span class="badge badge-active">Active</span>'}</div></div>
        <div class="kpi-card" style="padding:12px;"><div class="label">Joined</div><div style="font-size:12px;margin-top:4px;">${dt(u.createdAt)}</div></div>
      </div>
      ${u.banReason ? `<div style="padding:10px;background:#3a0f0f;border-radius:8px;font-size:13px;color:#f87171;margin-bottom:16px;">Ban reason: ${esc(u.banReason)}</div>` : ''}
      <hr class="divider">
      <div style="font-size:13px;font-weight:600;color:var(--muted);margin-bottom:10px;">RECENT TRANSACTIONS</div>
      ${u.transactions?.length ? `<table><thead><tr><th>Amount</th><th>Status</th><th>Gateway</th><th>Date</th></tr></thead><tbody>
        ${u.transactions.map(t => `<tr><td>${rp(t.amountIdr)}</td><td>${statusBadge(t.status)}</td><td>${esc(t.gateway||'—')}</td><td style="font-size:12px;">${dt(t.createdAt)}</td></tr>`).join('')}
      </tbody></table>` : '<div class="empty-state" style="padding:16px;">No transactions</div>'}
      <hr class="divider">
      <div style="font-size:13px;font-weight:600;color:var(--muted);margin-bottom:10px;">RECENT VIDEOS</div>
      ${u.videos?.length ? `<table><thead><tr><th>Niche</th><th>Status</th><th>Provider</th><th>Date</th></tr></thead><tbody>
        ${u.videos.map(v => `<tr><td>${esc(v.niche||'—')}</td><td>${statusBadge(v.status)}</td><td style="font-size:12px;">${esc(v.provider||'—')}</td><td style="font-size:12px;">${dt(v.createdAt)}</td></tr>`).join('')}
      </tbody></table>` : '<div class="empty-state" style="padding:16px;">No videos</div>'}
    `;
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

function openCreditsModal(id, name) {
  currentCreditsUserId = id;
  document.getElementById('modal-credits-username').textContent = 'User: ' + name + ' (' + id + ')';
  document.getElementById('credits-amount').value = '';
  document.getElementById('credits-reason').value = '';
  openModal('modal-credits');
}

async function submitCredits() {
  const amount = parseFloat(document.getElementById('credits-amount').value);
  const reason = document.getElementById('credits-reason').value;
  if (!amount || amount <= 0) { toast('Enter valid amount', 'error'); return; }
  try {
    const r = await api('/api/users/' + currentCreditsUserId + '/credits', { method: 'POST', body: { amount, reason } });
    if (!r) return;
    toast('Credits granted! New balance: ' + r.newBalance, 'success');
    closeModal('modal-credits');
    loadUsers(true);
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

function openTierModal(id, name, currentTier) {
  currentTierUserId = id;
  document.getElementById('modal-tier-username').textContent = 'User: ' + name + ' (current: ' + currentTier + ')';
  document.getElementById('tier-select').value = currentTier;
  openModal('modal-tier');
}

async function submitTier() {
  const tier = document.getElementById('tier-select').value;
  try {
    const r = await api('/api/users/' + currentTierUserId + '/tier', { method: 'PATCH', body: { tier } });
    if (!r) return;
    toast('Tier changed to ' + r.tier, 'success');
    closeModal('modal-tier');
    loadUsers(true);
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

function openBanModal(id, name, isBanned) {
  currentBanUserId = id;
  currentBanIsBanned = isBanned;
  document.getElementById('modal-ban-title').textContent = isBanned ? 'Unban User' : 'Ban User';
  document.getElementById('modal-ban-username').textContent = 'User: ' + name + ' (' + id + ')';
  document.getElementById('modal-ban-reason-wrap').style.display = isBanned ? 'none' : 'block';
  document.getElementById('ban-submit-btn').textContent = isBanned ? 'Unban User' : 'Ban User';
  document.getElementById('ban-reason').value = '';
  openModal('modal-ban');
}

async function submitBan() {
  const reason = document.getElementById('ban-reason').value;
  try {
    const r = await api('/api/users/' + currentBanUserId + '/ban', { method: 'POST', body: { banned: !currentBanIsBanned, reason } });
    if (!r) return;
    toast(r.isBanned ? 'User banned' : 'User unbanned', 'success');
    closeModal('modal-ban');
    loadUsers(true);
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

// ===================== TRANSACTIONS =====================
let currentTxFilter = '';
let txOffset = 0;

function setTxFilter(el, filter) {
  document.querySelectorAll('[data-tx-filter]').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  currentTxFilter = filter;
  txOffset = 0;
  loadTransactions();
}

async function loadTransactions() {
  const wrap = document.getElementById('tx-table-wrap');
  wrap.innerHTML = '<div class="loading">Loading...</div>';
  try {
    const params = new URLSearchParams({ limit: '50', offset: String(txOffset) });
    if (currentTxFilter) params.set('status', currentTxFilter);
    const resp = await api('/api/transactions?' + params);
    if (!resp) return;
    const { transactions: txs, total, offset: currentOffset, limit } = resp;
    if (!txs.length) { wrap.innerHTML = '<div class="empty-state">No transactions found</div>'; return; }
    const currentPage = Math.floor(currentOffset / limit) + 1;
    const totalPages = Math.max(1, Math.ceil(total / limit));
    wrap.innerHTML = `<table>
      <thead><tr><th>ID</th><th>User</th><th>Amount</th><th>Credits</th><th>Status</th><th>Gateway</th><th>Date</th></tr></thead>
      <tbody>${txs.map(t => `<tr>
        <td style="font-family:monospace;font-size:11px;">${esc(t.id||'').slice(0,16)}…</td>
        <td>${esc(userName(t.user))}</td>
        <td style="font-weight:600;">${rp(t.amountIdr)}</td>
        <td>${Number(t.creditsAmount||0).toFixed(1)}</td>
        <td>${statusBadge(t.status)}</td>
        <td style="font-size:12px;color:var(--muted);">${esc(t.gateway||'—')}</td>
        <td style="font-size:12px;color:var(--muted);">${dt(t.createdAt)}</td>
      </tr>`).join('')}</tbody>
    </table>
    <div style="display:flex;align-items:center;gap:12px;margin-top:12px;justify-content:flex-end;">
      <button class="btn btn-ghost btn-sm" onclick="txPrev()" ${txOffset === 0 ? 'disabled' : ''}>← Prev</button>
      <span style="font-size:13px;color:var(--muted);">Page ${currentPage} of ${totalPages}</span>
      <button class="btn btn-ghost btn-sm" onclick="txNext()" ${currentOffset + limit >= total ? 'disabled' : ''}>Next →</button>
    </div>`;
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

function txPrev() { txOffset = Math.max(0, txOffset - 50); loadTransactions(); }
function txNext() { txOffset += 50; loadTransactions(); }

