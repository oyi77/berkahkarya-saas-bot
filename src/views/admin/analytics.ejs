// ===================== ANALYTICS =====================
async function loadAnalytics() {
  try {
    const d = await api('/api/analytics');
    if (!d) return;
    document.getElementById('an-gen').textContent = d.today?.generations ?? '—';
    document.getElementById('an-rate').textContent = (d.today?.successRate ?? '—') + '%';
    document.getElementById('an-rev').textContent = rp(d.today?.revenue ?? 0);
    document.getElementById('an-active').textContent = d.activeUsers24h ?? '—';

    // Providers
    const ph = d.providerHealth || {};
    const providers = Object.entries(ph);
    document.getElementById('an-providers').innerHTML = providers.length ? providers.map(([name, state]) => {
      const s = state?.state || 'unknown';
      const badgeClass = s === 'closed' ? 'badge-closed' : s === 'open' ? 'badge-open' : s === 'half_open' ? 'badge-half' : 'badge-unknown';
      const label = s === 'half_open' ? 'Half Open' : s.charAt(0).toUpperCase() + s.slice(1);
      return `<div class="provider-card">
        <div style="font-size:11px;font-weight:600;margin-bottom:6px;color:var(--text);">${esc(name)}</div>
        <span class="badge ${badgeClass}">${label}</span>
        ${state?.failureCount ? `<div style="font-size:11px;color:var(--muted);margin-top:4px;">Fails: ${state.failureCount}</div>` : ''}
      </div>`;
    }).join('') : '<div class="empty-state">No provider data</div>';

    // Queue
    const q = d.queue || {};
    const qv = q.video || {};
    document.getElementById('an-queue').innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div class="provider-card"><div style="font-size:11px;color:var(--muted);">Waiting</div><div style="font-size:20px;font-weight:700;">${qv.waiting||0}</div></div>
        <div class="provider-card"><div style="font-size:11px;color:var(--muted);">Active</div><div style="font-size:20px;font-weight:700;color:var(--gold);">${qv.active||0}</div></div>
        <div class="provider-card"><div style="font-size:11px;color:var(--muted);">Completed</div><div style="font-size:20px;font-weight:700;color:#4ade80;">${qv.completed||0}</div></div>
        <div class="provider-card"><div style="font-size:11px;color:var(--muted);">Failed</div><div style="font-size:20px;font-weight:700;color:#f87171;">${qv.failed||0}</div></div>
      </div>`;

    // Niches
    document.getElementById('an-niches').innerHTML = d.topNiches?.length ?
      `<table><thead><tr><th>#</th><th>Niche</th><th>Count</th></tr></thead><tbody>${d.topNiches.map((n,i) => `<tr><td style="color:var(--muted);">${i+1}</td><td>${esc(n.niche||'—')}</td><td style="font-weight:600;">${n.count}</td></tr>`).join('')}</tbody></table>` :
      '<div class="empty-state">No niches today</div>';

    // Recent errors
    document.getElementById('an-errors').innerHTML = d.recentErrors?.length ?
      `<table><thead><tr><th>Niche</th><th>Error</th><th>Time</th></tr></thead><tbody>${d.recentErrors.map(e => `<tr><td>${esc(e.niche||'—')}</td><td style="font-size:11px;color:#f87171;max-width:200px;overflow:hidden;text-overflow:ellipsis;">${esc(e.errorMessage||'unknown')}</td><td style="font-size:11px;color:var(--muted);">${reltime(e.createdAt)}</td></tr>`).join('')}</tbody></table>` :
      '<div class="empty-state">No errors in 24h ✅</div>';

  } catch(e) { toast('Failed to load analytics: ' + e.message, 'error'); }
}

// ===================== PRICING =====================
let currentPricingCategory = 'package';

function setPricingTab(el, cat) {
  document.querySelectorAll('#pricing-tabs .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  currentPricingCategory = cat;
  const labels = { package: 'Credit Packages', subscription: 'Subscriptions', video_credit: 'Video Credits', provider_cost: 'Provider Costs', global: 'Global Settings' };
  document.getElementById('pricing-category-label').textContent = labels[cat] || cat;
  loadPricingTable(cat);
}

async function loadGateways() {
  try {
    const data = await api('/api/payment-settings');
    if (!data) return;
    const { settings, defaultGateway } = data;
    const gateways = ['midtrans', 'tripay', 'duitku'];
    document.getElementById('gateways-wrap').innerHTML = `<div style="display:flex;gap:16px;flex-wrap:wrap;">
      ${gateways.map(gw => {
        const enabled = settings?.[gw]?.enabled !== false;
        const isDefault = defaultGateway === gw;
        return `<div class="provider-card" style="min-width:180px;">
          <div style="font-size:14px;font-weight:700;text-transform:capitalize;margin-bottom:8px;">${gw}</div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <span class="badge ${enabled ? 'badge-active' : 'badge-banned'}">${enabled ? 'Enabled' : 'Disabled'}</span>
            ${isDefault ? '<span class="badge badge-enterprise">Default</span>' : ''}
          </div>
          <div style="display:flex;gap:6px;">
            <button class="btn btn-ghost btn-sm" onclick="toggleGateway('${gw}')">${enabled ? 'Disable' : 'Enable'}</button>
            ${!isDefault ? `<button class="btn btn-ghost btn-sm" onclick="setDefaultGateway('${gw}')">Set Default</button>` : ''}
          </div>
        </div>`;
      }).join('')}
    </div>`;
  } catch(e) { toast('Failed to load gateways: ' + e.message, 'error'); }
}

async function toggleGateway(gw) {
  try {
    await api('/api/payment-settings', { method: 'POST', body: { action: 'toggle_gateway', gateway: gw } });
    toast('Gateway toggled', 'success');
    loadGateways();
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

async function setDefaultGateway(gw) {
  try {
    await api('/api/payment-settings', { method: 'POST', body: { action: 'set_default', gateway: gw } });
    toast('Default gateway set to ' + gw, 'success');
    loadGateways();
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

async function loadPricingTable(cat) {
  const wrap = document.getElementById('pricing-table-wrap');
  wrap.innerHTML = '<div class="loading">Loading...</div>';
  try {
    const rows = await api('/api/pricing/' + cat);
    if (!rows) return;
    if (!rows.length) { wrap.innerHTML = '<div class="empty-state">No config entries. Click "+ Add" to create one.</div>'; return; }
    wrap.innerHTML = `<table>
      <thead><tr><th>Key</th><th>Value</th><th>Updated</th><th>Actions</th></tr></thead>
      <tbody>${rows.map(r => `<tr>
        <td style="font-family:monospace;font-size:12px;">${esc(r.key)}</td>
        <td style="font-size:12px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(JSON.stringify(r.value))}</td>
        <td style="font-size:11px;color:var(--muted);">${dt(r.updatedAt)}</td>
        <td><div style="display:flex;gap:4px;">
          <button class="btn btn-ghost btn-sm" onclick="editPricing('${esc(cat)}','${esc(r.key)}')">✏️</button>
          <button class="btn btn-danger btn-sm" onclick="deletePricing('${esc(cat)}','${esc(r.key)}')">🗑</button>
        </div></td>
      </tr>`).join('')}</tbody>
    </table>`;
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

function openPricingModal(cat, key, value) {
  document.getElementById('modal-pricing-title').textContent = key ? 'Edit Pricing Config' : 'Add Pricing Config';
  document.getElementById('pricing-category').value = cat || currentPricingCategory;
  document.getElementById('pricing-key').value = key || '';
  document.getElementById('pricing-value').value = value || '';
  document.getElementById('pricing-key').readOnly = !!key;
  document.getElementById('pricing-edit-id').value = key || '';
  openModal('modal-pricing');
}

async function editPricing(cat, key) {
  try {
    const data = await api('/api/pricing/' + encodeURIComponent(cat));
    const current = data[key];
    const valueStr = current !== undefined ? (typeof current === 'object' ? JSON.stringify(current) : String(current)) : '';
    openPricingModal(cat, key, valueStr);
  } catch(e) {
    console.error(e);
    toast('Gagal memuat setting payment', 'err');
  }
}

// ── LANDING CONFIG ──
let currentLandingConfig = {};
let currentLandingLang = 'id';

function setLandingLang(lang) {
  currentLandingLang = lang;
  // Update UI tabs
  document.querySelectorAll('.lang-tab').forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
  });
  renderTestimonials();
}

async function loadLandingConfig() {
  try {
    const res = await apiFetch('/api/landing-config');
    if (res) {
      currentLandingConfig = res;
      renderTestimonials();
    }
  } catch(e) { console.error('Failed to load landing config', e); }
}

function renderTestimonials() {
  const container = document.getElementById('testimonials-list');
  
  // Ensure structure is object-based for multi-lang
  if (Array.isArray(currentLandingConfig.testimonials)) {
    const oldTs = currentLandingConfig.testimonials;
    currentLandingConfig.testimonials = { id: oldTs, en: [] };
  }
  if (!currentLandingConfig.testimonials) currentLandingConfig.testimonials = { id: [], en: [] };
  
  const ts = currentLandingConfig.testimonials[currentLandingLang] || [];
  
  if (ts.length === 0) {
    container.innerHTML = '<div style="color:var(--dim);font-size:13px;padding:20px;text-align:center;background:var(--bg);border-radius:8px;border:1px dashed var(--border);">No testimonials for this language. Click "+ Add Testimonial" to start.</div>';
    return;
  }
  container.innerHTML = ts.map((t, i) => `
    <div style="background:var(--bg2); padding:16px; border-radius:8px; display:grid; gap:8px;">
      <input class="input" type="text" placeholder="Avatar URL" value="${escHtml(t.avatar || '')}" onchange="updateTestimonial(${i}, 'avatar', this.value)">
      <div style="display:flex; gap:8px;">
        <input class="input" type="text" placeholder="Name" value="${escHtml(t.name || '')}" style="flex:1" onchange="updateTestimonial(${i}, 'name', this.value)">
        <input class="input" type="text" placeholder="Role/Badge" value="${escHtml(t.role || '')}" style="flex:1" onchange="updateTestimonial(${i}, 'role', this.value)">
      </div>
      <textarea class="input" placeholder="User review text..." onchange="updateTestimonial(${i}, 'text', this.value)">${escHtml(t.text || '')}</textarea>
      <div style="text-align:right;"><button class="btn btn-danger btn-sm" onclick="removeTestimonial(${i})">Remove</button></div>
    </div>
  `).join('');
}

function updateTestimonial(index, field, value) {
  const ts = currentLandingConfig.testimonials[currentLandingLang];
  if (!ts) return;
  ts[index][field] = value;
}

function addTestimonialRow() {
  if (!currentLandingConfig.testimonials) currentLandingConfig.testimonials = { id: [], en: [] };
  if (!currentLandingConfig.testimonials[currentLandingLang]) currentLandingConfig.testimonials[currentLandingLang] = [];
  
  currentLandingConfig.testimonials[currentLandingLang].push({ name: '', role: '', avatar: '/public/avatar.png', text: '', bg: '#333', initial: '' });
  renderTestimonials();
}

function removeTestimonial(index) {
  const ts = currentLandingConfig.testimonials[currentLandingLang];
  if (!ts) return;
  ts.splice(index, 1);
  renderTestimonials();
}

async function saveLandingConfig() {
  const btn = event.target; btn.disabled = true; btn.textContent = 'Saving...';
  try {
    const res = await apiFetch('/api/landing-config', { method: 'POST', body: JSON.stringify(currentLandingConfig) });
    if (res && res.success) {
      toast('✅ Landing Config saved', 'ok');
    } else {
      toast('❌ Failed to save config', 'err');
    }
  } catch(e) { toast('Error saving config', 'err'); }
  btn.disabled = false; btn.textContent = 'Save Landing Config';
}

// ── MAIN INIT ──
async function deletePricing(cat, key) {
  if (!confirm('Delete pricing config: ' + key + '?')) return;
  try {
    await api('/api/pricing', { method: 'DELETE', body: { category: cat, key } });
    toast('Deleted', 'success');
    loadPricingTable(currentPricingCategory);
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

async function submitPricing() {
  const category = document.getElementById('pricing-category').value;
  const key = document.getElementById('pricing-key').value.trim();
  let value = document.getElementById('pricing-value').value.trim();
  if (!category || !key || !value) { toast('All fields required', 'error'); return; }
  try { value = JSON.parse(value); } catch {}
  try {
    await api('/api/pricing', { method: 'POST', body: { category, key, value } });
    toast('Saved', 'success');
    closeModal('modal-pricing');
    loadPricingTable(currentPricingCategory);
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

// ===================== PROMPTS =====================
async function loadPrompts() {
  const wrap = document.getElementById('prompts-table-wrap');
  wrap.innerHTML = '<div class="loading">Loading...</div>';
  const niche = document.getElementById('prompt-niche-filter').value;
  try {
    const prompts = await api('/api/admin-prompts' + (niche ? '?niche=' + encodeURIComponent(niche) : ''));
    if (!prompts) return;

    // Populate niche dropdown
    const niches = [...new Set(prompts.map(p => p.niche).filter(Boolean))];
    const sel = document.getElementById('prompt-niche-filter');
    const current = sel.value;
    sel.innerHTML = '<option value="">All Niches</option>' + niches.map(n => `<option value="${esc(n)}">${esc(n)}</option>`).join('');
    sel.value = current;

    if (!prompts.length) { wrap.innerHTML = '<div class="empty-state">No prompts found. Click "+ New Prompt" to create one.</div>'; return; }
    wrap.innerHTML = `<table>
      <thead><tr><th>Niche</th><th>Title</th><th>Usage</th><th>Created</th><th>Actions</th></tr></thead>
      <tbody>${prompts.map(p => `<tr>
        <td><span class="badge badge-starter">${esc(p.niche||'—')}</span></td>
        <td style="font-weight:500;">${esc(p.title||'—')}</td>
        <td style="color:var(--muted);">${p.successRate||0}</td>
        <td style="font-size:12px;color:var(--muted);">${dt(p.createdAt)}</td>
        <td><div style="display:flex;gap:4px;">
          <button class="btn btn-ghost btn-sm" onclick="editPrompt(${p.id},'${esc(p.niche)}','${esc(p.title)}',${JSON.stringify(esc(p.prompt))})">✏️</button>
          <button class="btn btn-danger btn-sm" onclick="deletePrompt(${p.id})">🗑</button>
        </div></td>
      </tr>`).join('')}</tbody>
    </table>`;
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

function openPromptModal() {
  document.getElementById('modal-prompt-title').textContent = 'Create Prompt';
  document.getElementById('prompt-edit-id').value = '';
  document.getElementById('prompt-niche').value = '';
  document.getElementById('prompt-title').value = '';
  document.getElementById('prompt-text').value = '';
  openModal('modal-prompt');
}

function editPrompt(id, niche, title, promptText) {
  document.getElementById('modal-prompt-title').textContent = 'Edit Prompt';
  document.getElementById('prompt-edit-id').value = id;
  document.getElementById('prompt-niche').value = niche;
  document.getElementById('prompt-title').value = title;
  document.getElementById('prompt-text').value = promptText;
  openModal('modal-prompt');
}

async function deletePrompt(id) {
  if (!confirm('Delete this prompt?')) return;
  try {
    await api('/api/admin-prompts/' + id, { method: 'DELETE' });
    toast('Prompt deleted', 'success');
    loadPrompts();
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

async function submitPrompt() {
  const id = document.getElementById('prompt-edit-id').value;
  const niche = document.getElementById('prompt-niche').value.trim().toLowerCase();
  const title = document.getElementById('prompt-title').value.trim();
  const prompt = document.getElementById('prompt-text').value.trim();
  if (!niche || !title || !prompt) { toast('All fields required', 'error'); return; }
  try {
    if (id) {
      await api('/api/admin-prompts/' + id, { method: 'PUT', body: { niche, title, prompt } });
    } else {
      await api('/api/admin-prompts', { method: 'POST', body: { niche, title, prompt } });
    }
    toast('Prompt saved', 'success');
    closeModal('modal-prompt');
    loadPrompts();
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

// ===================== BROADCAST =====================
async function previewBroadcast() {
  const tier = document.getElementById('bc-tier').value;
  try {
    const params = tier ? '?tier=' + tier : '';
    const users = await api('/api/users?limit=1000' + (tier ? '&tier=' + tier : ''));
    if (!users) return;
    document.getElementById('bc-preview').innerHTML = `<span style="color:var(--gold);font-weight:700;">${users.length} recipients</span> ${tier ? `(Tier: ${tier})` : '(All users)'}`;
  } catch(e) { toast('Preview failed: ' + e.message, 'error'); }
}

async function sendBroadcast() {
  const message = document.getElementById('bc-message').value.trim();
  const tier = document.getElementById('bc-tier').value;
  if (!message) { toast('Message is required', 'error'); return; }
  if (!confirm('Send broadcast to ' + (tier || 'ALL') + ' users?')) return;
  try {
    const r = await api('/api/broadcast', { method: 'POST', body: { message, ...(tier ? { tier } : {}) } });
    if (!r) return;
    toast(`Broadcast queued for ${r.recipientCount} users`, 'success');
    document.getElementById('bc-message').value = '';
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

