// ===================== AI ASSISTANT =====================
let aiChatBusy = false;

async function sendAdminChat() {
  const input = document.getElementById('ai-chat-input');
  const msg = input.value.trim();
  if (!msg || aiChatBusy) return;

  const messagesEl = document.getElementById('ai-chat-messages');

  // Add user message
  const userDiv = document.createElement('div');
  userDiv.className = 'ai-msg user';
  userDiv.style.cssText = 'align-self:flex-end;max-width:80%;background:rgba(0,217,255,0.12);border:1px solid rgba(0,217,255,0.15);padding:12px 16px;border-radius:14px;border-bottom-right-radius:4px;font-size:13px;line-height:1.6;';
  userDiv.textContent = msg;
  messagesEl.appendChild(userDiv);

  input.value = '';
  input.style.height = 'auto';
  aiChatBusy = true;
  document.getElementById('ai-chat-send').disabled = true;

  // Add typing indicator
  const typing = document.createElement('div');
  typing.className = 'ai-msg bot';
  typing.style.cssText = 'align-self:flex-start;max-width:80%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);padding:12px 16px;border-radius:14px;border-bottom-left-radius:4px;font-size:13px;line-height:1.6;color:var(--muted);font-style:italic;';
  typing.textContent = 'Thinking...';
  messagesEl.appendChild(typing);
  messagesEl.scrollTop = messagesEl.scrollHeight;

  try {
    const data = await api('/api/admin/ai-chat', { method: 'POST', body: { message: msg } });
    typing.remove();
    if (data && data.reply) {
      const botDiv = document.createElement('div');
      botDiv.className = 'ai-msg bot';
      botDiv.style.cssText = 'align-self:flex-start;max-width:80%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);padding:12px 16px;border-radius:14px;border-bottom-left-radius:4px;font-size:13px;line-height:1.6;white-space:pre-wrap;';
      botDiv.textContent = data.reply;
      messagesEl.appendChild(botDiv);
    } else {
      addAdminChatError(messagesEl, 'Failed to get response. Please try again.');
    }
  } catch(e) {
    typing.remove();
    addAdminChatError(messagesEl, 'Error: ' + e.message);
  }

  aiChatBusy = false;
  document.getElementById('ai-chat-send').disabled = false;
  messagesEl.scrollTop = messagesEl.scrollHeight;
  input.focus();
}

function addAdminChatError(container, msg) {
  const div = document.createElement('div');
  div.className = 'ai-msg bot';
  div.style.cssText = 'align-self:flex-start;max-width:80%;background:rgba(255,68,68,0.1);border:1px solid rgba(255,68,68,0.2);padding:12px 16px;border-radius:14px;border-bottom-left-radius:4px;font-size:13px;line-height:1.6;color:#f87171;';
  div.textContent = msg;
  container.appendChild(div);
}

// Enter to send, Shift+Enter for newline
document.getElementById('ai-chat-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAdminChat(); }
});
document.getElementById('ai-chat-input').addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 100) + 'px';
});

// ===================== INIT =====================
// Store token from URL into localStorage
const urlToken = new URLSearchParams(location.search).get('token');
if (urlToken) { localStorage.setItem('admin_password', urlToken); }

// Load initial section — support #hash navigation (e.g. redirect from /admin/settings)
const initSection = location.hash.replace('#', '') || 'overview';
if (initSection !== 'overview') {
  const navItem = document.querySelector(`[data-section="${initSection}"]`);
  if (navItem) navItem.click();
  else loadOverview();
} else {
  loadOverview();
}

// Auto-refresh overview + analytics every 30s
setInterval(() => {
  if (currentSection === 'overview') loadOverview();
  if (currentSection === 'analytics') loadAnalytics();
}, 30000);
function toggleSidebar() {
  document.querySelector('.sidebar').classList.toggle('open');
}
// Close sidebar when nav item clicked on mobile
document.querySelectorAll('.nav-item').forEach(item => {
  item.addEventListener('click', () => {
    if (window.innerWidth <= 768) {
      document.querySelector('.sidebar').classList.remove('open');
    }
  });
});
</script>
</body>
</html>
