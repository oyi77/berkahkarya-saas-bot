let profitPeriod = 30;

function setProfitPeriod(el, days) {
  profitPeriod = days;
  document.querySelectorAll('#section-profit .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  loadProfitReport();
}

async function loadProfitReport() {
  try {
    const data = await api(`/api/profit-report?period=${profitPeriod}`);
    if (!data) return;
    const fmt = n => Number(n || 0).toLocaleString('id-ID');

    document.getElementById('pf-revenue').textContent = 'Rp ' + fmt(data.revenue?.totalIdr);
    document.getElementById('pf-costs').textContent = 'Rp ' + fmt(data.costs?.totalIdr);
    document.getElementById('pf-profit').textContent = 'Rp ' + fmt(data.profit?.totalIdr);
    document.getElementById('pf-margin').textContent = (data.profit?.marginPercent || 0) + '%';
    document.getElementById('pf-txcount').textContent = fmt(data.revenue?.transactions);
    document.getElementById('pf-apicalls').textContent = fmt(data.costs?.apiCalls);
    document.getElementById('pf-costusd').textContent = '$' + Number(data.costs?.totalUsd || 0).toFixed(4);

    const avgCost = data.costs?.apiCalls > 0 ? Math.round(data.costs.totalIdr / data.costs.apiCalls) : 0;
    document.getElementById('pf-avgcost').textContent = 'Rp ' + fmt(avgCost);

    // Daily table
    const dailyRev = data.daily?.revenue || [];
    const dailyCost = data.daily?.costs || [];

    // Merge by date
    const dates = new Set([...dailyRev.map(r => r.date), ...dailyCost.map(c => c.date)]);
    const merged = [...dates].sort().map(d => {
      const rev = dailyRev.find(r => r.date === d);
      const cost = dailyCost.find(c => c.date === d);
      const revIdr = Number(rev?.revenue_idr || 0);
      const costIdr = Number(cost?.cost_idr || 0);
      return { date: d, revenue: revIdr, cost: costIdr, profit: revIdr - costIdr };
    });

    document.getElementById('pf-daily-table').innerHTML = merged.length ?
      `<table><thead><tr><th>Date</th><th>Revenue</th><th>Cost</th><th>Profit</th></tr></thead><tbody>
        ${merged.map(r => `<tr>
          <td style="font-size:12px;">${r.date}</td>
          <td style="color:#4ade80;">Rp ${fmt(r.revenue)}</td>
          <td style="color:#f87171;">Rp ${fmt(r.cost)}</td>
          <td style="color:${r.profit >= 0 ? 'var(--gold)' : '#f87171'};">Rp ${fmt(r.profit)}</td>
        </tr>`).join('')}
      </tbody></table>` : '<div class="empty-state">No data for this period</div>';

  } catch(e) { toast('Failed to load profit report: ' + e.message, 'error'); }
}

