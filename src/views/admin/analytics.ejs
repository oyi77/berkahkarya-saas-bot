            <span>On</span>
          </label>
        </div>
      </div>`;
    }).join('');

    // Landing
    document.getElementById('st-lpHeadline').value = landData.headline || '';
    document.getElementById('st-lpSub').value = landData.subheadline || '';
    document.getElementById('st-lpCta').value = landData.ctaText || '';
    document.getElementById('st-lpHeroImage').value = landData.heroImageUrl || '';
    document.getElementById('st-lpHeroVideo').value = landData.heroVideo || '';
    document.getElementById('st-lpPricingNote').value = landData.pricingNote || '';
    document.getElementById('st-lpFooterText').value = landData.footerText || '';

    // Exchange Rate
    try {
      const rateData = await api('/api/settings/exchange-rate');
      if (rateData) {
        document.getElementById('st-exchangeRate').value = rateData.rate || 16000;
        document.getElementById('st-exchangeRateDisplay').textContent = 'Rp ' + (rateData.rate || 16000).toLocaleString();
      }
    } catch(e) {}

    // Pixel Settings
    try {
      const pixelData = await api('/api/settings/pixels');
      if (pixelData) {
        document.getElementById('st-fbPixel').value = pixelData.fbPixelId || '';
        document.getElementById('st-ga4Id').value = pixelData.ga4Id || '';
