<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BerkahKarya Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg: #0d0d14;
      --sidebar: #111118;
      --card: #1a1a24;
      --border: #2a2a3a;
      --gold: #c4a35a;
      --gold-dim: #8a6f3a;
      --text: #e0e0f0;
      --muted: #888899;
    }
    * { box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; }
    .sidebar { background: var(--sidebar); border-right: 1px solid var(--border); width: 240px; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 50; display: flex; flex-direction: column; }
    .main { margin-left: 240px; padding: 24px; min-height: 100vh; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; cursor: pointer; border-left: 3px solid transparent; transition: all 0.15s; color: var(--muted); font-size: 14px; }
    .nav-item:hover { background: rgba(196,163,90,0.08); color: var(--text); }
    .nav-item.active { border-left-color: var(--gold); color: var(--gold); background: rgba(196,163,90,0.1); }
    .section { display: none; }
    .section.active { display: block; }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
    .kpi-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
    .kpi-card .label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
    .kpi-card .value { font-size: 28px; font-weight: 700; margin-top: 6px; }
    .kpi-card .sub { color: var(--muted); font-size: 12px; margin-top: 4px; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: 11px; font-weight: 600; }
    .badge-free { background: #2a2a3a; color: #aaa; }
    .badge-starter { background: #1a2a4a; color: #60a5fa; }
    .badge-pro { background: #2a1a4a; color: #a78bfa; }
    .badge-enterprise { background: #3a2a0a; color: var(--gold); }
    .badge-active { background: #0f3020; color: #4ade80; }
    .badge-banned { background: #3a0f0f; color: #f87171; }
    .badge-pending { background: #3a2a0a; color: #fbbf24; }
    .badge-success { background: #0f3020; color: #4ade80; }
    .badge-failed { background: #3a0f0f; color: #f87171; }
    .badge-completed { background: #0f3020; color: #4ade80; }
    .badge-processing { background: #0f2040; color: #60a5fa; }
    .badge-ok { background: #0f3020; color: #4ade80; }
    .badge-error { background: #3a0f0f; color: #f87171; }
    .badge-degraded { background: #3a2a0a; color: #fbbf24; }
    .badge-closed { background: #0f3020; color: #4ade80; }
    .badge-open { background: #3a0f0f; color: #f87171; }
    .badge-half { background: #3a2a0a; color: #fbbf24; }
    .badge-unknown { background: #2a2a3a; color: #aaa; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
    td { padding: 10px 12px; border-bottom: 1px solid rgba(42,42,58,0.5); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(196,163,90,0.03); }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; }
    .btn-gold { background: var(--gold); color: #0d0d14; }
    .btn-gold:hover { background: #d4b36a; }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.05); color: var(--text); }
    .btn-danger { background: #3a0f0f; color: #f87171; border: 1px solid #5a1f1f; }
    .btn-danger:hover { background: #5a1f1f; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .input { background: #0d0d14; border: 1px solid var(--border); color: var(--text); padding: 8px 12px; border-radius: 8px; font-size: 13px; outline: none; width: 100%; }
    .input:focus { border-color: var(--gold); }
    .select { background: #0d0d14; border: 1px solid var(--border); color: var(--text); padding: 8px 12px; border-radius: 8px; font-size: 13px; outline: none; }
    .select:focus { border-color: var(--gold); }
    textarea.input { resize: vertical; min-height: 100px; }
    .tab-bar { display: flex; gap: 4px; margin-bottom: 16px; }
    .tab { padding: 6px 16px; border-radius: 8px; font-size: 13px; cursor: pointer; color: var(--muted); background: transparent; border: 1px solid transparent; transition: all 0.15s; }
    .tab.active { background: rgba(196,163,90,0.15); color: var(--gold); border-color: var(--gold-dim); }
    .tab:hover:not(.active) { background: rgba(255,255,255,0.05); color: var(--text); }
    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 24px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
    .modal h3 { font-size: 18px; font-weight: 700; margin: 0 0 20px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    /* Toast */
    #toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 200; display: flex; flex-direction: column; gap: 8px; }
    .toast { padding: 12px 18px; border-radius: 10px; font-size: 13px; font-weight: 500; max-width: 320px; animation: slideIn 0.2s ease; border: 1px solid; }
    .toast-success { background: #0f3020; border-color: #1a5030; color: #4ade80; }
    .toast-error { background: #3a0f0f; border-color: #5a1f1f; color: #f87171; }
    .toast-info { background: #0f2040; border-color: #1a3060; color: #60a5fa; }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
    .divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }
    .health-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 16px; }
    .provider-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    .provider-card { background: #111118; border: 1px solid var(--border); border-radius: 8px; padding: 12px; }
    .chart-container { position: relative; height: 200px; }
    .section-title { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
    .section-sub { color: var(--muted); font-size: 13px; margin-bottom: 20px; }
    .empty-state { text-align: center; padding: 40px; color: var(--muted); }
    .loading { text-align: center; padding: 20px; color: var(--muted); }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
  <div style="padding: 20px; border-bottom: 1px solid var(--border);">
    <div style="font-size: 16px; font-weight: 700; color: var(--gold);">⚡ BerkahKarya</div>
    <div style="font-size: 11px; color: var(--muted); margin-top: 2px;">Admin Dashboard v3</div>
  </div>
  <nav style="flex: 1; padding: 12px 0;" id="nav">
    <div class="nav-item active" data-section="overview">📊 Overview</div>
    <div class="nav-item" data-section="users">👥 Users</div>
    <div class="nav-item" data-section="transactions">💳 Transactions</div>
    <div class="nav-item" data-section="videos">🎬 Videos</div>
    <div class="nav-item" data-section="analytics">📈 Analytics</div>
    <div class="nav-item" data-section="pricing">💰 Pricing</div>
    <div class="nav-item" data-section="prompts">✍️ Prompts</div>
    <div class="nav-item" data-section="broadcast">📢 Broadcast</div>
    <div class="nav-item" data-section="system">⚙️ System</div>
    <div class="nav-item" data-section="tokens">🪙 Token Usage</div>
  </nav>
  <div style="padding: 16px 20px; border-top: 1px solid var(--border);">
    <div id="live-clock" style="font-size: 12px; color: var(--muted); font-family: monospace;"></div>
    <button class="btn btn-ghost btn-sm" style="margin-top: 8px; width: 100%; justify-content: center;" onclick="logout()">🚪 Logout</button>
  </div>
</div>

<!-- Main Content -->
<div class="main">

  <!-- ====== OVERVIEW ====== -->
  <div id="section-overview" class="section active">
    <div class="section-title">Overview</div>
    <div class="section-sub">Business metrics at a glance</div>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
      <div class="kpi-card">
        <div class="label">Total Users</div>
        <div class="value" id="ov-users">—</div>
        <div class="sub" id="ov-users-sub">loading...</div>
      </div>
      <div class="kpi-card">
        <div class="label">Total Revenue</div>
        <div class="value" id="ov-revenue" style="font-size:20px;">—</div>
        <div class="sub" id="ov-revenue-today">Today: —</div>
      </div>
      <div class="kpi-card">
        <div class="label">Total Videos</div>
        <div class="value" id="ov-videos">—</div>
        <div class="sub" id="ov-videos-sub">loading...</div>
      </div>
      <div class="kpi-card">
        <div class="label">Queue Waiting</div>
        <div class="value" id="ov-queue">—</div>
        <div class="sub" id="ov-queue-sub">active jobs</div>
      </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">REVENUE (7 DAYS)</div>
        <div class="chart-container"><canvas id="chart-revenue"></canvas></div>
      </div>
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">NEW USERS (7 DAYS)</div>
        <div class="chart-container"><canvas id="chart-newusers"></canvas></div>
      </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">USERS BY TIER</div>
        <div class="chart-container"><canvas id="chart-tiers"></canvas></div>
      </div>
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">VIDEOS BY STATUS</div>
        <div class="chart-container"><canvas id="chart-vstatus"></canvas></div>
      </div>
    </div>
  </div>

  <!-- ====== USERS ====== -->
  <div id="section-users" class="section">
    <div class="section-title">Users</div>
    <div class="section-sub">Manage registered users</div>
    <div class="card" style="margin-bottom: 16px;">
      <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
        <input class="input" id="user-search" placeholder="🔍 Search by name or username..." style="max-width: 280px;" oninput="debounceUserSearch()">
        <select class="select" id="user-filter" onchange="loadUsers(true)">
          <option value="">All Users</option>
          <option value="active">Active</option>
          <option value="banned">Banned</option>
          <option value="FREE">FREE</option>
          <option value="STARTER">STARTER</option>
          <option value="PRO">PRO</option>
          <option value="ENTERPRISE">ENTERPRISE</option>
        </select>
        <button class="btn btn-gold btn-sm" onclick="loadUsers(true)">Refresh</button>
      </div>
    </div>
    <div class="card">
      <div id="users-table-wrap"><div class="loading">Loading users...</div></div>
      <div style="text-align: center; margin-top: 16px;">
        <button class="btn btn-ghost" id="users-load-more" style="display:none;" onclick="loadMoreUsers()">Load More</button>
      </div>
    </div>
  </div>

  <!-- ====== TRANSACTIONS ====== -->
  <div id="section-transactions" class="section">
    <div class="section-title">Transactions</div>
    <div class="section-sub">Payment history and status</div>
    <div class="tab-bar">
      <div class="tab active" data-tx-filter="" onclick="setTxFilter(this, '')">All</div>
      <div class="tab" data-tx-filter="pending" onclick="setTxFilter(this, 'pending')">Pending</div>
      <div class="tab" data-tx-filter="success" onclick="setTxFilter(this, 'success')">Success</div>
      <div class="tab" data-tx-filter="failed" onclick="setTxFilter(this, 'failed')">Failed</div>
    </div>
    <div class="card">
      <div id="tx-table-wrap"><div class="loading">Loading transactions...</div></div>
    </div>
  </div>

  <!-- ====== VIDEOS ====== -->
  <div id="section-videos" class="section">
    <div class="section-title">Videos</div>
    <div class="section-sub">Video generation jobs</div>
    <div class="tab-bar">
      <div class="tab active" data-vid-filter="" onclick="setVidFilter(this, '')">All</div>
      <div class="tab" data-vid-filter="pending" onclick="setVidFilter(this, 'pending')">Pending</div>
      <div class="tab" data-vid-filter="processing" onclick="setVidFilter(this, 'processing')">Processing</div>
      <div class="tab" data-vid-filter="completed" onclick="setVidFilter(this, 'completed')">Completed</div>
      <div class="tab" data-vid-filter="failed" onclick="setVidFilter(this, 'failed')">Failed</div>
    </div>
    <div class="card">
      <div id="vid-table-wrap"><div class="loading">Loading videos...</div></div>
    </div>
  </div>

  <!-- ====== ANALYTICS ====== -->
  <div id="section-analytics" class="section">
    <div class="section-title">Analytics</div>
    <div class="section-sub">Today's performance & system health</div>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
      <div class="kpi-card"><div class="label">Generations Today</div><div class="value" id="an-gen">—</div></div>
      <div class="kpi-card"><div class="label">Success Rate</div><div class="value" id="an-rate" style="color:var(--gold);">—</div></div>
      <div class="kpi-card"><div class="label">Revenue Today</div><div class="value" id="an-rev" style="font-size:18px;">—</div></div>
      <div class="kpi-card"><div class="label">Active Users 24h</div><div class="value" id="an-active">—</div></div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">PROVIDER HEALTH</div>
        <div id="an-providers" class="provider-grid"><div class="loading">Loading...</div></div>
      </div>
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">QUEUE STATUS</div>
        <div id="an-queue"><div class="loading">Loading...</div></div>
      </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">TOP NICHES TODAY</div>
        <div id="an-niches"><div class="loading">Loading...</div></div>
      </div>
      <div class="card">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--muted);">RECENT ERRORS (24H)</div>
        <div id="an-errors"><div class="loading">Loading...</div></div>
      </div>
    </div>
  </div>

  <!-- ====== PRICING ====== -->
  <div id="section-pricing" class="section">
    <div class="section-title">Pricing</div>
    <div class="section-sub">Manage payment gateways and credit pricing</div>
    <div class="card" style="margin-bottom: 20px;">
      <div style="font-size: 14px; font-weight: 600; margin-bottom: 16px; color: var(--muted);">PAYMENT GATEWAYS</div>
      <div id="gateways-wrap"><div class="loading">Loading...</div></div>
    </div>
    <div id="pricing-tabs" class="tab-bar">
      <div class="tab active" onclick="setPricingTab(this,'package')">Credit Packages</div>
      <div class="tab" onclick="setPricingTab(this,'subscription')">Subscriptions</div>
      <div class="tab" onclick="setPricingTab(this,'video_credit')">Video Credits</div>
      <div class="tab" onclick="setPricingTab(this,'provider_cost')">Provider Costs</div>
      <div class="tab" onclick="setPricingTab(this,'global')">Global</div>
    </div>
    <div class="card">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <span id="pricing-category-label" style="font-size: 13px; color: var(--muted);">Credit Packages</span>
        <button class="btn btn-gold btn-sm" onclick="openPricingModal()">+ Add</button>
      </div>
      <div id="pricing-table-wrap"><div class="loading">Loading...</div></div>
    </div>
  </div>

  <!-- ====== PROMPTS ====== -->
  <div id="section-prompts" class="section">
    <div class="section-title">Prompts</div>
    <div class="section-sub">Global AI prompt templates for users</div>
    <div class="card" style="margin-bottom: 16px;">
      <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
        <select class="select" id="prompt-niche-filter" onchange="loadPrompts()">
          <option value="">All Niches</option>
        </select>
        <button class="btn btn-gold btn-sm" onclick="openPromptModal()">+ New Prompt</button>
        <button class="btn btn-ghost btn-sm" onclick="loadPrompts()">Refresh</button>
      </div>
    </div>
    <div class="card">
      <div id="prompts-table-wrap"><div class="loading">Loading prompts...</div></div>
    </div>
  </div>

  <!-- ====== BROADCAST ====== -->
  <div id="section-broadcast" class="section">
    <div class="section-title">Broadcast</div>
    <div class="section-sub">Send messages to all or specific user groups</div>
    <div class="card" style="max-width: 600px;">
      <div class="form-group">
        <label>Message</label>
        <textarea class="input" id="bc-message" placeholder="Enter your broadcast message..."></textarea>
      </div>
      <div class="form-group">
        <label>Target Audience</label>
        <select class="select" id="bc-tier" onchange="previewBroadcast()">
          <option value="">All Users</option>
          <option value="FREE">FREE</option>
          <option value="STARTER">STARTER</option>
          <option value="PRO">PRO</option>
          <option value="ENTERPRISE">ENTERPRISE</option>
        </select>
      </div>
      <div id="bc-preview" style="padding: 12px; background: #0d0d14; border: 1px solid var(--border); border-radius: 8px; font-size: 13px; color: var(--muted); margin-bottom: 16px;">
        Click "Preview" to see recipient count.
      </div>
      <div style="display: flex; gap: 12px;">
        <button class="btn btn-ghost" onclick="previewBroadcast()">👁 Preview</button>
        <button class="btn btn-gold" onclick="sendBroadcast()">📢 Send Broadcast</button>
      </div>
    </div>
  </div>

  <!-- ====== SYSTEM ====== -->
  <div id="section-system" class="section">
    <div class="section-title">System</div>
    <div class="section-sub">Health checks and configuration</div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
      <div class="health-card" id="sys-db">
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Database</div>
        <div style="font-size: 22px; font-weight: 700;" id="sys-db-status">—</div>
        <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">PostgreSQL</div>
      </div>
      <div class="health-card" id="sys-redis">
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Redis</div>
        <div style="font-size: 22px; font-weight: 700;" id="sys-redis-status">—</div>
        <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">Cache & Queue</div>
      </div>
      <div class="health-card" id="sys-webhook">
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Telegram Webhook</div>
        <div style="font-size: 22px; font-weight: 700;" id="sys-wh-status">—</div>
        <div style="font-size: 12px; color: var(--muted); margin-top: 4px;" id="sys-wh-url">—</div>
      </div>
    </div>
    <div class="card">
      <div style="font-size: 14px; font-weight: 600; margin-bottom: 16px; color: var(--muted);">BOT INFORMATION</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;" id="sys-info">
        <div class="loading">Loading...</div>
      </div>
    </div>
    <div style="text-align: right; margin-top: 16px;">
      <button class="btn btn-gold" onclick="loadSystem()">🔄 Refresh Health</button>
    </div>
  </div>

  <!-- ====== TOKEN USAGE ====== -->
  <div id="section-tokens" class="section">
    <div class="section-title">Token Usage</div>
    <div class="section-sub">LLM token consumption and cost across all providers</div>
    <div style="display:flex;gap:8px;margin-bottom:20px;align-items:center;">
      <button class="tab active" onclick="setTokenPeriod(this,7)">7 Days</button>
      <button class="tab" onclick="setTokenPeriod(this,30)">30 Days</button>
      <button class="tab" onclick="setTokenPeriod(this,90)">90 Days</button>
      <button class="btn btn-gold btn-sm" style="margin-left:auto;" onclick="loadTokenStats()">🔄 Refresh</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;">
      <div class="kpi-card"><div class="label">Total Requests</div><div class="value" id="tk-requests">—</div></div>
      <div class="kpi-card"><div class="label">Total Tokens</div><div class="value" id="tk-tokens">—</div></div>
      <div class="kpi-card"><div class="label">Cost (USD)</div><div class="value" id="tk-usd" style="color:var(--gold)">—</div></div>
