let tokenPeriodDays = 7;

function setTokenPeriod(el, days) {
  document.querySelectorAll('#section-tokens .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  tokenPeriodDays = days;
  loadTokenStats();
}

async function loadTokenStats() {
  try {
    const [stats, recent] = await Promise.all([
      api('/api/token-stats?days=' + tokenPeriodDays),
      api('/api/token-usage?limit=30'),
    ]);
    if (!stats || !recent) return;

    document.getElementById('tk-requests').textContent = (stats.summary.totalRequests || 0).toLocaleString();
    document.getElementById('tk-tokens').textContent = Number(stats.summary.totalTokens || 0).toLocaleString();
    document.getElementById('tk-usd').textContent = '$' + Number(stats.summary.totalCostUsd || 0).toFixed(4);
    document.getElementById('tk-idr').textContent = rp(stats.summary.totalCostIdr || 0);

    document.getElementById('tk-by-provider').innerHTML = stats.byProvider?.length ?
      `<table><thead><tr><th>Provider</th><th>Requests</th><th>Tokens</th><th>Cost USD</th></tr></thead><tbody>
        ${stats.byProvider.map(r => `<tr>
          <td><span class="badge badge-starter">${esc(r.provider)}</span></td>
          <td>${Number(r.requests).toLocaleString()}</td>
          <td>${Number(r.tokens).toLocaleString()}</td>
          <td style="color:var(--gold);">$${Number(r.cost_usd).toFixed(5)}</td>
        </tr>`).join('')}
      </tbody></table>` : '<div class="empty-state">No data yet — usage appears after first AI call</div>';

    document.getElementById('tk-by-model').innerHTML = stats.byModel?.length ?
      `<table><thead><tr><th>Model</th><th>Requests</th><th>Cost USD</th></tr></thead><tbody>
        ${stats.byModel.map(r => `<tr>
          <td style="font-size:11px;font-family:monospace;max-width:160px;overflow:hidden;text-overflow:ellipsis;">${esc(r.model)}</td>
          <td>${Number(r.requests).toLocaleString()}</td>
          <td style="color:var(--gold);">$${Number(r.cost_usd).toFixed(5)}</td>
        </tr>`).join('')}
      </tbody></table>` : '<div class="empty-state">No data yet</div>';

    document.getElementById('tk-by-service').innerHTML = stats.byService?.length ?
      `<table><thead><tr><th>Service</th><th>Tokens</th><th>Requests</th></tr></thead><tbody>
        ${stats.byService.map(r => `<tr>
          <td><span class="badge badge-pro">${esc(r.service)}</span></td>
          <td>${Number(r.tokens).toLocaleString()}</td>
          <td>${Number(r.requests).toLocaleString()}</td>
        </tr>`).join('')}
      </tbody></table>` : '<div class="empty-state">No data yet</div>';

    document.getElementById('tk-daily').innerHTML = stats.daily?.length ?
      `<table><thead><tr><th>Date</th><th>Tokens</th><th>Cost USD</th><th>Requests</th></tr></thead><tbody>
        ${stats.daily.map(r => `<tr>
          <td style="font-size:12px;">${r.date}</td>
          <td>${Number(r.tokens).toLocaleString()}</td>
          <td style="color:var(--gold);">$${Number(r.cost_usd).toFixed(5)}</td>
          <td>${Number(r.requests).toLocaleString()}</td>
        </tr>`).join('')}
      </tbody></table>` : '<div class="empty-state">No data yet</div>';

    document.getElementById('tk-recent').innerHTML = recent?.length ?
      `<table><thead><tr><th>Provider</th><th>Model</th><th>Service</th><th>Tokens</th><th>Cost USD</th><th>Time</th></tr></thead><tbody>
        ${recent.map(r => `<tr>
          <td><span class="badge badge-starter">${esc(r.provider)}</span></td>
          <td style="font-size:11px;font-family:monospace;max-width:140px;overflow:hidden;text-overflow:ellipsis;">${esc(r.model)}</td>
          <td><span class="badge badge-pro">${esc(r.service)}</span></td>
          <td>${Number(r.totalTokens).toLocaleString()}</td>
          <td style="color:var(--gold);">$${Number(r.costUsd).toFixed(6)}</td>
          <td style="font-size:11px;color:var(--muted);">${reltime(r.createdAt)}</td>
        </tr>`).join('')}
      </tbody></table>` :
      '<div class="empty-state">No token usage recorded yet.<br>Usage will appear here after first AI chat call.</div>';

  } catch(e) { toast('Failed to load token stats: ' + e.message, 'error'); }
}

// ===================== INIT =====================
// Store token from URL into localStorage
const urlToken = new URLSearchParams(location.search).get('token');
if (urlToken) { localStorage.setItem('admin_password', urlToken); }

// Load initial section
loadOverview();

// Auto-refresh overview + analytics every 30s
setInterval(() => {
  if (currentSection === 'overview') loadOverview();
  if (currentSection === 'analytics') loadAnalytics();
}, 30000);
</script>
</body>
</html>
