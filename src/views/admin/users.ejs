<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin - Users Management</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --bg: #0d0d14;
      --sidebar: #111118;
      --card: #1a1a24;
      --border: #2a2a3a;
      --gold: #c4a35a;
      --gold-dim: #8a6f3a;
      --text: #e0e0f0;
    }
    body { background-color: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; }
    .sidebar { background-color: var(--sidebar); border-right: 1px solid var(--border); }
    .card { background-color: var(--card); border: 1px solid var(--border); }
    .btn-primary { background: var(--gold); color: #000; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: bold; }
    .btn-primary:hover { background: #d5b875; }
  </style>
</head>
<body class="flex h-screen overflow-hidden">

  <!-- Sidebar -->
  <aside class="sidebar w-64 h-full flex flex-col hidden md:flex">
    <div class="p-6 border-b border-[var(--border)]">
      <h1 class="text-2xl font-bold" style="color: var(--gold)">OpenClaw <span class="text-white text-sm">v3.0</span></h1>
    </div>
    <nav class="flex-1 p-4 space-y-2">
      <a href="/admin/dashboard" class="block p-3 rounded hover:bg-[var(--card)] transition">📊 Analytics</a>
      <a href="/admin/users" class="block p-3 rounded bg-[var(--card)] font-bold transition">👥 Users</a>
      <a href="/admin/pricing" class="block p-3 rounded hover:bg-[var(--card)] transition">💰 Pricing</a>
      <a href="/admin/prompts" class="block p-3 rounded hover:bg-[var(--card)] transition">📝 Prompts</a>
      <a href="/admin/settings" class="block p-3 rounded hover:bg-[var(--card)] transition">⚙️ Settings</a>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto p-8">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-bold">User Management</h2>
    </div>

    <!-- Search -->
    <div class="card p-6 rounded-xl mb-6">
      <input type="text" id="searchInput" placeholder="Search by username or ID..." class="w-full bg-[var(--bg)] border border-[var(--border)] p-3 rounded text-white mb-4 focus:outline-none focus:border-[var(--gold)]">
      <button onclick="searchUsers()" class="btn-primary">Search Users</button>
    </div>

    <!-- Users Table -->
    <div class="card rounded-xl overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead class="bg-[#2a2a3a]">
          <tr>
            <th class="p-4">Telegram ID</th>
            <th class="p-4">Username</th>
            <th class="p-4">Tier</th>
            <th class="p-4">Credits</th>
            <th class="p-4">Status</th>
            <th class="p-4">Actions</th>
          </tr>
        </thead>
        <tbody id="usersTable">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>

    <!-- Transfers Section -->
    <div class="mt-12">
      <h2 class="text-2xl font-bold mb-4">Recent Credit Transfers (P2P)</h2>
      <div class="card rounded-xl overflow-hidden p-6">
        <div id="transfersLog" class="space-y-3">Loading transfers...</div>
      </div>
    </div>
  </main>

  <script>
    async function loadUsers(query = '') {
      const res = await fetch(\`/api/users/search?q=\${query}&limit=20\`);
      const users = await res.json();
      
      const tbody = document.getElementById('usersTable');
      tbody.innerHTML = '';
      
      if (!users.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-gray-500">No users found. Try searching.</td></tr>';
        return;
      }

      users.forEach(u => {
        tbody.innerHTML += \`
          <tr class="border-b border-[var(--border)]">
            <td class="p-4">\${u.telegramId}</td>
            <td class="p-4">@\${u.username || 'unknown'}</td>
            <td class="p-4"><span class="px-2 py-1 rounded bg-gray-800 text-xs font-bold">\${u.tier}</span></td>
            <td class="p-4">\${u.creditBalance}</td>
            <td class="p-4">\${u.isBanned ? '<span class="text-red-500">BANNED</span>' : '<span class="text-green-500">ACTIVE</span>'}</td>
            <td class="p-4">
              <button onclick="promptCredit('\${u.telegramId}')" class="text-blue-400 hover:underline mr-2">Add Credit</button>
              <button onclick="promptTier('\${u.telegramId}')" class="text-yellow-400 hover:underline mr-2">Set Tier</button>
              <button onclick="toggleBan('\${u.telegramId}', \${!u.isBanned})" class="text-red-400 hover:underline">\${u.isBanned ? 'Unban' : 'Ban'}</button>
            </td>
          </tr>
        \`;
      });
    }

    async function loadTransfers() {
      const res = await fetch('/api/transactions/transfers');
      const transfers = await res.json();
      
      const div = document.getElementById('transfersLog');
      if (!transfers.length) {
        div.innerHTML = '<span class="text-gray-500">No recent transfers found.</span>';
        return;
      }
      
      div.innerHTML = transfers.map(t => \`
        <div class="p-3 bg-[var(--bg)] rounded border border-[var(--border)] flex justify-between">
          <span>From: <b>@\${t.user?.username}</b> (\${t.userId})</span>
          <span>Amount: <b>\${t.creditsAmount} Credits</b></span>
          <span class="text-gray-400">\${new Date(t.createdAt).toLocaleString()}</span>
        </div>
      \`).join('');
    }

    function searchUsers() {
      loadUsers(document.getElementById('searchInput').value);
    }

    async function promptCredit(id) {
      const amt = prompt('Amount of credits to add:');
      if(!amt) return;
      await fetch(\`/api/users/\${id}/credits\`, {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ amount: parseFloat(amt), reason: 'admin manual' })
      });
      alert('Credit added!');
      searchUsers();
    }

    async function promptTier(id) {
      const tier = prompt('Enter new tier (FREE, STARTER, PRO, ENTERPRISE):');
      if(!tier) return;
      await fetch(\`/api/users/\${id}/tier\`, {
        method:'PATCH',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ tier: tier.toUpperCase() })
      });
      alert('Tier updated!');
      searchUsers();
    }

    async function toggleBan(id, banState) {
      if(!confirm('Are you sure?')) return;
      await fetch(\`/api/users/\${id}/ban\`, {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ banned: banState })
      });
      searchUsers();
    }

    // Load initial
    loadUsers('a'); // load some users with 'a'
    loadTransfers();
  </script>
</body>
</html>
