<style>
  .settings-tabs { display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);flex-wrap:wrap; }
  .settings-tab { padding:10px 20px;cursor:pointer;font-size:14px;border-bottom:2px solid transparent;color:var(--muted);white-space:nowrap; }
  .settings-tab.active { border-bottom:2px solid var(--gold);color:var(--gold); }
  .settings-panel { display:none; }
  .settings-panel.active { display:block; }

  /* Runtime Config styles (from system.ejs) */
  .group-header { display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 12px 16px; background: #111118; border-radius: 8px 8px 0 0; border: 1px solid var(--border); user-select: none; margin-top: 16px; }
  .group-header:hover { background: rgba(196,163,90,0.06); }
  .group-title { font-size: 14px; font-weight: 600; color: var(--text); }
  .group-body { border: 1px solid var(--border); border-top: none; border-radius: 0 0 8px 8px; overflow: hidden; margin-bottom: 4px; }
  .config-row { display: grid; grid-template-columns: 220px 1fr 180px; align-items: center; gap: 12px; padding: 10px 16px; border-bottom: 1px solid rgba(42,42,58,0.5); font-size: 13px; }
  .config-row:last-child { border-bottom: none; }
  .config-row:hover { background: rgba(196,163,90,0.03); }
  .config-key { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 11px; color: #a0a0c0; word-break: break-all; }
  .config-val { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 12px; color: var(--text); }
  .config-val.clickable { cursor: pointer; }
  .config-val.clickable:hover { color: var(--gold); text-decoration: underline; }
  .actions { display: flex; gap: 6px; }
  @media (max-width: 768px) {
    .config-row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>

<div id="toast-container"></div>

<div class="section-title">Settings</div>
<div class="section-sub">System configuration, tracking, broadcast, runtime config and API keys</div>

<!-- Tab Bar -->
<div class="settings-tabs">
  <div class="settings-tab active" onclick="switchSettingsTab('general')">&#9881;&#65039; General</div>
  <div class="settings-tab" onclick="switchSettingsTab('tracking')">&#128202; Tracking</div>
  <div class="settings-tab" onclick="switchSettingsTab('broadcast')">&#128226; Broadcast</div>
  <div class="settings-tab" onclick="switchSettingsTab('runtime')">&#128295; Runtime Config</div>
  <div class="settings-tab" onclick="switchSettingsTab('apikeys')">&#128273; API Keys</div>
</div>

<!-- ====== GENERAL TAB ====== -->
<div id="stab-general" class="settings-panel active">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

    <!-- USD->IDR Exchange Rate -->
    <div class="card" style="padding:20px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border);">
        <div style="font-size:14px;font-weight:600;">&#128177; USD &#8594; IDR Exchange Rate</div>
        <button class="btn btn-gold btn-sm" onclick="saveExchangeRate()">Save</button>
      </div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:12px;">Used for cost calculations, profit reports, and pricing recommendations. Changes take effect immediately.</div>
      <input type="number" id="st-exchangeRate" style="width:100%;background:var(--bg);border:1px solid var(--border);padding:8px;border-radius:6px;color:var(--text);font-size:16px;" placeholder="16000" min="10000" max="50000" step="100">
      <div style="font-size:11px;color:var(--muted);margin-top:8px;">Current: <span id="st-exchangeRateDisplay">loading...</span></div>
    </div>

    <!-- Referral Rates -->
    <div class="card" style="padding:20px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border);">
        <div style="font-size:14px;font-weight:600;">Referral Commission Rates</div>
        <button class="btn btn-gold btn-sm" onclick="saveReferralRates()">Save</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        <div>
          <div style="font-size:12px;color:var(--muted);margin-bottom:4px;">Sell Rate (IDR/credit) &#8212; paid when converting commission &#8594; credits</div>
          <input type="number" id="st-refSellRate" style="width:100%;background:var(--bg);border:1px solid var(--border);padding:8px;border-radius:6px;color:var(--text);" placeholder="3000" min="100" step="100">
        </div>
        <div>
          <div style="font-size:12px;color:var(--muted);margin-bottom:4px;">Buy Rate (IDR/credit) &#8212; average credit purchase price (reference)</div>
          <input type="number" id="st-refBuyRate" style="width:100%;background:var(--bg);border:1px solid var(--border);padding:8px;border-radius:6px;color:var(--text);" placeholder="6000" min="100" step="100">
        </div>
        <div style="font-size:11px;color:var(--muted);">E.g. Rp 30,000 commission &#247; Rp 3,000 sell rate = 10 credits.</div>
      </div>
    </div>

  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

    <!-- Pricing Seed -->
    <div class="card" style="padding:20px;">
      <div style="font-size:14px;font-weight:600;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--border);">Pricing Data</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:16px;">Seed the database with default packages and subscription plans from static config. Safe to run multiple times (idempotent).</div>
      <button class="btn btn-gold btn-sm" onclick="seedPricing()">&#127793; Seed Default Pricing Data</button>
      <div id="st-seed-result" style="margin-top:10px;font-size:12px;color:var(--muted);"></div>
    </div>

    <!-- Free Trial Settings -->
    <div class="card" style="padding:20px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border);">
        <div style="font-size:14px;font-weight:600;">&#127873; Free Trial Settings</div>
        <button class="btn btn-gold btn-sm" onclick="saveFreeTrial()">Save</button>
      </div>
      <div id="st-freeTrialConfig"><div class="loading">Loading...</div></div>
    </div>

  </div>
</div>

<!-- ====== TRACKING TAB ====== -->
<div id="stab-tracking" class="settings-panel">
  <div class="card" style="padding:20px;max-width:600px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border);">
      <div style="font-size:14px;font-weight:600;">&#128202; Tracking Pixels</div>
      <button class="btn btn-gold btn-sm" onclick="savePixels()">Save</button>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:4px;">Meta (Facebook) Pixel ID</div>
        <input type="text" id="st-fbPixel" style="width:100%;background:var(--bg);border:1px solid var(--border);padding:8px;border-radius:6px;color:var(--text);" placeholder="771021905629860">
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:4px;">GA4 Measurement ID</div>
        <input type="text" id="st-ga4Id" style="width:100%;background:var(--bg);border:1px solid var(--border);padding:8px;border-radius:6px;color:var(--text);" placeholder="G-XXXXXXXXXX">
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:4px;">TikTok Pixel ID</div>
        <input type="text" id="st-ttPixel" style="width:100%;background:var(--bg);border:1px solid var(--border);padding:8px;border-radius:6px;color:var(--text);" placeholder="D6IA84RC77UCTB9KG9OG">
      </div>
    </div>
  </div>
</div>

<!-- ====== BROADCAST TAB ====== -->
<div id="stab-broadcast" class="settings-panel">
  <div class="section-sub">Send messages to all or specific user groups</div>
  <div class="card" style="max-width: 600px;">
    <div class="form-group">
      <label>Message</label>
      <textarea class="input" id="bc-message" placeholder="Enter your broadcast message..."></textarea>
    </div>
    <div class="form-group">
      <label>Target Audience</label>
      <select class="select" id="bc-tier" onchange="previewBroadcast()">
        <option value="">All Users</option>
        <option value="free">free</option>
        <option value="basic">basic</option>
        <option value="lite">lite</option>
        <option value="pro">pro</option>
        <option value="agency">agency</option>
      </select>
    </div>
    <div id="bc-preview" style="padding: 12px; background: #0d0d14; border: 1px solid var(--border); border-radius: 8px; font-size: 13px; color: var(--muted); margin-bottom: 16px;">
      Click "Preview" to see recipient count.
    </div>
    <div style="display: flex; gap: 12px;">
      <button class="btn btn-ghost" onclick="previewBroadcast()">&#128065; Preview</button>
      <button class="btn btn-gold" onclick="sendBroadcast()">&#128226; Send Broadcast</button>
    </div>
  </div>
</div>

<!-- ====== RUNTIME CONFIG TAB ====== -->
<div id="stab-runtime" class="settings-panel">
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;">
    <input class="input" id="search" placeholder="Filter by key..." style="max-width: 280px; padding: 8px 12px;" oninput="filterRows(this.value)" />
    <button class="btn btn-ghost btn-sm" onclick="expandAll()">Expand All</button>
    <button class="btn btn-ghost btn-sm" onclick="collapseAll()">Collapse All</button>
    <button class="btn btn-gold btn-sm" onclick="loadConfig()">&#8635; Refresh</button>
    <span id="summary" style="font-size: 12px; color: var(--muted);"></span>
  </div>
  <div id="config-container">
    <div style="text-align: center; padding: 40px; color: var(--muted);">Loading configuration...</div>
  </div>
</div>

<!-- ====== API KEYS TAB ====== -->
<div id="stab-apikeys" class="settings-panel">
  <div style="margin-bottom:16px;display:flex;gap:8px;align-items:center;">
    <button class="btn btn-gold btn-sm" onclick="loadApiKeys()">&#8635; Refresh</button>
    <span style="font-size:12px;color:var(--muted);">DB values override env vars immediately. Masked display only &#8212; full values never shown.</span>
  </div>
  <div id="apikeys-container">
    <div style="text-align:center;padding:40px;color:var(--muted);">Loading...</div>
  </div>
</div>

<script>
// ── AUTH + HELPERS ────────────────────────────────────────────────────
const getToken = () => localStorage.getItem('admin_password') || new URLSearchParams(location.search).get('token') || '';
async function api(path, opts = {}) {
  const token = getToken();
  const headers = { 'Authorization': 'Basic ' + btoa(':' + token), ...(opts.headers || {}) };
  if (opts.body && typeof opts.body !== 'string') { headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(opts.body); }
  const res = await fetch(path, { ...opts, headers, credentials: 'include' });
  if (res.status === 401) { location.href = '/admin/login'; return null; }
  const text = await res.text();
  let data; try { data = JSON.parse(text); } catch { data = text; }
  if (!res.ok) throw new Error(typeof data === 'string' ? data : (data?.error || 'Request failed'));
  return data;
}
function toast(msg, type = 'success') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}

// ── TAB SWITCHING ────────────────────────────────────────────────────
function switchSettingsTab(tab) {
  document.querySelectorAll('.settings-tab').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.settings-panel').forEach(el => el.classList.remove('active'));
  const idx = ['general','tracking','runtime','broadcast','apikeys'].indexOf(tab);
  if (idx >= 0) document.querySelectorAll('.settings-tab')[idx].classList.add('active');
  const panel = document.getElementById('stab-' + tab);
  if (panel) panel.classList.add('active');
  loadSettingsTab(tab);
}

function loadSettingsTab(tab) {
  if (tab === 'general') {
    loadGeneralSettings();
  } else if (tab === 'tracking') {
    loadPixels();
  } else if (tab === 'runtime') {
    loadConfig();
  } else if (tab === 'apikeys') {
    loadApiKeys();
  }
}

// ── GENERAL SETTINGS ─────────────────────────────────────────────────
async function loadGeneralSettings() {
  try {
    const [refData] = await Promise.all([
      api('/api/settings/referral'),
    ]);
    // Referral
    if (refData) {
      document.getElementById('st-refSellRate').value = refData.sellRate || 3000;
      document.getElementById('st-refBuyRate').value = refData.buyRate || 6000;
    }
  } catch(e) { toast('Failed to load settings: ' + e.message, 'error'); }

  // Exchange Rate
  try {
    const rateData = await api('/api/settings/exchange-rate');
    if (rateData) {
      document.getElementById('st-exchangeRate').value = rateData.rate || 16000;
      document.getElementById('st-exchangeRateDisplay').textContent = 'Rp ' + (rateData.rate || 16000).toLocaleString();
    }
  } catch(e) {}

  // Free trial
  loadFreeTrial();
}

async function saveExchangeRate() {
  const rate = parseInt(document.getElementById('st-exchangeRate').value);
  if (!rate || rate < 10000 || rate > 50000) { toast('Exchange rate must be between 10,000 and 50,000 IDR/USD', 'error'); return; }
  const res = await api('/api/settings/exchange-rate', { method: 'POST', body: { rate } });
  if (res !== null) {
    toast('Exchange rate saved: ' + rate);
    document.getElementById('st-exchangeRateDisplay').textContent = 'Rp ' + rate.toLocaleString();
  } else {
    toast('Failed to save exchange rate', 'error');
  }
}

async function saveReferralRates() {
  const sellRate = parseInt(document.getElementById('st-refSellRate').value);
  const buyRate = parseInt(document.getElementById('st-refBuyRate').value);
  if (!sellRate || sellRate <= 0 || !buyRate || buyRate <= 0) { toast('Rates must be positive numbers', 'error'); return; }
  const res = await api('/api/settings/referral', { method: 'POST', body: { sellRate, buyRate } });
  res !== null ? toast('Referral rates saved!') : toast('Failed to save rates', 'error');
}

async function seedPricing() {
  document.getElementById('st-seed-result').textContent = 'Seeding...';
  const data = await api('/api/settings/seed-pricing', { method: 'POST' });
  if (data) {
    document.getElementById('st-seed-result').textContent = data.success
      ? '\u2705 Seeded ' + data.seeded + ' entries.'
      : '\u274C Failed: ' + (data.error || 'Unknown');
    if (data.success) toast('Seeded ' + data.seeded + ' pricing entries');
  }
}

// ── FREE TRIAL ───────────────────────────────────────────────────────
async function loadFreeTrial() {
  try {
    const data = await api('/api/settings/free-trial');
    if (!data) return;
    const el = document.getElementById('st-freeTrialConfig');
    el.innerHTML = `
      <div style="display:flex;flex-direction:column;gap:12px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <label style="font-size:13px;min-width:160px;">Welcome Bonus Enabled</label>
          <input type="checkbox" id="ft-welcomeEnabled" ${data.welcomeBonus?.enabled ? 'checked' : ''}>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <label style="font-size:13px;min-width:160px;">Welcome Bonus Count</label>
          <input type="number" id="ft-welcomeCount" value="${data.welcomeBonus?.count ?? 1}" min="0" style="width:80px;background:var(--bg);border:1px solid var(--border);padding:6px;border-radius:6px;color:var(--text);">
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <label style="font-size:13px;min-width:160px;">Allow Video Generation</label>
          <input type="checkbox" id="ft-videoGen" ${data.restrictions?.videoGeneration ? 'checked' : ''}>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <label style="font-size:13px;min-width:160px;">Max Video Duration (s)</label>
          <input type="number" id="ft-maxDuration" value="${data.restrictions?.maxVideoDuration ?? 15}" min="5" max="60" style="width:80px;background:var(--bg);border:1px solid var(--border);padding:6px;border-radius:6px;color:var(--text);">
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <label style="font-size:13px;min-width:160px;">Watermark</label>
          <input type="checkbox" id="ft-watermark" ${data.restrictions?.watermark ? 'checked' : ''}>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <label style="font-size:13px;min-width:160px;">Allow Custom Prompt</label>
          <input type="checkbox" id="ft-customPrompt" ${data.restrictions?.customPrompt ? 'checked' : ''}>
        </div>
      </div>`;
  } catch(e) { document.getElementById('st-freeTrialConfig').textContent = 'Failed to load'; }
}

async function saveFreeTrial() {
  const payload = {
    welcomeBonus: {
      enabled: document.getElementById('ft-welcomeEnabled').checked,
      count: parseInt(document.getElementById('ft-welcomeCount').value) || 1,
      type: 'image_generation',
      provider: 'google_gemini',
    },
    restrictions: {
      videoGeneration: document.getElementById('ft-videoGen').checked,
      maxVideoDuration: parseInt(document.getElementById('ft-maxDuration').value) || 15,
      watermark: document.getElementById('ft-watermark').checked,
      customPrompt: document.getElementById('ft-customPrompt').checked,
      promptSource: 'library_only',
      queuePriority: 'lowest',
    },
  };
  const res = await api('/api/settings/free-trial', { method: 'POST', body: payload });
  res !== null ? toast('Free trial settings saved!') : toast('Failed to save free trial settings', 'error');
}

// ── TRACKING / PIXELS ────────────────────────────────────────────────
async function loadPixels() {
  try {
    const pixelData = await api('/api/settings/pixels');
    if (pixelData) {
      document.getElementById('st-fbPixel').value = pixelData.fbPixelId || '';
      document.getElementById('st-ga4Id').value = pixelData.ga4Id || '';
      document.getElementById('st-ttPixel').value = pixelData.ttPixelId || '';
    }
  } catch(e) {}
}

async function savePixels() {
  const payload = {
    fbPixelId: document.getElementById('st-fbPixel').value,
    ga4Id: document.getElementById('st-ga4Id').value,
    ttPixelId: document.getElementById('st-ttPixel').value,
  };
  const res = await api('/api/settings/pixels', { method: 'POST', body: payload });
  res !== null ? toast('Pixel settings saved!') : toast('Failed to save pixels', 'error');
}

// ── BROADCAST ────────────────────────────────────────────────────────
async function previewBroadcast() {
  const tier = document.getElementById('bc-tier').value;
  try {
    const users = await api('/api/users?limit=1000' + (tier ? '&tier=' + tier : ''));
    if (!users) return;
    document.getElementById('bc-preview').innerHTML = '<span style="color:var(--gold);font-weight:700;">' + users.length + ' recipients</span> ' + (tier ? '(Tier: ' + tier + ')' : '(All users)');
  } catch(e) { toast('Preview failed: ' + e.message, 'error'); }
}

async function sendBroadcast() {
  const message = document.getElementById('bc-message').value.trim();
  const tier = document.getElementById('bc-tier').value;
  if (!message) { toast('Message is required', 'error'); return; }
  if (!confirm('Send broadcast to ' + (tier || 'ALL') + ' users?')) return;
  try {
    const r = await api('/api/broadcast', { method: 'POST', body: { message, ...(tier ? { tier } : {}) } });
    if (!r) return;
    toast('Broadcast queued for ' + r.recipientCount + ' users', 'success');
    document.getElementById('bc-message').value = '';
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

// ── RUNTIME CONFIG (from system.ejs) ─────────────────────────────────
let configData = {};

const CATEGORY_LABELS = {
  provider:   '&#128268; Provider Config',
  ai_param:   '&#129504; AI Parameters',
  timeout:    '&#9201;&#65039; Timeouts',
  retry:      '&#128260; Retry / Poll',
  queue:      '&#128247; Queue',
  retention:  '&#128231; Retention',
  rate_limit: '&#9940; Rate Limits',
  hpas:       '&#127916; HPAS',
};

const CATEGORY_ORDER = ['provider', 'ai_param', 'timeout', 'retry', 'queue', 'retention', 'rate_limit', 'hpas'];

async function loadConfig() {
  document.getElementById('config-container').innerHTML =
    '<div style="text-align: center; padding: 40px; color: var(--muted);">Loading...</div>';
  try {
    const res = await fetch('/api/admin-config');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    configData = await res.json();
    renderConfig('');
  } catch (e) {
    document.getElementById('config-container').innerHTML =
      '<div style="text-align: center; padding: 40px; color: #f87171;">Failed to load: ' + e.message + '</div>';
  }
}

function renderConfig(filterText) {
  const ft = (filterText || '').toLowerCase();
  let html = '';
  let totalDb = 0, totalDefault = 0;

  for (const cat of CATEGORY_ORDER) {
    const entries = configData[cat] || {};
    const rows = Object.entries(entries)
      .filter(([k]) => !ft || k.toLowerCase().includes(ft))
      .sort(([a], [b]) => a.localeCompare(b));
    if (rows.length === 0 && ft) continue;

    const groupId = 'group-' + cat;
    let rowsHtml = '';
    for (const [key, value] of rows) {
      const displayVal = JSON.stringify(value);
      totalDb++;
      rowsHtml += `
        <div class="config-row" data-key="${escAttr(key)}" data-cat="${escAttr(cat)}">
          <div class="config-key">${escHtml(key)}</div>
          <div class="config-val">
            <span class="clickable" onclick="startEdit('${escAttr(cat)}','${escAttr(key)}',this)" title="Click to edit">${escHtml(displayVal)}</span>
          </div>
          <div class="actions">
            <span class="badge badge-db">db</span>
            <button class="btn btn-danger btn-sm" onclick="resetKey('${escAttr(cat)}','${escAttr(key)}')">Reset</button>
          </div>
        </div>`;
    }
    if (!ft && rows.length === 0) {
      rowsHtml = '<div style="padding:12px 16px; color: var(--muted); font-size:12px;">No values stored (all using defaults)</div>';
      totalDefault++;
    }

    html += `
      <div id="${groupId}-wrapper">
        <div class="group-header" onclick="toggleGroup('${groupId}')">
          <span class="group-title">${CATEGORY_LABELS[cat] || cat} <span style="color:var(--muted);font-weight:400;font-size:12px;">(${rows.length})</span></span>
          <span id="${groupId}-arrow" style="color:var(--muted);font-size:12px;">&#9660;</span>
        </div>
        <div class="group-body" id="${groupId}-body">${rowsHtml}</div>
      </div>`;
  }

  document.getElementById('config-container').innerHTML = html ||
    '<div style="text-align:center;padding:40px;color:var(--muted);">No matching keys.</div>';
  if (!ft) {
    document.getElementById('summary').textContent = totalDb + ' stored in DB';
  } else {
    document.getElementById('summary').textContent = '';
  }
}

function startEdit(cat, key, spanEl) {
  const current = spanEl.textContent;
  const input = document.createElement('input');
  input.className = 'input';
  input.style.width = '100%';
  input.value = current;
  input.onblur = () => { spanEl.style.display = ''; input.replaceWith(spanEl); };
  input.onkeydown = async (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      await saveKey(cat, key, input.value, spanEl);
    } else if (e.key === 'Escape') {
      input.blur();
    }
  };
  spanEl.style.display = 'none';
  spanEl.parentNode.insertBefore(input, spanEl);
  input.focus();
  input.select();
}

async function saveKey(cat, key, rawValue, spanEl) {
  let parsed;
  try {
    parsed = JSON.parse(rawValue);
  } catch {
    toast('Invalid JSON value', 'error');
    return;
  }
  try {
    const res = await fetch('/api/admin-config/' + encodeURIComponent(cat) + '/' + encodeURIComponent(key), {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ value: parsed }),
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    spanEl.textContent = JSON.stringify(parsed);
    spanEl.style.display = '';
    configData[cat][key] = parsed;
    toast('Saved: ' + key, 'success');
  } catch (e) {
    toast('Save failed: ' + e.message, 'error');
    spanEl.style.display = '';
  }
}

async function resetKey(cat, key) {
  if (!confirm('Reset "' + key + '" to compiled default?')) return;
  try {
    const res = await fetch('/api/admin-config/' + encodeURIComponent(cat) + '/' + encodeURIComponent(key), {
      method: 'DELETE',
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    delete configData[cat][key];
    toast('Reset: ' + key, 'success');
    renderConfig(document.getElementById('search').value);
  } catch (e) {
    toast('Reset failed: ' + e.message, 'error');
  }
}

function filterRows(text) {
  renderConfig(text);
}

function toggleGroup(id) {
  const body = document.getElementById(id + '-body');
  const arrow = document.getElementById(id + '-arrow');
  if (!body) return;
  const isHidden = body.style.display === 'none';
  body.style.display = isHidden ? '' : 'none';
  if (arrow) arrow.innerHTML = isHidden ? '&#9660;' : '&#9658;';
}

function expandAll() {
  document.querySelectorAll('.group-body').forEach(el => { el.style.display = ''; });
  document.querySelectorAll('[id$="-arrow"]').forEach(el => { el.innerHTML = '&#9660;'; });
}

function collapseAll() {
  document.querySelectorAll('.group-body').forEach(el => { el.style.display = 'none'; });
  document.querySelectorAll('[id$="-arrow"]').forEach(el => { el.innerHTML = '&#9658;'; });
}

function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function escAttr(str) {
  return String(str).replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

// ── API KEYS (from system.ejs) ───────────────────────────────────────
const AK_GROUPS = {
  'Core': ['BOT_TOKEN','ADMIN_PASSWORD','DATABASE_URL','REDIS_URL','WEBHOOK_URL','WEBHOOK_SECRET','USD_TO_IDR_RATE'],
  'AI / LLM': ['OMNIROUTE_API_KEY','OMNIROUTE_URL','GEMINI_API_KEY','OPENAI_API_KEY','XAI_API_KEY','GROQ_API_KEY','AGENTROUTER_API_KEY'],
  'Video Providers': ['BYTEPLUS_API_KEY','LAOZHANG_API_KEY','EVOLINK_API_KEY','HYPEREAL_API_KEY','SILICONFLOW_API_KEY','FALAI_API_KEY','KIE_API_KEY','PIAPI_API_KEY','GEMINIGEN_API_KEY','LINGYAAI_API_KEY','GETGOAPI_API_KEY','APIYI_API_KEY','ZAI_API_KEY','DID_API_KEY'],
  'Image Providers': ['RUNWARE_API_KEY','WAVESPEED_API_KEY','TOGETHER_API_KEY','SEGMIND_API_KEY','NVIDIA_API_KEY'],
  'Payment': ['MIDTRANS_SERVER_KEY','MIDTRANS_CLIENT_KEY','TRIPAY_API_KEY','TRIPAY_PRIVATE_KEY','DUITKU_MERCHANT_CODE','DUITKU_API_KEY','NOWPAYMENTS_API_KEY'],
  'Storage': ['AWS_ACCESS_KEY_ID','AWS_SECRET_ACCESS_KEY','AWS_S3_BUCKET','R2_ACCESS_KEY_ID','R2_SECRET_ACCESS_KEY','R2_BUCKET_NAME','R2_ENDPOINT'],
};

async function loadApiKeys() {
  const el = document.getElementById('apikeys-container');
  el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted);">Loading...</div>';
  try {
    const res = await fetch('/api/admin/api-keys', { headers: { 'Authorization': 'Basic ' + btoa(':' + getToken()) }, credentials: 'include' });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const keys = await res.json();
    renderApiKeys(keys);
  } catch(e) {
    el.innerHTML = '<div style="color:#f87171;padding:20px;">Failed: ' + escHtml(e.message) + '</div>';
  }
}

function renderApiKeys(keys) {
  const el = document.getElementById('apikeys-container');
  const keyMap = Object.fromEntries(keys.map(k => [k.key, k]));
  let html = '';
  for (const [group, keyList] of Object.entries(AK_GROUPS)) {
    const gid = 'akgrp-' + group.replace(/\W/g,'_');
    html += '<div class="group-header" onclick="document.getElementById(\'' + gid + '\').style.display=document.getElementById(\'' + gid + '\').style.display===\'none\'?\'\':\'none\'">' +
      '<span class="group-title">' + escHtml(group) + '</span><span style="font-size:11px;color:var(--muted);">\u25BC</span>' +
      '</div><div class="group-body" id="' + gid + '">';
    for (const k of keyList) {
      const d = keyMap[k];
      if (!d) continue;
      const srcBadge = d.source === 'db' ? '<span class="badge badge-db">DB</span>' : d.source === 'env' ? '<span class="badge badge-default">ENV</span>' : '<span style="font-size:11px;color:#f87171;">not set</span>';
      html += '<div class="config-row">' +
        '<div><div class="config-key">' + escHtml(k) + '</div><div style="font-size:11px;color:var(--muted);margin-top:2px;">' + escHtml(d.label) + '</div></div>' +
        '<div class="config-val">' + (d.hasValue ? escHtml(d.masked) : '<span style="color:var(--muted);">\u2014</span>') + '</div>' +
        '<div class="actions">' + srcBadge +
        ' <button class="btn btn-ghost btn-sm" onclick="editApiKey(\'' + escAttr(k) + '\')">Edit</button>' +
        (d.source === 'db' ? ' <button class="btn btn-danger btn-sm" onclick="resetApiKey(\'' + escAttr(k) + '\')">Reset</button>' : '') +
        '</div></div>';
    }
    html += '</div>';
  }
  el.innerHTML = html;
}

async function editApiKey(keyName) {
  const newVal = prompt('New value for ' + keyName + ':\n(current: masked for security)');
  if (!newVal || !newVal.trim()) return;
  try {
    const res = await fetch('/api/admin/api-keys/' + encodeURIComponent(keyName), {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic ' + btoa(':' + getToken()) },
      credentials: 'include',
      body: JSON.stringify({ value: newVal.trim() })
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    toast('API key updated: ' + keyName, 'success');
    loadApiKeys();
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

async function resetApiKey(keyName) {
  if (!confirm('Remove DB override for ' + keyName + '? Will revert to env var.')) return;
  try {
    const res = await fetch('/api/admin/api-keys/' + encodeURIComponent(keyName), {
      method: 'DELETE',
      headers: { 'Authorization': 'Basic ' + btoa(':' + getToken()) },
      credentials: 'include'
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    toast('Reset to env: ' + keyName, 'success');
    loadApiKeys();
  } catch(e) { toast('Failed: ' + e.message, 'error'); }
}

// ── LOGOUT ───────────────────────────────────────────────────────────
function logout() {
  document.cookie = 'admin_token=; Max-Age=0; Path=/';
  window.location.href = '/admin/login';
}

// ── INIT ─────────────────────────────────────────────────────────────
// Handle hash-based tab navigation
(function() {
  const hash = location.hash.replace('#','');
  const tabMap = { 'api-keys': 'apikeys', 'apikeys': 'apikeys', 'runtime': 'runtime', 'tracking': 'tracking', 'broadcast': 'broadcast', 'general': 'general' };
  const tab = tabMap[hash] || 'general';
  if (tab !== 'general') {
    switchSettingsTab(tab);
  } else {
    loadSettingsTab('general');
  }
})();
</script>
