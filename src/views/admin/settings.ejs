<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin - Settings</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root { --bg: #0d0d14; --sidebar: #111118; --card: #1a1a24; --border: #2a2a3a; --gold: #c4a35a; --text: #e0e0f0; }
    body { background-color: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; }
    .sidebar { background-color: var(--sidebar); border-right: 1px solid var(--border); }
    .card { background-color: var(--card); border: 1px solid var(--border); }
    .btn-primary { background: var(--gold); color: #000; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: bold; }
  </style>
</head>
<body class="flex h-screen overflow-hidden">

  <!-- Sidebar -->
  <aside class="sidebar w-64 h-full flex flex-col hidden md:flex">
    <div class="p-6 border-b border-[var(--border)]">
      <h1 class="text-2xl font-bold" style="color: var(--gold)">OpenClaw <span class="text-white text-sm">v3.0</span></h1>
    </div>
    <nav class="flex-1 p-4 space-y-2">
      <a href="/admin/dashboard" class="block p-3 rounded hover:bg-[var(--card)] transition">📊 Analytics</a>
      <a href="/admin/users" class="block p-3 rounded hover:bg-[var(--card)] transition">👥 Users</a>
      <a href="/admin/pricing" class="block p-3 rounded hover:bg-[var(--card)] transition">💰 Pricing</a>
      <a href="/admin/prompts" class="block p-3 rounded hover:bg-[var(--card)] transition">📝 Prompts</a>
      <a href="/admin/settings" class="block p-3 rounded bg-[var(--card)] font-bold transition">⚙️ Settings</a>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto p-8">
    <h2 class="text-3xl font-bold mb-8">System Settings</h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Provider Settings -->
      <div class="card p-6 rounded-xl">
        <h3 class="text-xl font-bold mb-4 border-b border-[var(--border)] pb-2 flex justify-between items-center">
          AI Provider Priority
          <button onclick="saveProviders()" class="btn-primary text-sm">Save Priority</button>
        </h3>
        
        <div class="mb-4">
          <label class="block text-sm text-gray-400 mb-2">Video Providers (Lower Number = Higher Priority)</label>
          <div id="videoProviders" class="space-y-3">
            <!-- JS populated -->
          </div>
        </div>
      </div>

      <!-- Landing Page Config -->
      <div class="card p-6 rounded-xl">
        <h3 class="text-xl font-bold mb-4 border-b border-[var(--border)] pb-2 flex justify-between items-center">
          Landing Page Editor
          <button onclick="saveLanding()" class="btn-primary text-sm">Save Content</button>
        </h3>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Main Headline</label>
            <input type="text" id="lpHeadline" class="w-full bg-[var(--bg)] border border-[var(--border)] p-2 rounded text-white" placeholder="Bring Your AI Ideas to Life">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Sub-Headline</label>
            <textarea id="lpSub" class="w-full bg-[var(--bg)] border border-[var(--border)] p-2 rounded text-white h-24" placeholder="Generate cinematic AI videos directly from Telegram..."></textarea>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Call To Action Button</label>
            <input type="text" id="lpCta" class="w-full bg-[var(--bg)] border border-[var(--border)] p-2 rounded text-white" placeholder="Start Creating Now">
          </div>
        </div>
      </div>

    </div>

    <!-- Pricing Seed -->
    <div class="card p-6 rounded-xl mt-8">
      <h3 class="text-xl font-bold mb-4 border-b border-[var(--border)] pb-2">
        Pricing Data
      </h3>
      <p class="text-sm text-gray-400 mb-4">If the Pricing tab in the dashboard shows empty, seed the database with the default packages and subscription plans from the static config.</p>
      <button onclick="seedPricing()" class="btn-primary text-sm">🌱 Seed Default Pricing Data</button>
      <div id="seed-result" class="mt-3 text-sm text-gray-400"></div>
    </div>

    <!-- Referral Rates -->
    <div class="card p-6 rounded-xl mt-8">
      <h3 class="text-xl font-bold mb-4 border-b border-[var(--border)] pb-2 flex justify-between items-center">
        Referral Commission Rates
        <button onclick="saveReferralRates()" class="btn-primary text-sm">Save Rates</button>
      </h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1">Sell Rate (IDR per credit) — rate paid when user converts commission → credits</label>
          <input type="number" id="refSellRate" class="w-full bg-[var(--bg)] border border-[var(--border)] p-2 rounded text-white" placeholder="3000" min="100" step="100">
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Buy Rate (IDR per credit) — average credit purchase price (for reference)</label>
          <input type="number" id="refBuyRate" class="w-full bg-[var(--bg)] border border-[var(--border)] p-2 rounded text-white" placeholder="6000" min="100" step="100">
        </div>
        <p class="text-xs text-gray-500">Sell rate determines how many credits a user gets when converting commission. E.g., Rp 30,000 commission ÷ Rp 3,000 sell rate = 10 credits.</p>
      </div>
    </div>

  </main>

  <script>
    // HARDCODED DEFAULTS TO MOCK EXISTING KEYS
    const DEFAULT_VIDEO_KEYS = ['byteplus', 'xai', 'laozhang', 'evolink', 'falai_video', 'geminigen', 'siliconflow', 'piapi', 'remotion'];
    
    async function loadProviders() {
      const res = await fetch('/api/admin/settings/providers');
      const data = await res.json();
      const overrides = data.overrides?.video || {};

      const html = DEFAULT_VIDEO_KEYS.map(k => {
        const priority = overrides[k] ? overrides[k].priority : 99;
        const enabled = overrides[k] ? overrides[k].enabled : true;
        return \`
          <div class="flex items-center justify-between bg-[var(--bg)] p-3 rounded border border-[var(--border)]">
            <span class="font-bold">\${k}</span>
            <div class="flex space-x-4 items-center">
              <input type="number" id="prio_\${k}" value="\${priority}" class="w-16 bg-[var(--card)] border border-[var(--border)] p-1 rounded text-center text-white" title="Priority (Lower = First)">
              <label class="flex items-center space-x-2 text-sm">
                <input type="checkbox" id="en_\${k}" \${enabled ? 'checked':''} class="rounded bg-black border-gray-600">
                <span>Enabled</span>
              </label>
            </div>
          </div>
        \`;
      }).join('');
      document.getElementById('videoProviders').innerHTML = html;
    }

    async function saveProviders() {
      const video = {};
      DEFAULT_VIDEO_KEYS.forEach(k => {
        const val = parseInt(document.getElementById(\`prio_\${k}\`).value);
        const en = document.getElementById(\`en_\${k}\`).checked;
        video[k] = { priority: val, enabled: en };
      });

      await fetch('/api/admin/settings/providers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ video })
      });
      alert('Providers Saved!');
    }

    async function loadLanding() {
      const res = await fetch('/api/settings/landing');
      const data = await res.json();
      document.getElementById('lpHeadline').value = data.headline || '';
      document.getElementById('lpSub').value = data.subheadline || '';
      document.getElementById('lpCta').value = data.ctaText || '';
    }

    async function saveLanding() {
      const payload = {
        headline: document.getElementById('lpHeadline').value,
        subheadline: document.getElementById('lpSub').value,
        ctaText: document.getElementById('lpCta').value
      };
      await fetch('/api/settings/landing', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      alert('Landing Page config saved!');
    }

    async function seedPricing() {
      const res = await fetch('/api/settings/seed-pricing', { method: 'POST' });
      const data = await res.json();
      document.getElementById('seed-result').textContent = data.success
        ? `✅ Seeded ${data.seeded} pricing entries. Go to Pricing tab to view.`
        : '❌ Seed failed: ' + (data.error || 'Unknown');
    }

    async function loadReferralRates() {
      const res = await fetch('/api/settings/referral');
      const data = await res.json();
      document.getElementById('refSellRate').value = data.sellRate || 3000;
      document.getElementById('refBuyRate').value = data.buyRate || 6000;
    }

    async function saveReferralRates() {
      const sellRate = parseInt(document.getElementById('refSellRate').value);
      const buyRate = parseInt(document.getElementById('refBuyRate').value);
      if (!sellRate || sellRate <= 0 || !buyRate || buyRate <= 0) {
        alert('Both rates must be positive numbers.');
        return;
      }
      await fetch('/api/settings/referral', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sellRate, buyRate })
      });
      alert('Referral rates saved!');
    }

    loadProviders();
    loadLanding();
    loadReferralRates();
  </script>
</body>
</html>
