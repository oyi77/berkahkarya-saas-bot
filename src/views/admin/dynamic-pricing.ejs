<style>
  .pricing-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
  .provider-table { width: 100%; border-collapse: collapse; }
  .provider-table th { text-align: left; font-size: 11px; color: var(--muted); text-transform: uppercase; padding: 10px 12px; border-bottom: 1px solid var(--border); font-weight: 600; }
  .provider-table td { padding: 12px; border-bottom: 1px solid var(--border); font-size: 13px; vertical-align: middle; }
  .provider-table tr:hover { background: rgba(255,255,255,0.02); }
  .provider-table tr:last-child td { border-bottom: none; }
  .cost-source { font-size: 10px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .cost-source.api { background: rgba(74,222,128,0.15); color: #4ade80; }
  .cost-source.manual { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .cost-source.static { background: rgba(160,174,192,0.15); color: #a0aec0; }
  .cost-value { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 500; }
  .simulation-form { display: grid; gap: 12px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .price-result { background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.2); border-radius: 8px; padding: 16px; margin-top: 12px; }
  .price-result .label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .price-result .value { font-size: 24px; font-weight: 700; color: var(--green); margin-top: 4px; }
  .drift-alert { background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.2); border-radius: 8px; padding: 12px; margin-bottom: 16px; }
  .drift-alert.ok { background: rgba(74,222,128,0.08); border-color: rgba(74,222,128,0.2); }
  .recommendation-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; border-bottom: 1px solid var(--border); font-size: 13px; }
  .recommendation-item:last-child { border-bottom: none; }
  .recommendation-item .key { font-weight: 500; }
  .recommendation-item .diff { font-size: 12px; font-weight: 600; }
  .recommendation-item .diff.positive { color: var(--green); }
  .recommendation-item .diff.negative { color: var(--red); }
  .recommendation-item .diff.neutral { color: var(--muted); }
  @media (max-width: 768px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .provider-table th:nth-child(n+3), .provider-table td:nth-child(n+3) { display: none; }
  }
</style>

<div class="section-title">💵 Dynamic Pricing & Provider Costs</div>
<div class="section-sub">Real-time provider cost tracking and automatic price calculations based on cost + margin</div>

<!-- Tab Bar -->
<div class="tab-bar">
  <div class="tab active" data-tab="costs" onclick="switchTab('costs')">💰 Provider Costs</div>
  <div class="tab" data-tab="simulation" onclick="switchTab('simulation')">🧮 Price Simulator</div>
  <div class="tab" data-tab="recommendations" onclick="switchTab('recommendations')">📊 Recommendations</div>
</div>

<!-- Provider Costs Tab -->
<div id="tab-costs" class="tab-content">
  <!-- KPI Cards -->
  <div class="kpi-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
    <div class="kpi-card">
      <div class="label">Total Providers</div>
      <div class="value" id="summary-total">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">API Tracked</div>
      <div class="value" style="color: var(--green);" id="summary-api">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Manual</div>
      <div class="value" style="color: var(--yellow);" id="summary-manual">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Static</div>
      <div class="value" style="color: var(--muted);" id="summary-static">—</div>
    </div>
  </div>

  <!-- Drift Alert -->
  <div id="drift-alert" class="drift-alert" style="display: none;">
    <div style="display: flex; align-items: center; gap: 8px;">
      <span style="font-size: 18px;">⚠️</span>
      <div>
        <div style="font-weight: 600; font-size: 13px;" id="drift-title">Price Drift Detected</div>
        <div style="font-size: 12px; color: var(--muted);" id="drift-message">Some provider costs have changed significantly</div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="card" style="margin-bottom: 24px;">
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <span style="font-size: 13px; color: var(--muted);">Actions:</span>
      <button class="btn btn-gold btn-sm" onclick="syncAllCosts()">🔄 Sync from Config</button>
      <button class="btn btn-ghost btn-sm" onclick="checkDrift()">📊 Check Drift</button>
      <button class="btn btn-ghost btn-sm" onclick="loadProviderCosts()">🔃 Reload</button>
    </div>
  </div>

  <!-- Provider Costs Table -->
  <div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
      <div>
        <div style="font-size: 16px; font-weight: 600;">Provider Costs</div>
        <div style="font-size: 12px; color: var(--muted); margin-top: 2px;">Real-time cost tracking from API usage and manual input</div>
      </div>
    </div>

    <table class="provider-table">
      <thead>
        <tr>
          <th>Provider</th>
          <th>Cost (USD)</th>
          <th>Source</th>
          <th>Last Updated</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="provider-costs-body">
        <tr><td colspan="5" class="loading">Loading provider costs...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Simulation Tab -->
<div id="tab-simulation" class="tab-content" style="display: none;">
  <div class="pricing-grid">
    <div>
      <div class="card">
        <div style="font-size: 16px; font-weight: 600; margin-bottom: 4px;">Price Simulator</div>
        <div style="font-size: 12px; color: var(--muted); margin-bottom: 20px;">Calculate dynamic pricing based on provider cost + margin</div>

        <div class="simulation-form">
          <div>
            <label style="font-size: 11px; color: var(--muted); text-transform: uppercase; display: block; margin-bottom: 6px;">Provider</label>
            <select id="sim-provider" class="input" style="width: 100%;">
              <option value="omniroute">Omniroute (Auto-routing)</option>
              <option value="laozhang">LaoZhang</option>
              <option value="evolink">EvoLink</option>
              <option value="siliconflow">SiliconFlow</option>
              <option value="fal">Fal.ai</option>
              <option value="hypereal">Hypereal</option>
            </select>
          </div>

          <div>
            <label style="font-size: 11px; color: var(--muted); text-transform: uppercase; display: block; margin-bottom: 6px;">Units</label>
            <input type="number" id="sim-units" class="input" value="10" min="1" style="width: 100%;">
          </div>

          <div>
            <label style="font-size: 11px; color: var(--muted); text-transform: uppercase; display: block; margin-bottom: 6px;">Margin (%)</label>
            <input type="number" id="sim-margin" class="input" value="30" min="0" max="100" style="width: 100%;">
          </div>

          <div style="display: flex; align-items: flex-end;">
            <button class="btn btn-gold" style="width: 100%;" onclick="runSimulation()">Calculate Price</button>
          </div>
        </div>

        <div id="sim-result" style="display: none;">
          <div class="price-result">
            <div class="label">Final Price (IDR)</div>
            <div class="value" id="sim-price">—</div>
            <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(74,222,128,0.2); font-size: 12px; color: var(--muted);">
              <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                <span>Credits:</span>
                <span id="sim-credits" style="color: var(--text);">—</span>
              </div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                <span>Provider Cost:</span>
                <span id="sim-cost" style="color: var(--text);">—</span>
              </div>
              <div style="display: flex; justify-content: space-between;">
                <span>Margin:</span>
                <span id="sim-margin-value" style="color: var(--text);">—</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div>
      <div class="card">
        <div style="font-size: 14px; font-weight: 600; margin-bottom: 4px;">Quick Presets</div>
        <div style="font-size: 11px; color: var(--muted); margin-bottom: 12px;">Common scenarios</div>

        <div style="display: flex; flex-direction: column; gap: 8px;">
          <button class="btn btn-ghost btn-sm" style="justify-content: flex-start;" onclick="setPreset('video-15')">🎬 Video 15s (5 scenes)</button>
          <button class="btn btn-ghost btn-sm" style="justify-content: flex-start;" onclick="setPreset('video-30')">🎬 Video 30s (7 scenes)</button>
          <button class="btn btn-ghost btn-sm" style="justify-content: flex-start;" onclick="setPreset('video-60')">🎬 Video 60s (7 scenes)</button>
          <button class="btn btn-ghost btn-sm" style="justify-content: flex-start;" onclick="setPreset('image')">🖼️ Image Generation</button>
          <button class="btn btn-ghost btn-sm" style="justify-content: flex-start;" onclick="setPreset('image-set')">🖼️ Image Set (7 scenes)</button>
        </div>
      </div>

      <div class="card" style="margin-top: 16px;">
        <div style="font-size: 14px; font-weight: 600; margin-bottom: 4px;">Current Settings</div>
        <div style="font-size: 11px; color: var(--muted); margin-bottom: 12px;">Global pricing configuration</div>

        <div style="font-size: 12px; display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; justify-content: space-between;">
            <span style="color: var(--muted);">Default Margin:</span>
            <span id="current-margin">30%</span>
          </div>
          <div style="display: flex; justify-content: space-between;">
            <span style="color: var(--muted);">Exchange Rate:</span>
            <span id="current-rate">—</span>
          </div>
          <div style="display: flex; justify-content: space-between;">
            <span style="color: var(--muted);">Min Price Floor:</span>
            <span>100 IDR</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recommendations Tab -->
<div id="tab-recommendations" class="tab-content" style="display: none;">
  <div class="card" style="margin-bottom: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <div style="font-size: 16px; font-weight: 600; margin-bottom: 4px;">Dynamic Pricing Recommendations</div>
        <div style="font-size: 12px; color: var(--muted);">Recommended unit costs based on current provider costs</div>
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="btn btn-gold btn-sm" onclick="recalculatePrices()">🔄 Recalculate All</button>
        <button class="btn btn-ghost btn-sm" onclick="loadRecommendations()">🔃 Reload</button>
      </div>
    </div>
  </div>

  <div class="kpi-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
    <div class="kpi-card">
      <div class="label">Total Recommendations</div>
      <div class="value" id="rec-total">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Needs Update</div>
      <div class="value" style="color: var(--yellow);" id="rec-needs-update">—</div>
    </div>
    <div class="kpi-card">
      <div class="label">Up to Date</div>
      <div class="value" style="color: var(--green);" id="rec-current">—</div>
    </div>
  </div>

  <div class="card">
    <div style="font-size: 14px; font-weight: 600; margin-bottom: 16px;">Unit Cost Recommendations</div>
    <div id="recommendations-list">
      <div class="loading">Loading recommendations...</div>
    </div>
  </div>
</div>

<script>
const API_BASE = '/api/admin';
const TOKEN = document.cookie.match(/admin_token=([^;]+)/)?.[1];

async function apiCall(endpoint, options = {}) {
  const headers = { 'Content-Type': 'application/json' };
  if (TOKEN) headers['Cookie'] = `admin_token=${TOKEN}`;
  const res = await fetch(API_BASE + endpoint, { ...options, headers });
  if (!res.ok) throw new Error(`API error: ${res.status}`);
  return res.json();
}

function switchTab(tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[data-tab="${tab}"]`).classList.add('active');
  document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
  document.getElementById(`tab-${tab}`).style.display = 'block';

  if (tab === 'costs') loadProviderCosts();
  if (tab === 'recommendations') loadRecommendations();
  if (tab === 'simulation') loadCurrentSettings();
}

async function loadProviderCosts() {
  try {
    const data = await apiCall('/provider-costs');
    const tbody = document.getElementById('provider-costs-body');
    const summary = data.summary;

    document.getElementById('summary-total').textContent = summary.total;
    document.getElementById('summary-api').textContent = summary.apiTracked;
    document.getElementById('summary-manual').textContent = summary.manual;
    document.getElementById('summary-static').textContent = summary.static;

    tbody.innerHTML = data.costs.map(cost => `
      <tr>
        <td><span style="font-weight: 500;">${cost.providerKey}</span></td>
        <td><span class="cost-value">$${cost.costUsd.toFixed(4)}</span></td>
        <td><span class="cost-source ${cost.source}">${cost.source}</span></td>
        <td style="color: var(--muted); font-size: 12px;">${cost.lastUpdated ? new Date(cost.lastUpdated).toLocaleDateString() : 'Never'}</td>
        <td>
          <button class="btn btn-ghost btn-xs" onclick="refreshCost('${cost.providerKey}')">Refresh</button>
        </td>
      </tr>
    `).join('');

    await checkDrift();
  } catch (error) {
    console.error('Failed to load provider costs:', error);
    showToast('Failed to load provider costs', 'error');
  }
}

async function checkDrift() {
  try {
    const data = await apiCall('/dynamic-pricing/drift?threshold=10');
    const alert = document.getElementById('drift-alert');

    if (data.needsUpdate) {
      alert.style.display = 'block';
      alert.classList.remove('ok');
      document.getElementById('drift-title').textContent = `Price Drift Detected (${data.driftedProviders.length} providers)`;
      document.getElementById('drift-message').textContent = data.driftedProviders.map(p => `${p.providerKey}: ${p.driftPercent.toFixed(1)}%`).join(', ');
    } else {
      alert.style.display = 'block';
      alert.classList.add('ok');
      document.getElementById('drift-title').textContent = '✓ All Costs Stable';
      document.getElementById('drift-message').textContent = 'All provider costs are within the 10% threshold';
    }
  } catch (error) {
    console.error('Failed to check drift:', error);
  }
}

async function syncAllCosts() {
  try {
    const data = await apiCall('/provider-costs/sync', { method: 'POST' });
    showToast(data.message, 'success');
    await loadProviderCosts();
  } catch (error) {
    showToast('Failed to sync costs', 'error');
  }
}

async function refreshCost(providerKey) {
  try {
    const data = await apiCall(`/provider-costs/${providerKey}/refresh`, { method: 'POST' });
    showToast(data.message, 'success');
    await loadProviderCosts();
  } catch (error) {
    showToast('Failed to refresh cost', 'error');
  }
}

async function runSimulation() {
  try {
    const provider = document.getElementById('sim-provider').value;
    const units = parseInt(document.getElementById('sim-units').value);
    const margin = parseInt(document.getElementById('sim-margin').value);

    const data = await apiCall(`/dynamic-pricing/simulation?providerKey=${provider}&units=${units}&margin=${margin}`);

    document.getElementById('sim-result').style.display = 'block';
    document.getElementById('sim-price').textContent = `Rp ${data.priceIdr.toLocaleString()}`;
    document.getElementById('sim-credits').textContent = data.credits;
    document.getElementById('sim-cost').textContent = `$${data.costUsd.toFixed(4)}`;
    document.getElementById('sim-margin-value').textContent = `${data.marginPercent}%`;
  } catch (error) {
    showToast('Simulation failed', 'error');
  }
}

function setPreset(preset) {
  const presets = {
    'video-15': { units: 50, margin: 30 },
    'video-30': { units: 70, margin: 30 },
    'video-60': { units: 70, margin: 30 },
    'image': { units: 10, margin: 30 },
    'image-set': { units: 70, margin: 30 }
  };

  const p = presets[preset];
  if (p) {
    document.getElementById('sim-units').value = p.units;
    document.getElementById('sim-margin').value = p.margin;
    runSimulation();
  }
}

async function loadCurrentSettings() {
  try {
    const data = await apiCall('/settings');
    document.getElementById('current-margin').textContent = `${data.marginPercent || 30}%`;
    document.getElementById('current-rate').textContent = `Rp ${(data.usdToIdrRate || 16000).toLocaleString()}`;
  } catch (error) {
    console.error('Failed to load settings:', error);
  }
}

async function loadRecommendations() {
  try {
    const data = await apiCall('/dynamic-pricing/recommendations');
    const list = document.getElementById('recommendations-list');

    document.getElementById('rec-total').textContent = data.summary.total;
    document.getElementById('rec-needs-update').textContent = data.summary.needsUpdate;
    document.getElementById('rec-current').textContent = data.summary.total - data.summary.needsUpdate;

    list.innerHTML = data.recommendations.map(rec => {
      const diff = rec.difference;
      const diffClass = diff > 0 ? 'positive' : diff < 0 ? 'negative' : 'neutral';
      const diffText = diff > 0 ? `+${diff}` : diff.toString();

      return `
        <div class="recommendation-item">
          <div>
            <span class="key">${rec.key}</span>
            <div style="font-size: 11px; color: var(--muted); margin-top: 2px;">
              ${rec.credits} credits · ${rec.units} units · Rp ${rec.priceIdr.toLocaleString()}
            </div>
          </div>
          <div class="diff ${diffClass}">
            ${rec.needsUpdate ? '⚠️ ' : '✓ '}${diffText} units
          </div>
        </div>
      `;
    }).join('');
  } catch (error) {
    console.error('Failed to load recommendations:', error);
    showToast('Failed to load recommendations', 'error');
  }
}

async function recalculatePrices() {
  if (!confirm('Recalculate all unit costs based on current provider costs? This will update pricing in the database.')) return;

  try {
    const data = await apiCall('/dynamic-pricing/recalculate', { method: 'POST' });
    showToast(data.message, 'success');
    await loadRecommendations();
  } catch (error) {
    showToast('Failed to recalculate prices', 'error');
  }
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container') || (() => {
    const div = document.createElement('div');
    div.id = 'toast-container';
    document.body.appendChild(div);
    return div;
  })();

  const toast = document.createElement('div');
  toast.className = `toast toast-${type}`;
  toast.textContent = message;
  container.appendChild(toast);

  setTimeout(() => toast.remove(), 3000);
}

// Initial load
loadProviderCosts();
</script>
