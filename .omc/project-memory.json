    "scripts": {
      "dev": "tsx watch src/index.ts",
      "build": "tsc -p tsconfig.build.json",
      "start": "tsx src/index.ts",
      "start:prod": "NODE_ENV=production tsx src/index.ts",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:coverage": "jest --coverage",
      "test:e2e": "jest --config jest.e2e.config.js",
      "test:e2e:api": "jest --config jest.e2e.config.js",
      "test:e2e:playwright": "playwright test",
      "test:e2e:bot": "cd tests/e2e/bot && python3 -m pytest -v --tb=short",
      "lint": "eslint src/ --ext .ts",
      "lint:fix": "eslint src/ --ext .ts --fix",
      "format": "prettier --write \"src/**/*.ts\"",
      "format:check": "prettier --check \"src/**/*.ts\"",
      "typecheck": "tsc --noEmit",
      "migrate:dev": "prisma migrate dev",
      "migrate:prod": "prisma migrate deploy",
      "migrate:status": "prisma migrate status",
      "db:seed": "tsx prisma/seed.ts",
      "db:studio": "prisma studio",
      "db:generate": "prisma generate",
      "setup": "bash scripts/setup.sh",
      "deploy": "bash scripts/deploy.sh",
      "health-check": "bash scripts/health-check.sh",
      "backup": "bash scripts/backup.sh",
      "docker:build": "docker build -t openclaw-bot:latest .",
      "docker:run": "docker run -d --env-file .env -p 3000:3000 openclaw-bot:latest",
      "prepare": "husky install"
    }
  },
